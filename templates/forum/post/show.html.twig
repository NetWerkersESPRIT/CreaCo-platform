{# templates/forum/post/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
	{{ post.title }}
	- CreaCo Forum
{% endblock %}

{% block page_title %}Post
{% endblock %}
{% block page_subtitle %}Detailed Discussion
{% endblock %}

{% block body %}
	{% set postUrl = url('app_post_show', {'id': post.id}) %}

	<div
		class="flex flex-wrap -mx-3">
		<!-- Main Content (Centered & Wide) -->
		<div class="w-full max-w-full px-3 lg:w-10/12 mx-auto">

			<div class="flex items-center gap-4 mb-4 ml-1">
				<a href="{{ path('forum_index') }}" class="text-xs font-bold text-slate-400 hover:text-purple-700 uppercase transition-all">
					<i class="fas fa-arrow-left mr-1"></i>
					Back to Forum
				</a>
				{% if not app.user and not app.session.get('user_id') %}
					<span class="text-slate-300 text-xs">|</span>
					<a href="{{ path('app_visitor') }}" class="text-xs font-bold text-slate-400 hover:text-fuchsia-500 uppercase transition-all">
						<i class="fas fa-home mr-1"></i>
						Welcome Page
					</a>
				{% endif %}
			</div>

			<div class="relative flex flex-col min-w-0 break-words bg-white border border-gray-100 shadow-soft-xl rounded-2xl bg-clip-border mb-6">
				<!-- Post Header -->
				<div class="p-6">
					<div class="flex items-start gap-4">
                        <!-- User Avatar with Gradient Border -->
                        <div class="relative shrink-0">
                            <div class="p-[2px] rounded-full bg-gradient-to-tr from-purple-700 to-pink-500">
                                <div class="bg-white p-[2px] rounded-full">
                                    <img src="{{ post.user and post.user.image ? post.user.image : 'https://ui-avatars.com/api/?name=' ~ (post.user ? post.user.username|url_encode : 'A') ~ '&background=random&color=fff' }}" 
                                         class="w-12 h-12 rounded-full object-cover" alt="avatar">
                                </div>
                            </div>
                        </div>

                        <div class="grow">
    						<h4 class="mb-0 font-bold text-slate-700 text-xl">{{ post.title }}</h4>
                            <p class="mb-4 text-xs text-slate-400">
                                Posted by 
                                <span class="font-bold text-slate-500">{{ post.user ? post.user.username : 'Anonymous' }}</span>
                                • 
                                {{ post.createdAt ? post.createdAt|date('d/m/Y') : '' }}
                            </p>

                            <div class="post-body text-slate-600 leading-relaxed mb-6 text-sm">
                                {{ post.content|raw }}
                            </div>
                        </div>
					</div>

					{# ✅ PDF BLOCK (Drive first, fallback to local) #}
					{% if post.pdfName %}
						<div class="mb-6 p-4 bg-gray-50 rounded-xl border border-dashed border-gray-200 flex items-center justify-between">
							<div class="flex items-center">
								<div class="bg-red-100 p-2 rounded-lg mr-3">
									<i class="fas fa-file-pdf text-red-600 text-lg"></i>
								</div>
								<div>
									<p class="text-sm font-bold text-slate-700 mb-0">PDF Document</p>
									<p class="text-xxs text-slate-400 mb-0">Local upload</p>
								</div>
							</div>

							<a href="{{ asset('uploads/' ~ post.pdfName) }}" target="_blank" class="px-6 py-2.5 text-xs font-bold text-center text-white uppercase align-middle transition-all border-0 rounded-lg cursor-pointer shadow-soft-md hover:scale-102 hover:shadow-soft-lg active:opacity-85 tracking-tight-soft bg-gradient-to-tl from-purple-700 to-pink-500">
								<i class="fas fa-eye mr-1"></i>
								View
							</a>
						</div>
					{% endif %}

					<div class="mt-4 pt-4 border-t border-gray-100 flex flex-wrap items-center justify-between gap-4">
						<div class="flex flex-wrap items-center gap-3">
							{% set likedPosts = app.session.get('liked_posts', []) %}
							{% set isLiked = post.id in likedPosts %}

							<!-- Share Button -->
							<div class="relative inline-block text-left">
								<button type="button" onclick="toggleShareDropdown('shareDropdown-{{ post.id }}')" class="bg-transparent flex items-center px-2 py-2 text-slate-500 hover:text-purple-700 transition-all border-0 cursor-pointer group">
									<span class="text-xs font-medium mr-2">↪</span>
									<span class="text-xs font-bold tracking-tight">Share</span>
								</button>
                                <!-- ... dropdown content omitted for brevity but preserved in file ... -->

								<div id="shareDropdown-{{ post.id }}" class="share-dropdown-menu hidden absolute left-0 bottom-full mb-2 w-56 bg-white border border-gray-100 rounded-xl shadow-soft-2xl z-50 py-2 text-left animate-fade-in">
									<button type="button" onclick="shareOnTwitter('{{ post.title|e('js') }}', '{{ post.content|striptags|slice(0, 160)|e('js') }}', '{{ post.user ? post.user.username|e('js') : 'Anonymous' }}')" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-gray-50 flex items-center border-0 bg-transparent cursor-pointer">
										<i class="fab fa-twitter mr-2 w-4 text-sky-500"></i>
										Share on Twitter
									</button>

									<button type="button" onclick="shareOnWhatsApp('{{ post.title|e('js') }}', '{{ post.content|striptags|slice(0, 160)|e('js') }}', '{{ post.user ? post.user.username|e('js') : 'Anonymous' }}')" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-gray-50 flex items-center border-0 bg-transparent cursor-pointer">
										<i class="fab fa-whatsapp mr-2 w-4 text-green-500"></i>
										Share on WhatsApp
									</button>

									<button type="button" onclick="copyPageUrl('{{ postUrl|e('js') }}', 'shareDropdown-{{ post.id }}')" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-gray-50 flex items-center border-0 bg-transparent cursor-pointer">
										<i class="fas fa-link mr-2 w-4 text-purple-700"></i>
										Copy Link
									</button>

									<div class="border-t border-gray-100 my-1"></div>

									<button type="button" onclick="generateQRCode('{{ post.title|e('js') }}', '{{ post.content|striptags|slice(0, 160)|e('js') }}', '{{ post.user ? post.user.username|e('js') : 'Anonymous' }}')" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-gray-50 flex items-center border-0 bg-transparent cursor-pointer">
										<i class="fas fa-qrcode mr-2 w-4 text-slate-700"></i>
										Generate QR Code
									</button>
								</div>
							</div>

							<!-- Reactions Button (Styled as Pill) -->
							<div class="reaction-container relative group">
								{% set userReaction = null %}
								{% if app_user %}
									{% for r in post.reactions %}
										{% if r.user == app_user %}
											{% set userReaction = r.type %}
										{% endif %}
									{% endfor %}
								{% endif %}

								<!-- Reaction Popup Bar -->
								<div class="reaction-bar hidden group-hover:flex absolute bottom-full mb-3 left-0 bg-white shadow-soft-2xl rounded-full px-1.5 py-1 items-center gap-1 animate-reaction-pop z-50 border border-gray-100">
									<button type="button" onclick="handleReaction({{ post.id }}, 'like')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Like">
										<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png" class="w-7 h-7" alt="👍">
									</button>
									<button type="button" onclick="handleReaction({{ post.id }}, 'love')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Love">
										<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png" class="w-7 h-7" alt="❤️">
									</button>
									<button type="button" onclick="handleReaction({{ post.id }}, 'haha')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Haha">
										<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png" class="w-7 h-7" alt="😂">
									</button>
									<button type="button" onclick="handleReaction({{ post.id }}, 'wow')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Wow">
										<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png" class="w-7 h-7" alt="😮">
									</button>
									<button type="button" onclick="handleReaction({{ post.id }}, 'sad')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Sad">
										<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png" class="w-7 h-7" alt="😢">
									</button>
									<button type="button" onclick="handleReaction({{ post.id }}, 'angry')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Angry">
										<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png" class="w-7 h-7" alt="😡">
									</button>
								</div>

								<!-- Main Button (Pill Style) -->
								<button id="react-btn-{{ post.id }}" type="button" onclick="handleReaction({{ post.id }}, '{{ userReaction ?: 'like' }}')" class="flex items-center gap-2 px-4 py-1.5 bg-[#f8f9fa] rounded-full border border-gray-200 cursor-pointer hover:bg-gray-200 transition-all text-slate-600 text-[10px] font-bold uppercase tracking-wider shadow-none">
									<i class="fas fa-thumbs-up {{ userReaction ? 'text-fuchsia-600' : 'text-slate-500' }}"></i>
									<span>LIKE {{ post.reactions|length }}</span>
								</button>
							</div>

							<!-- Replies Count (Styled as Pill) -->
							<div class="flex items-center gap-2 px-4 py-1.5 bg-[#f8f9fa] rounded-full border border-gray-200 text-slate-600 text-[10px] font-bold uppercase tracking-wider shadow-none">
								<i class="fas fa-comment text-slate-500"></i>
								<span>
									{% set count = 0 %}
									{% for c in post.comments %}
										{% if c.status in ['visible', 'solution'] or (app_user and c.user == app_user) or isAdmin %}
											{% set count = count + 1 %}
										{% endif %}
									{% endfor %}
									{{ count }} REPLIES</span>
							</div>
						</div>

						<!-- Admin/Owner Actions (Icons only, rounded) -->
						<div class="flex items-center gap-2">
                            {% set isAdmin = is_granted('ROLE_ADMIN') or app.session.get('user_role') == 'ROLE_ADMIN' %}
						    {% set isPostOwner = app_user and post.user == app_user %}

							{% if isAdmin %}
								<form action="{{ path('app_post_pin', {'id': post.id}) }}" method="POST" class="m-0" id="pin-form">
									<button type="button" onclick="confirmAction('{{ post.pinned ? 'Unpin' : 'Pin' }} Post?', 'Do you want to {{ post.pinned ? 'unpin' : 'pin' }} this post?', 'question', 'Yes').then(c => { if(c) document.getElementById('pin-form').submit(); })" class="flex items-center justify-center w-8 h-8 rounded-lg bg-[#f8f9fa] border border-gray-200 {{ post.pinned ? 'text-purple-600' : 'text-slate-600' }} hover:bg-gray-200 transition-all cursor-pointer shadow-none" title="{{ post.pinned ? 'Unpin' : 'Pin' }}">
										<i class="fas fa-thumbtack text-xs"></i>
									</button>
								</form>
							{% endif %}

							{% if isAdmin or isPostOwner %}
								<form action="{{ path('app_post_toggle_lock', {'id': post.id}) }}" method="POST" class="m-0" id="lock-form">
									<button type="button" onclick="confirmAction('{{ post.isCommentLocked ? 'Unlock' : 'Lock' }} Comments?', 'Do you want to {{ post.isCommentLocked ? 'enable' : 'disable' }} comments for this post?', '{{ post.isCommentLocked ? 'info' : 'warning' }}', 'Yes').then(c => { if(c) document.getElementById('lock-form').submit(); })" class="flex items-center justify-center w-8 h-8 rounded-lg bg-[#f8f9fa] border border-gray-200 {{ post.isCommentLocked ? 'text-green-500' : 'text-slate-600' }} hover:bg-gray-200 transition-all cursor-pointer shadow-none" title="{{ post.isCommentLocked ? 'Enable comments' : 'Disable comments' }}">
										<i class="fas {{ post.isCommentLocked ? 'fa-lock-open' : 'fa-lock' }} text-xs"></i>
									</button>
								</form>

								<a href="{{ path('app_post_edit', {'id': post.id}) }}" class="flex items-center justify-center w-8 h-8 rounded-lg bg-[#f8f9fa] border border-gray-100 text-slate-600 hover:text-purple-600 hover:bg-gray-200 transition-all shadow-none" title="Edit">
									<i class="fas fa-pencil-alt text-xs"></i>
								</a>

								<form action="{{ path('app_post_delete', {'id': post.id}) }}" method="POST" class="m-0" id="del-post-show-{{ post.id }}">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
									<button type="button" onclick="confirmDelete(document.getElementById('del-post-show-{{ post.id }}'), '{{ post.title|e('js') }}')" class="flex items-center justify-center w-8 h-8 rounded-lg bg-[#f8f9fa] border border-gray-100 text-slate-600 hover:text-red-600 hover:bg-gray-200 transition-all cursor-pointer shadow-none">
										<i class="fas fa-trash-alt text-xs"></i>
									</button>
								</form>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

			<!-- Comments Section -->
			<div class="relative flex flex-col min-w-0 break-words bg-white border border-gray-100 shadow-soft-xl rounded-2xl bg-clip-border mb-6">
				<div class="flex-auto p-0">
					<div class="p-6 border-b border-gray-100 flex items-center">
						<h6 class="font-bold mb-0 text-slate-700">Comments</h6>
                        <span class="text-slate-400 text-xs ml-2">• 
                            {% set count = 0 %}
                            {% for c in post.comments %}
                                {% if c.status in ['visible', 'solution'] or (app_user and c.user == app_user) or isAdmin %}
                                    {% set count = count + 1 %}
                                {% endif %}
                            {% endfor %}
                            {{ count }} comments
                        </span>
					</div>

					<div class="p-6">
                        <!-- Comments Tree -->
                        <div id="comments-tree" class="space-y-4 mb-8">
                            {% import _self as macros %}
                            {% for comment in comments %}
                                {{ macros.render_comment(comment, post, app_user, 0) }}
                            {% else %}
                                <div class="text-center py-12 flex flex-col items-center">
                                    <div class="bg-slate-800 rounded-full w-12 h-12 flex items-center justify-center mb-4 shadow-soft-lg">
                                        <i class="fas fa-comment text-white text-xl"></i>
                                    </div>
                                    <h6 class="font-bold text-slate-700 mb-1">No comments yet</h6>
                                    <p class="text-xs text-slate-400">Be the first to share your thoughts!</p>
                                </div>
                            {% endfor %}
                        </div>

                        {% if not post.isCommentLocked %}
                            <div class="border-t border-gray-100 pt-6">
                                {{ form_start(commentForm, {'action': path('app_comment_new', {'id': post.id}), 'method': 'POST', 'attr': {'novalidate': 'novalidate', 'class': 'relative'}}) }}
                                    <div class="flex items-center gap-3">
                                        <div class="shrink-0">
                                            <img src="{{ app_user and app_user.image ? app_user.image : 'https://ui-avatars.com/api/?name=' ~ (app_user ? app_user.username|url_encode : 'A') ~ '&background=random&color=fff' }}" 
                                                 class="w-10 h-10 rounded-full border border-gray-100 shadow-soft-xs" alt="user avatar">
                                        </div>
                                        
                                        <div class="relative grow bg-slate-50 rounded-2xl flex items-center px-4 py-1.5 border border-transparent focus-within:border-purple-200 focus-within:bg-white transition-all group">
                                            <button type="button" class="text-slate-400 hover:text-purple-600 transition-colors border-0 bg-transparent p-0 cursor-pointer">
                                                <i class="far fa-smile text-lg"></i>
                                            </button>
                                            
                                            {{ form_widget(commentForm.body, {'attr': {
                                                'class': 'grow bg-transparent border-0 focus:ring-0 text-sm py-2 px-3 text-slate-700 min-h-[40px] focus:outline-none',
                                                'placeholder': 'Add a comment...',
                                                'rows': '1'
                                            }}) }}

                                            <div class="flex items-center gap-2">
                                                <span class="bg-slate-200 text-slate-500 text-[10px] font-bold px-1.5 py-0.5 rounded uppercase">GIF</span>
                                                <button type="submit" class="bg-transparent border-0 text-fuchsia-600 font-bold text-sm hover:scale-110 transition-transform cursor-pointer px-2">Post</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-[10px] text-red-500 mt-1 ml-14">
                                        {{ form_errors(commentForm.body) }}
                                    </div>
                                {{ form_end(commentForm) }}
                            </div>
                        {% else %}
                            <div class="p-6 bg-orange-50/50 rounded-2xl border border-orange-100 text-center">
                                <i class="fas fa-lock text-orange-600 mb-2 text-xl"></i>
                                <p class="text-xs font-bold text-orange-800 mb-0">The comment section is locked.</p>
                            </div>
                        {% endif %}
					</div>
				</div>
			</div>

		</div>
	</div>

	{% macro render_comment(comment, post, app_user, depth) %}
		{% import _self as macros %}
		{% set isAdmin = is_granted('ROLE_ADMIN') or app.session.get('user_role') == 'ROLE_ADMIN' %}
		{% set isCommentOwner = app_user and comment.user == app_user %}

		<div class="relative group mt-4">
			{% if depth > 0 %}
				<div class="absolute left-[-1.5rem] top-0 bottom-0 w-[1px] bg-slate-100 group-hover:bg-purple-200 transition-colors"></div>
			{% endif %}

			<div class="flex">
				<div class="flex-shrink-0 mr-3">
					<img src="{{ comment.user and comment.user.image ? comment.user.image : 'https://ui-avatars.com/api/?name=' ~ (comment.user ? comment.user.username|url_encode : 'Anonymous') ~ '&background=random&color=fff' }}" class="w-8 h-8 rounded-full shadow-soft-xs border border-gray-100" alt="avatar">
				</div>

				<div class="flex-grow">
					<div class="flex items-center mb-1">
						<span class="text-xs font-bold text-slate-700 mr-2">{{ comment.user ? comment.user.username : 'Anonymous' }}</span>
						<span class="text-[10px] text-slate-400 capitalize">{{ comment.createdAt|date('d/m/Y H:i') }}</span>

						{% if comment.status == 'solution' or post.solution == comment %}
							<span class="ml-2 px-2 py-0.5 text-[9px] font-bold text-green-600 bg-green-100 rounded-lg uppercase">
								<i class="fas fa-check-circle mr-1"></i>
								Solution
							</span>
						{% endif %}

						{% if comment.status == 'pending' %}
							<span class="ml-2 px-2 py-0.5 text-[9px] font-bold text-orange-600 bg-orange-100 rounded-lg uppercase">
								<i class="fas fa-clock mr-1"></i>
								Pending Approval
							</span>
						{% endif %}
					</div>

					<div class="text-sm text-slate-600 leading-relaxed font-normal">
						{{ comment.body|nl2br }}
					</div>

					<div class="flex items-center mt-3 gap-6 opacity-80 hover:opacity-100 transition-opacity">
						{% set isCommentLiked = app_user ? comment.isLikedByUser(app_user) : false %}
						<button onclick="handleCommentLike({{ comment.id }})" id="comment-like-btn-{{ comment.id }}" class="bg-transparent border-0 p-0 text-xs font-semibold uppercase cursor-pointer transition-all flex items-center {{ isCommentLiked ? 'text-fuchsia-600' : 'text-slate-500 hover:text-fuchsia-600' }}">
							<i class="{{ isCommentLiked ? 'fas' : 'far' }} fa-heart mr-2 transition-colors"></i>
							<span id="comment-like-count-{{ comment.id }}" class="text-[10px]">{{ comment.likes > 0 ? comment.likes : '' }}</span>
						</button>

						{% if not post.isCommentLocked and app_user %}
							<button onclick="document.getElementById('reply-form-{{ comment.id }}').classList.toggle('hidden')" class="bg-transparent border-0 p-0 text-xs font-semibold text-slate-500 hover:text-purple-600 uppercase cursor-pointer transition-all flex items-center" title="Reply">
								<i class="fas fa-reply mr-2 transition-colors"></i>
							</button>
						{% endif %}

						{% if isCommentOwner %}
							<a href="{{ path('app_comment_edit', {'id': comment.id}) }}" class="text-xs font-semibold text-slate-500 hover:text-blue-600 uppercase transition-all flex items-center no-underline" title="Edit">
								<i class="fas fa-pencil-alt mr-2 transition-colors"></i>
							</a>
						{% endif %}

						{% if isCommentOwner or isAdmin %}
							<form action="{{ path('app_comment_delete', {'id': comment.id}) }}" method="POST" class="inline m-0" id="del-cmt-{{ comment.id }}">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
								<button type="button" onclick="confirmDelete(document.getElementById('del-cmt-{{ comment.id }}'), 'this comment')" class="bg-transparent border-0 p-0 text-xs font-semibold text-slate-500 hover:text-red-500 uppercase cursor-pointer transition-all flex items-center" title="Delete">
									<i class="fas fa-trash-alt mr-2 transition-colors"></i>
								</button>
							</form>
						{% endif %}

						{% if (isAdmin or (app_user and post.user == app_user)) and post.solution != comment and post.status != 'solved' %}
							<form action="{{ path('app_comment_solve', {'id': comment.id}) }}" method="POST" class="inline m-0">
								<button type="submit" class="bg-transparent border-0 p-0 text-xs font-semibold text-slate-500 hover:text-green-500 uppercase cursor-pointer transition-all flex items-center" title="Mark as Solution">
									<i class="fas fa-check-double mr-2 transition-colors"></i>
								</button>
							</form>
						{% endif %}
					</div>

					<div id="reply-form-{{ comment.id }}" class="hidden mt-4 bg-gray-50/50 p-4 rounded-2xl border border-gray-100 shadow-soft-xs">
						<form action="{{ path('app_comment_new', {'id': post.id}) }}" method="POST" onsubmit="return validateReply(this, '{{ comment.id }}')" novalidate="novalidate">
							<input type="hidden" name="comment[_token]" value="{{ csrf_token('comment') }}">
							<input type="hidden" name="parent_id" value="{{ comment.id }}">

							<textarea name="comment[body]" class="block w-full px-4 py-3 text-sm text-slate-700 border border-gray-100 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 transition-all bg-white" placeholder="Your reply..." rows="2"></textarea>

							<div id="reply-error-{{ comment.id }}" class="text-xs text-red-500 mt-1 hidden">
								Comment content is required.
							</div>

							<div class="mt-2 flex justify-end">
								<button type="submit" class="px-5 py-2 text-[10px] font-bold text-white uppercase bg-gradient-to-tl from-purple-700 to-pink-500 rounded-lg shadow-soft-md hover:scale-102 transition-all border-0 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
									Reply
								</button>
							</div>
						</form>
					</div>

					{% if comment.replies|length > 0 %}
						<div class="ml-6 mt-2">
							{% for reply in comment.replies %}
								{% if reply.status in ['visible', 'solution'] or (app_user and reply.user == app_user) or isAdmin %}
									{{ macros.render_comment(reply, post, app_user, depth + 1) }}
								{% endif %}
							{% endfor %}
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	{% endmacro %}
{% endblock %}

