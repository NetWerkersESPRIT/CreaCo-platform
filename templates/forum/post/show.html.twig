async function handleReaction(postId, type) {
const btn = document.getElementById (`react-btn-${postId}`);
const countSpan = document.getElementById (`react-count-${postId}`);

try {
const response = await fetch (`/posts/${postId}/react`, {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify({type})
});

if (response.status === 401) {
window.location.href = "{{ path('app_auth') }}";
return;
}

const data = await response.json();
if (data.success) { // Update Count
countSpan.textContent = data.counts.total;

// Update Button UI
if (data.user_reaction) {
const react = reactionMap[data.user_reaction];
btn.innerHTML = `
							<img src="${
react.emoji
}" class="w-5 h-5 mr-1" alt="${
data.user_reaction
}">
							<span>${
react.label
}</span>
							<span id="react-count-${postId}" class="ml-1 text-[10px] text-slate-400">
								${
data.counts.total
}
							</span>
						`;
btn.classList.add('text-fuchsia-700');
btn.classList.remove('text-slate-600');

// Re-assign countSpan reference because innerHTML changed
const newCountSpan = document.getElementById (`react-count-${postId}`);
newCountSpan.classList.add('animate-reaction-pop');
} else {
btn.innerHTML = `
							<i class="far fa-thumbs-up text-slate-400 transition-colors"></i>
							<span>Like</span>
							<span id="react-count-${postId}" class="ml-1 text-[10px] text-slate-400">
								${
data.counts.total
}
							</span>
						`;
btn.classList.remove('text-fuchsia-700');
btn.classList.add('text-slate-600');
}
}
} catch (err) {
console.error('Reaction failed', err);
}
}

async function handleCommentLike(commentId) {
	const btn = document.getElementById(`comment-like-btn-${commentId}`);
	const countSpan = document.getElementById(`comment-like-count-${commentId}`);
	const icon = btn.querySelector('i');

	try {
		const response = await fetch(`/comment/${commentId}/like`, {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json'
			}
		});

		if (response.status === 401) {
			window.location.href = "{{ path('app_auth') }}";
			return;
		}

		const data = await response.json();
		if (data.success) {
			countSpan.textContent = data.likes > 0 ? data.likes : '';
			if (data.isLiked) {
				btn.classList.add('text-fuchsia-600');
				btn.classList.remove('text-slate-500', 'hover:text-fuchsia-600');
				icon.classList.remove('far');
				icon.classList.add('fas');
			} else {
				btn.classList.remove('text-fuchsia-600');
				btn.classList.add('text-slate-500', 'hover:text-fuchsia-600');
				icon.classList.remove('fas');
				icon.classList.add('far');
			}
		}
	} catch (err) {
		console.error('Comment like failed', err);
	}
}

// Long-press support for mobile
document.addEventListener('DOMContentLoaded', () => {
let pressTimer;
const container = document.querySelector('.reaction-container');
if (! container) 
return;



const btn = container.querySelector('button[id^="react-btn-"]');
const bar = container.querySelector('.reaction-bar');

const start = (e) => {
pressTimer = setTimeout(() => {
bar.classList.remove('hidden');
bar.classList.add('flex');
}, 500);
};

const cancel = (e) => {
clearTimeout(pressTimer);
};

btn.addEventListener('touchstart', start);
btn.addEventListener('touchend', cancel);
btn.addEventListener('mousedown', start);
btn.addEventListener('mouseup', cancel);
btn.addEventListener('mouseleave', cancel);

// Hide bar when clicking a reaction
bar.addEventListener('click', () => {
bar.classList.add('hidden');
bar.classList.remove('flex');
});

// Hide bar when clicking outside
document.addEventListener('click', (e) => {
if (!e.target.closest('.reaction-container')) {
bar.classList.add('hidden');
bar.classList.remove('flex');
}
});
});
	</script>
