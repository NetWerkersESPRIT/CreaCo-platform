function validateReply(form, id) {
const textarea = form.querySelector('textarea[name="comment[body]"]');
const errorDiv = document.getElementById('reply-error-' + id);
const submitBtn = form.querySelector('button[type="submit"]');

if (textarea.value.trim().length === 0) {
errorDiv.classList.remove('hidden');
textarea.classList.add('border-red-500');
textarea.focus();
return false;
}

// Success - show loading state
errorDiv.classList.add('hidden');
textarea.classList.remove('border-red-500');
submitBtn.disabled = true;
submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Loading...';

return true;
}

// --- OpenRouter AI Integration ---
function callOpenRouter(action, postId) {
    Swal.fire({
        title: 'Asking AI...',
        text: 'Please wait while we process the content.',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
    });

    const content = document.querySelector('.post-body').innerText;

    fetch('/api/forum/ai/' + action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
    })
    .then(r => r.json())
    .then(data => {
        if (data.error) throw new Error(data.error);
        
        // Show result in a nice modal
        Swal.fire({
            title: action === 'explain' ? 'AI Explanation' : 'AI Solution',
            html: `<div style="text-align:left; font-size:14px; line-height:1.6; color:#334155; padding:10px; background:#f8fafc; border-radius:8px; border:1px solid #e2e8f0; max-height:400px; overflow-y:auto;">${data.result.replace(/\n/g, '<br>')}</div>`,
            icon: 'info',
            showCancelButton: true,
            showDenyButton: true,
            confirmButtonText: 'Got it!',
            cancelButtonText: '<i class="fas fa-copy"></i> Copy',
            denyButtonText: '<i class="fas fa-comment"></i> Post',
            customClass: {
                confirmButton: 'inline-block px-4 py-2 mx-1 font-bold text-center text-white uppercase bg-gradient-to-tl from-purple-700 to-pink-500 rounded-lg shadow-soft-md text-[10px]',
                cancelButton: 'inline-block px-4 py-2 mx-1 font-bold text-center text-slate-700 uppercase bg-gray-100 hover:bg-gray-200 rounded-lg shadow-soft-md text-[10px]',
                denyButton: 'inline-block px-4 py-2 mx-1 font-bold text-center text-white uppercase bg-indigo-500 hover:bg-indigo-600 rounded-lg shadow-soft-md text-[10px]'
            },
            buttonsStyling: false
        }).then((result) => {
            if (result.isDenied) {
                // Post as comment
                const textarea = document.querySelector('.comment-textarea');
                if (textarea) {
                    textarea.value += (textarea.value ? '\n\n' : '') + data.result;
                    textarea.focus();
                    textarea.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            } else if (result.dismiss === Swal.DismissReason.cancel) {
                // Copy to clipboard
                navigator.clipboard.writeText(data.result).then(() => {
                    Swal.fire({
                        title: 'Copied!',
                        text: 'AI response copied to clipboard',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    });
                });
            }
        });
    })
    .catch(err => {
        Swal.fire('Error', err.message || 'Failed to get AI response.', 'error');
    });
}

// --- Klipy GIF Integration ---
function openGifPicker(btnElement) {
    const textarea = btnElement.closest('.relative').querySelector('textarea');

    Swal.fire({
        title: 'Choose a GIF',
        html: `
            <input type="text" id="swal-gif-search" class="w-full px-4 py-2 mb-4 border border-gray-200 rounded-lg focus:outline-none focus:border-purple-500 text-sm" placeholder="Search GIFs...">
            <div id="swal-gif-grid" class="grid grid-cols-3 gap-2 max-h-[300px] overflow-y-auto p-2 bg-gray-50 rounded-lg">
                <div class="col-span-3 text-center text-gray-500 text-sm py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Loading trending GIFs...</div>
            </div>
        `,
        showConfirmButton: false,
        showCloseButton: true,
        didOpen: () => {
            const searchInput = document.getElementById('swal-gif-search');
            const grid = document.getElementById('swal-gif-grid');
            let timeout = null;

            const loadGifs = (query = '') => {
                const url = query ? '/api/forum/gifs/search?q=' + encodeURIComponent(query) : '/api/forum/gifs/trending';
                grid.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Loading...</div>';
                
                fetch(url)
                    .then(r => r.json())
                    .then(data => {
                        if (!data.gifs || data.gifs.length === 0) {
                            grid.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4">No GIFs found</div>';
                            return;
                        }
                        
                        grid.innerHTML = data.gifs.map(gifUrl => `
                            <img src="${gifUrl}" class="w-full h-24 object-cover rounded cursor-pointer hover:opacity-80 transition-opacity" 
                                 onclick="insertGif('${gifUrl}')">
                        `).join('');
                    });
            };

            // Expose insert function globally so onclick can access it
            window.insertGif = (url) => {
                const gifTag = ` [gif]${url}[/gif] `;
                textarea.value += gifTag;
                textarea.focus();
                Swal.close();
            };

            searchInput.addEventListener('input', (e) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => loadGifs(e.target.value), 500);
            });

            loadGifs();
        }
    });
}

// Parse GIF tags in comments on load and handle AI drafts
document.addEventListener('DOMContentLoaded', () => {
    // Draft logic from list view
    const postId = {{ post.id }};
    const draft = sessionStorage.getItem('ai_draft_' + postId);
    if (draft) {
        const textarea = document.querySelector('.comment-textarea');
        if (textarea) {
            textarea.value = draft;
            textarea.focus();
            textarea.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        sessionStorage.removeItem('ai_draft_' + postId);
    }

    // GIF parsing
    document.querySelectorAll('.comment-body-content').forEach(el => {
        let html = el.innerHTML;
        // Regex to find [gif]...[/gif]
        const gifRegex = /\[gif\](https?:\/\/[^\[]+)\[\/gif\]/g;
        if (gifRegex.test(html)) {
            html = html.replace(gifRegex, '<img src="$1" class="max-h-48 rounded-lg mt-3 block shadow-soft-sm border border-gray-100">');
            el.innerHTML = html;
        }
    });
});

