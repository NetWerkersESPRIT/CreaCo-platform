{% extends 'base.html.twig' %}

{% block title %}Forum - CreaCo
{% endblock %}
{% block page_title %}Forum
{% endblock %}
{% block page_subtitle %}News Feed
{% endblock %}

{% block body %}
	<div
		class="flex flex-wrap -mx-3 justify-center">
		<!-- Main Feed Section (Centered & Wide) -->
		<div
			class="w-full max-w-full px-3 lg:w-10/12 mx-auto">

			<!-- Forum Header & Unified Search -->
			<div class="mb-6">
				<div class="relative flex flex-wrap justify-between items-center bg-white shadow-soft-xl rounded-2xl p-6 mb-4 gap-4">
					<div class="flex items-center gap-4 flex-grow max-w-2xl">
						<h6 class="mb-0 font-bold text-slate-700 whitespace-nowrap">Recent Discussions</h6>
						<form action="{{ path('forum_index') }}" method="get" class="flex-grow flex items-center">
							<div class="relative w-full">
								<span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
									<i class="fa fa-search text-xs"></i>
								</span>
								<input type="text" name="q" value="{{ app.request.query.get('q')|default('') }}" class="pl-10 pr-4 py-2 w-full text-sm border-gray-200 rounded-xl focus:ring-fuchsia-500 focus:border-fuchsia-500 transition-all border outline-none text-center" placeholder="Search discussions...">
							</div>
							{% if app.request.query.get('q') is not empty %}
								<a href="{{ path('forum_index') }}" class="ml-2 text-slate-400 hover:text-red-500" title="Clear search">
									<i class="fa fa-times-circle text-lg"></i>
								</a>
							{% endif %}
						</form>
					</div>

					<a href="{{ path('app_post_new') }}" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-transparent border-0 rounded-lg cursor-pointer leading-pro text-xs ease-soft-in shadow-soft-md bg-150 bg-x-25 bg-gradient-to-tl from-purple-700 to-pink-500 hover:shadow-soft-2xl hover:scale-102">
						<i class="fas fa-plus mr-1 text-xs"></i>
						Create New Post
					</a>
				</div>
			</div>

			{% for post in posts %}
				<div
					class="relative flex flex-col min-w-0 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border mb-6 hover:shadow-soft-2xl transition-all duration-300">
					<!-- Header Style -->
					<div class="p-4 pb-0">
						<div class="flex items-center">
							<div class="avatar avatar-xs me-2">
								<img src="https://ui-avatars.com/api/?name={{ post.user ? post.user.username : 'User' }}&background=f5f5f5&color=cb0c9f" class="w-10 h-10 rounded-full border border-gray-100 shadow-soft-xs" alt="user1">
							</div>
							<div class="flex flex-col ml-3">
								<span class="text-xs font-bold text-slate-700">
									{{ post.user ? post.user.username : 'Anonymous' }}
									{% if post.status == 'pending' %}
										{% set isAdmin = app.session.get('user_role') == 'ROLE_ADMIN' %}
										{% if isAdmin or (app_user and post.user == app_user) %}
											<span class="ml-2 px-2 py-0.5 text-[10px] font-bold text-orange-700 bg-orange-100 rounded-lg">Pending</span>
										{% endif %}
									{% endif %}
									{% if post.isPinned() %}
										<span class="ml-2 px-2 py-0.5 text-[10px] font-bold text-white bg-gradient-to-tl from-purple-700 to-pink-500 rounded-lg shadow-soft-sm">
											<i class="fas fa-thumbtack mr-1"></i>
											Pinned
										</span>
									{% endif %}
									{% if post.status == 'solved' %}
										<span class="ml-2 px-2 py-0.5 text-[10px] font-bold text-green-700 bg-green-100 rounded-lg">
											<i class="fas fa-check-circle mr-1"></i>
											Solved
										</span>
									{% endif %}
								</span>
							</div>
						</div>
					</div>

					<!-- Content Style -->
					<div class="p-4 pt-2">
						<a href="{{ path('app_post_show', {'id': post.id}) }}" class="block">
							<h5 class="font-bold text-slate-800 mb-2 leading-tight hover:text-purple-700 transition-colors">{{ post.title }}</h5>
						</a>
						<div class="text-sm leading-normal text-slate-600 mb-4 whitespace-pre-wrap">
							{{ post.content }}
						</div>

						{% if post.imageName %}
							<div class="mb-3 overflow-hidden rounded-xl border border-gray-100">
								<img src="{{ asset('uploads/' ~ post.imageName) }}" class="w-full h-auto" alt="post image">
							</div>
						{% endif %}

						{% if post.pdfName %}
							<div class="mb-3 p-3 bg-gray-50 rounded-xl border border-dashed border-gray-200 flex items-center justify-between">
								<div class="flex items-center">
									<div class="bg-red-100 p-1.5 rounded-lg mr-2">
										<i class="fas fa-file-pdf text-red-600 text-sm"></i>
									</div>
									<span class="text-xs font-bold text-slate-700">PDF Document</span>
								</div>
								<a href="{{ asset('uploads/' ~ post.pdfName) }}" target="_blank" class="text-xs font-bold text-white bg-gradient-to-tl from-purple-700 to-pink-500 px-4 py-2 rounded-lg shadow-soft-md hover:scale-102 transition-all uppercase">
									<i class="fas fa-eye mr-1"></i>
									Open
								</a>
							</div>
						{% endif %}
					</div>

					<!-- Interaction Bar -->
					<div
						class="p-4 pt-0 flex flex-wrap items-center gap-2">
						<!-- Reactions Button -->
						<div class="reaction-container relative group">
							{% set userReaction = null %}
							{% if app_user %}
								{% for r in post.reactions %}
									{% if r.user == app_user %}
										{% set userReaction = r.type %}
									{% endif %}
								{% endfor %}
							{% endif %}

							<!-- Reaction Popup Bar -->
							<div class="reaction-bar hidden group-hover:flex absolute bottom-full mb-3 left-0 bg-white shadow-soft-2xl rounded-full px-1.5 py-1 items-center gap-1 animate-reaction-pop z-50 border border-gray-100">
								<button type="button" onclick="handleReaction({{ post.id }}, 'like')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Like">
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png" class="w-7 h-7" alt="👍">
								</button>
								<button type="button" onclick="handleReaction({{ post.id }}, 'love')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Love">
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png" class="w-7 h-7" alt="❤️">
								</button>
								<button type="button" onclick="handleReaction({{ post.id }}, 'haha')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Haha">
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png" class="w-7 h-7" alt="😂">
								</button>
								<button type="button" onclick="handleReaction({{ post.id }}, 'wow')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Wow">
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png" class="w-7 h-7" alt="😮">
								</button>
								<button type="button" onclick="handleReaction({{ post.id }}, 'sad')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Sad">
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png" class="w-7 h-7" alt="😢">
								</button>
								<button type="button" onclick="handleReaction({{ post.id }}, 'angry')" class="reaction-item hover:scale-120 hover:-translate-y-1 transition-all duration-200 p-1 rounded-full cursor-pointer bg-transparent border-0" title="Angry">
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png" class="w-7 h-7" alt="😡">
								</button>
							</div>

							<!-- Main Button -->
							<button id="react-btn-{{ post.id }}" type="button" onclick="handleReaction({{ post.id }}, '{{ userReaction ?: 'like' }}')" class="bg-gray-100 rounded-full flex items-center px-4 py-2 hover:bg-gray-200 transition-all border-0 shadow-none cursor-pointer {{ userReaction ? 'text-fuchsia-600' : 'text-slate-600' }}">

								{% if userReaction == 'like' %}
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png" class="w-5 h-5 mr-2" alt="👍">
									<span class="text-xs font-bold">Like</span>
								{% elseif userReaction == 'love' %}
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png" class="w-5 h-5 mr-2" alt="❤️">
									<span class="text-xs font-bold">Love</span>
								{% elseif userReaction == 'haha' %}
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png" class="w-5 h-5 mr-2" alt="😂">
									<span class="text-xs font-bold">Haha</span>
								{% elseif userReaction == 'wow' %}
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png" class="w-5 h-5 mr-2" alt="😮">
									<span class="text-xs font-bold">Wow</span>
								{% elseif userReaction == 'sad' %}
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png" class="w-5 h-5 mr-2" alt="😢">
									<span class="text-xs font-bold">Sad</span>
								{% elseif userReaction == 'angry' %}
									<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png" class="w-5 h-5 mr-2" alt="😡">
									<span class="text-xs font-bold">Angry</span>
								{% else %}
									<i class="far fa-thumbs-up text-xs mr-2 text-slate-400"></i>
									<span class="text-xs font-bold">Like</span>
								{% endif %}

								<span id="react-count-{{ post.id }}" class="ml-2 text-[10px] text-slate-400 bg-white px-1.5 py-0.5 rounded-full shadow-soft-sm">
									{{ post.reactions|length }}
								</span>
							</button>
						</div>

						<!-- Comment -->
						<a href="{{ path('app_post_show', {'id': post.id}) }}" class="bg-gray-100 rounded-full flex items-center px-4 py-2 text-slate-600 hover:bg-gray-200 transition-all text-decoration-none border-0">
							<i class="fas fa-comment text-xs text-slate-500 mr-2"></i>
							<span class="text-xs font-bold">{{ post.comments|length }}
								Comments</span>
						</a>

						{% set isAdmin = is_granted('ROLE_ADMIN') or app.session.get('user_role') == 'ROLE_ADMIN' %}
						{% set isOwner = app_user and post.user == app_user %}
						{% set canManagePost = isAdmin or isOwner %}

						{% if canManagePost %}
							<!-- Edit Button -->
							<a href="{{ path('app_post_edit', {'id': post.id}) }}" class="bg-gray-100 rounded-full flex items-center px-4 py-2 text-slate-600 hover:bg-purple-100 hover:text-purple-700 transition-all text-decoration-none border-0">
								<i class="fas fa-edit text-xs mr-2"></i>
								<span class="text-xs font-bold">Edit</span>
							</a>

							<!-- Delete Button -->
							<form action="{{ path('app_post_delete', {'id': post.id}) }}" method="POST" class="mb-0" onsubmit="return confirm('Delete this post?')">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
								<button type="submit" class="bg-gray-100 rounded-full flex items-center px-4 py-2 text-slate-600 hover:bg-red-100 hover:text-red-700 transition-all border-0 shadow-none cursor-pointer">
									<i class="fas fa-trash text-xs mr-2"></i>
									<span class="text-xs font-bold">Delete</span>
								</button>
							</form>
						{% endif %}

						<!-- Pin Button (Admin Only) -->
						{% if isAdmin %}
							<form action="{{ path('app_post_pin', {'id': post.id}) }}" method="POST" class="mb-0">
								<button type="submit" class="bg-gray-100 rounded-full flex items-center px-4 py-2 text-slate-600 hover:bg-yellow-100 hover:text-yellow-700 transition-all border-0 shadow-none cursor-pointer" title="{{ post.isPinned() ? 'Unpin' : 'Pin' }}">
									<i class="fas fa-thumbtack text-xs mr-2 {{ post.isPinned() ? 'text-yellow-600' : '' }}"></i>
									<span class="text-xs font-bold">{{ post.isPinned() ? 'Unpin' : 'Pin' }}</span>
								</button>
							</form>
						{% endif %}
						<!-- Share Button -->
						<div class="relative inline-block text-left">
							{% set postUrl = url('app_post_show', {'id': post.id}) %}
							<button type="button" onclick="toggleShareDropdown('shareDropdown-{{ post.id }}')" class="bg-gray-100 rounded-full flex items-center px-4 py-2 text-slate-600 hover:bg-gray-200 transition-all border-0 shadow-none cursor-pointer group">
								<i class="fas fa-share text-xs text-slate-400 group-hover:text-purple-700 transition-colors mr-2"></i>
								<span class="text-xs font-bold">Share</span>
							</button>
							<div id="shareDropdown-{{ post.id }}" class="share-dropdown-menu hidden absolute left-0 bottom-full mb-2 w-40 bg-white border border-gray-100 rounded-xl shadow-soft-2xl z-50 py-2 text-left animate-fade-in">
								<button type="button" onclick="copyPageUrl('{{ postUrl|e('js') }}', 'shareDropdown-{{ post.id }}')" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-gray-50 flex items-center border-0 bg-transparent cursor-pointer">
									<i class="fas fa-link mr-2 w-4 text-purple-700"></i>
									Copy Link
								</button>
							</div>
						</div>
					</div>
				</div>
			{% else %}
				<div class="relative flex flex-col min-w-0 break-words bg-white shadow-soft-xl rounded-2xl p-12 text-center">
					<div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
						<i class="fas fa-search text-2xl text-slate-300"></i>
					</div>
					{% if app.request.query.get('q') %}
						<h6 class="mb-1 font-bold text-slate-700">No posts found</h6>
						<p class="text-sm text-slate-500 mb-0">We couldn't find any discussions matching "{{ app.request.query.get('q') }}".</p>
					{% else %}
						<h6 class="mb-1 font-bold text-slate-700">Nothing here yet</h6>
						<p class="text-sm text-slate-500 mb-0">Start the discussion and be the first to post!</p>
					{% endif %}
				</div>
			{% endfor %}
		</div>
	</div>

{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		function toggleShareDropdown(id) {
const dropdown = document.getElementById(id);
if (! dropdown) 
return;



// Close all other dropdowns
document.querySelectorAll('.share-dropdown-menu').forEach(d => {
if (d.id !== id) 
d.classList.add('hidden');



});

dropdown.classList.toggle('hidden');
}

async function copyPageUrl(postUrl, dropdownId) {
const dropdown = document.getElementById(dropdownId);
if (dropdown) 
dropdown.classList.add('hidden');



try {
if (navigator.clipboard && window.isSecureContext) {
await navigator.clipboard.writeText(postUrl);
alert('✅ Link copied to clipboard!');
} else {
const textArea = document.createElement("textarea");
textArea.value = postUrl;
textArea.style.position = "fixed";
textArea.style.left = "-9999px";
textArea.style.top = "0";
document.body.appendChild(textArea);
textArea.focus();
textArea.select();
const success = document.execCommand('copy');
document.body.removeChild(textArea);
if (success) 
alert('✅ Link copied to clipboard!');



}
} catch (err) {
console.error('Copy failed', err);
}
}

// Close dropdowns on outside click or ESC
document.addEventListener('click', function (e) {
if (! e.target.closest('.relative')) {
document.querySelectorAll('.share-dropdown-menu').forEach(d => d.classList.add('hidden'));
}
});

document.addEventListener('keydown', function (e) {
if (e.key === 'Escape') {
document.querySelectorAll('.share-dropdown-menu').forEach(d => d.classList.add('hidden'));
}
});
	</script>
	<style>
		.animate-fade-in {
			animation: fadeIn 0.15s ease-out;
		}

		.animate-reaction-pop {
			animation: reactionPop 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateY(5px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@keyframes reactionPop {
			from {
				opacity: 0;
				transform: scale(0.5) translateY(20px);
			}
			to {
				opacity: 1;
				transform: scale(1) translateY(0);
			}
		}

		.reaction-bar {
			transform-origin: bottom left;
		}
		.reaction-item:hover {
			box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
		}
	</style>

	<script>
		const reactionMap = {
'like': {
emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png',
label: 'Like'
},
'love': {
emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png',
label: 'Love'
},
'haha': {
emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png',
label: 'Haha'
},
'wow': {
emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png',
label: 'Wow'
},
'sad': {
emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png',
label: 'Sad'
},
'angry': {
emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png',
label: 'Angry'
}
};

async function handleReaction(postId, type) {
const btn = document.getElementById (`react-btn-${postId}`);
const countSpan = document.getElementById (`react-count-${postId}`);

try {
const response = await fetch (`/posts/${postId}/react`, {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify({type})
});

if (response.status === 401) {
window.location.href = "{{ path('app_auth') }}";
return;
}

const data = await response.json();
if (data.success) { // Update Count
countSpan.textContent = data.counts.total;

// Update Button UI
if (data.user_reaction) {
const react = reactionMap[data.user_reaction];
btn.innerHTML = `
							<img src="${
react.emoji
}" class="w-5 h-5 mr-2" alt="${
data.user_reaction
}">
							<span class="text-xs font-bold">${
react.label
}</span>
							<span id="react-count-${postId}" class="ml-2 text-[10px] text-slate-400 bg-white px-1.5 py-0.5 rounded-full shadow-soft-sm">
								${
data.counts.total
}
							</span>
						`;
btn.classList.add('text-fuchsia-600');
btn.classList.remove('text-slate-600');

// Re-assign countSpan reference because innerHTML changed
const newCountSpan = document.getElementById (`react-count-${postId}`);
newCountSpan.classList.add('animate-reaction-pop');
} else {
btn.innerHTML = `
							<i class="far fa-thumbs-up text-xs mr-2 text-slate-400"></i>
							<span class="text-xs font-bold">Like</span>
							<span id="react-count-${postId}" class="ml-2 text-[10px] text-slate-400 bg-white px-1.5 py-0.5 rounded-full shadow-soft-sm">
								${
data.counts.total
}
							</span>
						`;
btn.classList.remove('text-fuchsia-600');
btn.classList.add('text-slate-600');
}
}
} catch (err) {
console.error('Reaction failed', err);
}
}

// Long-press support for mobile
document.addEventListener('DOMContentLoaded', () => {
let pressTimer;
const reactionContainers = document.querySelectorAll('.reaction-container');

reactionContainers.forEach(container => {
const btn = container.querySelector('button[id^="react-btn-"]');
const bar = container.querySelector('.reaction-bar');

const start = (e) => {
pressTimer = setTimeout(() => {
bar.classList.remove('hidden');
bar.classList.add('flex');
}, 500);
};

const cancel = (e) => {
clearTimeout(pressTimer);
};

btn.addEventListener('touchstart', start);
btn.addEventListener('touchend', cancel);
btn.addEventListener('mousedown', start);
btn.addEventListener('mouseup', cancel);
btn.addEventListener('mouseleave', cancel);

// Hide bar when clicking a reaction
bar.addEventListener('click', () => {
bar.classList.add('hidden');
bar.classList.remove('flex');
});
});

// Hide bars when clicking outside
document.addEventListener('click', (e) => {
if (!e.target.closest('.reaction-container')) {
document.querySelectorAll('.reaction-bar').forEach(bar => {
bar.classList.add('hidden');
bar.classList.remove('flex');
});
}
});
});
	</script>
{% endblock %}
