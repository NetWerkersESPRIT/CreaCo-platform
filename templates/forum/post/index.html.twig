{% extends 'base.html.twig' %}

{% block title %}Forum - CreaCo
{% endblock %}
{% block page_title %}Forum
{% endblock %}
{% block page_subtitle %}News Feed
{% endblock %}

{% block body %}
	<div
		class="flex flex-wrap -mx-3 justify-center">
		<!-- Main Feed Section (Centered & Wide) -->
		<div
			class="w-full max-w-full px-3 lg:w-10/12 mx-auto">

			<!-- Forum Header & Unified Search -->
			<div class="mb-6">
				<div class="relative flex flex-wrap justify-between items-center bg-white shadow-soft-xl rounded-2xl p-6 mb-4 gap-4">
					<div class="flex items-center gap-4 flex-grow max-w-2xl">
						<h6 class="mb-0 font-bold text-slate-700 whitespace-nowrap">Recent Discussions</h6>
						<form action="{{ path('forum_index') }}" method="get" class="flex-grow flex items-center">
							<div class="relative w-full">
								<span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
									<i class="fa fa-search text-xs"></i>
								</span>
								<input type="text" name="q" value="{{ app.request.query.get('q')|default('') }}" class="pl-10 pr-4 py-2 w-full text-sm border-gray-200 rounded-xl focus:ring-fuchsia-500 focus:border-fuchsia-500 transition-all border outline-none text-center" placeholder="Search discussions...">
							</div>
							{% if app.request.query.get('q') is not empty %}
								<a href="{{ path('forum_index') }}" class="ml-2 text-slate-400 hover:text-red-500" title="Clear search">
									<i class="fa fa-times-circle text-lg"></i>
								</a>
							{% endif %}
						</form>
					</div>

					<a href="{{ path('app_post_new') }}" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-transparent border-0 rounded-lg cursor-pointer leading-pro text-xs ease-soft-in shadow-soft-md bg-150 bg-x-25 bg-gradient-to-tl from-purple-700 to-pink-500 hover:shadow-soft-2xl hover:scale-102">
						<i class="fas fa-plus mr-1 text-xs"></i>
						Create New Post
					</a>
				</div>
			</div>

			<div id="post-list-container">
				{% include 'forum/post/_list.html.twig' %}
			</div>
		</div>
	</div>

{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		document.addEventListener('DOMContentLoaded', function () {
const searchInput = document.querySelector('input[name="q"]');
const postContainer = document.getElementById('post-list-container');
const searchForm = searchInput.closest('form');
let debounceTimer;

searchInput.addEventListener('input', function () {
clearTimeout(debounceTimer);
const query = this.value;

debounceTimer = setTimeout(() => {
const url = new URL(window.location.href);
url.searchParams.set('q', query);

// Show loading state (optional)
postContainer.style.opacity = '0.5';

fetch(url, {
headers: {
'X-Requested-With': 'XMLHttpRequest'
}
}).then(response => response.text()).then(html => {
postContainer.innerHTML = html;
postContainer.style.opacity = '1';
// Update URL without reloading
window.history.pushState({}, '', url);
}).catch(error => {
console.error('Error:', error);
postContainer.style.opacity = '1';
});
}, 300); // 300ms debounce
});

searchForm.addEventListener('submit', function (e) {
e.preventDefault();
});
});

function toggleShareDropdown(id) {
const dropdown = document.getElementById(id);
if (! dropdown) 
return;



// Close all other dropdowns
document.querySelectorAll('.share-dropdown-menu').forEach(d => {
if (d.id !== id) 
d.classList.add('hidden');



});

dropdown.classList.toggle('hidden');
}

async function copyPageUrl(postUrl, dropdownId) {
const dropdown = document.getElementById(dropdownId);
if (dropdown) 
dropdown.classList.add('hidden');



try {
if (navigator.clipboard && window.isSecureContext) {
await navigator.clipboard.writeText(postUrl);
} else {
const textArea = document.createElement('textarea');
textArea.value = postUrl;
textArea.style.cssText = 'position:fixed;left:-9999px;top:0;';
document.body.appendChild(textArea);
textArea.focus();
textArea.select();
document.execCommand('copy');
document.body.removeChild(textArea);
}
showCopied('Link copied to clipboard.');
} catch (err) {
console.error('Copy failed', err);
}
}

// Close dropdowns on outside click or ESC
document.addEventListener('click', function (e) {
if (! e.target.closest('.relative')) {
document.querySelectorAll('.share-dropdown-menu').forEach(d => d.classList.add('hidden'));
}
});

document.addEventListener('keydown', function (e) {
if (e.key === 'Escape') {
document.querySelectorAll('.share-dropdown-menu').forEach(d => d.classList.add('hidden'));
}
});
	</script>
	<style>
		.animate-fade-in {
			animation: fadeIn 0.15s ease-out;
		}

		.animate-reaction-pop {
			animation: reactionPop 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		}

		@keyframes fadeIn {
			from { opacity: 0; transform: translateY(5px); }
			to { opacity: 1; transform: translateY(0); }
		}

		@keyframes reactionPop {
			0% { opacity: 0; transform: scale(0.8) translateY(12px); }
			60% { transform: scale(1.05) translateY(-2px); }
			100% { opacity: 1; transform: scale(1) translateY(0); }
		}

		/* Staggered entrance for emojis */
		.stagger-1 { animation: reactionPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; animation-delay: 0.02s; }
		.stagger-2 { animation: reactionPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; animation-delay: 0.06s; }
		.stagger-3 { animation: reactionPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; animation-delay: 0.10s; }
		.stagger-4 { animation: reactionPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; animation-delay: 0.14s; }
		.stagger-5 { animation: reactionPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; animation-delay: 0.18s; }
		.stagger-6 { animation: reactionPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; animation-delay: 0.22s; }

		/* Popup Reaction Bar Styling */
		.reaction-picker {
			transform-origin: bottom center;
			backdrop-filter: blur(12px);
			background-color: rgba(255, 255, 255, 0.7) !important;
		}

		/* Hover Bridge: Prevents flickering when moving mouse from button to picker */
		.reaction-picker::after {
			content: '';
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			height: 15px;
			background: transparent;
		}

		.active-glow {
			background-color: transparent !important;
			box-shadow: none !important;
			border-color: transparent !important;
			position: relative;
			font-weight: 800 !important;
		}

		/* Indicator dot for active reaction */
		.active-glow::after {
			content: '';
			position: absolute;
			bottom: 4px;
			left: 50%;
			transform: translateX(-50%);
			width: 4px;
			height: 4px;
			background-color: #d946ef;
			border-radius: 50%;
		}
	</style>

	<script>
		const reactionMap = {
			'like': { emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png', label: 'Like' },
			'love': { emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png', label: 'Love' },
			'haha': { emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png', label: 'Haha' },
			'wow':  { emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png', label: 'Wow' },
			'sad':  { emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png', label: 'Sad' },
			'angry':{ emoji: 'https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png', label: 'Angry' }
		};

		async function handleMainReaction(postId) {
			const btn = document.getElementById(`react-btn-${postId}`);
			const currentType = btn.getAttribute('data-reaction-type');
			
			// If already reacted, toggle it off by sending the same type
			// If not reacted, default to 'like'
			const typeToSend = currentType || 'like';
			handleReaction(postId, typeToSend);
		}

		async function handleReaction(postId, type) {
			const btn = document.getElementById(`react-btn-${postId}`);

			try {
				const response = await fetch(`/posts/${postId}/react`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ type })
				});

				if (response.status === 401) {
					window.location.href = "{{ path('app_auth') }}";
					return;
				}

				const data = await response.json();
				if (data.success) {
					// Update Main Button UI & State
					if (data.user_reaction) {
						const react = reactionMap[data.user_reaction];
						btn.setAttribute('data-reaction-type', data.user_reaction);
						btn.innerHTML = `
							<img src="${react.emoji}" class="w-5 h-5 mr-2" alt="${data.user_reaction}">
							<span class="text-xs font-bold">${react.label}</span>
							<span id="react-count-${postId}" class="ml-1 text-[10px] text-fuchsia-600 font-bold">
								${data.counts.total}
							</span>
						`;
						btn.classList.add('text-fuchsia-600', 'active-glow');
						btn.classList.remove('text-slate-600');
					} else {
						btn.setAttribute('data-reaction-type', '');
						btn.innerHTML = `
							<i class="far fa-thumbs-up text-xs mr-2 text-slate-400"></i>
							<span class="text-xs font-bold">Like</span>
							<span id="react-count-${postId}" class="ml-1 text-[10px] text-slate-400 font-bold">
								${data.counts.total}
							</span>
						`;
						btn.classList.remove('text-fuchsia-600', 'active-glow');
						btn.classList.add('text-slate-600');
					}

					// Animation Trigger
					const newCountSpan = document.getElementById(`react-count-${postId}`);
					if (newCountSpan) {
						newCountSpan.classList.add('animate-reaction-pop');
						setTimeout(() => newCountSpan.classList.remove('animate-reaction-pop'), 300);
					}

					// Auto-hide picker
					const picker = btn.closest('.reaction-container').querySelector('.reaction-picker');
					if (picker) {
						picker.classList.add('hidden');
						picker.classList.remove('flex');
					}
				}
			} catch (err) {
				console.error('Reaction failed', err);
			}
		}

		// Mobile/Stability Logic: Long-press or click support
		document.addEventListener('DOMContentLoaded', () => {
			let pressTimer;
			
			document.addEventListener('mousedown', (e) => {
				const btn = e.target.closest('[id^="react-btn-"]');
				if (!btn) return;
				
				pressTimer = setTimeout(() => {
					const picker = btn.closest('.reaction-container').querySelector('.reaction-picker');
					if (picker) {
						picker.classList.remove('hidden');
						picker.classList.add('flex');
					}
				}, 400); // 400ms for long-press
			});

			document.addEventListener('mouseup', () => clearTimeout(pressTimer));
			document.addEventListener('touchstart', (e) => {
				const btn = e.target.closest('[id^="react-btn-"]');
				if (!btn) return;
				pressTimer = setTimeout(() => {
					const picker = btn.closest('.reaction-container').querySelector('.reaction-picker');
					if (picker) {
						picker.classList.remove('hidden');
						picker.classList.add('flex');
					}
				}, 400);
			});
			document.addEventListener('touchend', () => clearTimeout(pressTimer));

			// Hide bars when clicking outside
			document.addEventListener('click', (e) => {
				if (!e.target.closest('.reaction-container')) {
					document.querySelectorAll('.reaction-picker').forEach(picker => {
						picker.classList.add('hidden');
						picker.classList.remove('flex');
					});
				}
			});
		});
	</script>

	<script>
		// --- Text-to-Speech Implementation for Forum List ---
		let currentUtterance = null;
		let currentPostId = null;
		const synth = window.speechSynthesis;

		function handleTTS(action, postId) {
			const readBtn = document.getElementById(`tts-read-${postId}`);
			const pauseBtn = document.getElementById(`tts-pause-${postId}`);
			const resumeBtn = document.getElementById(`tts-resume-${postId}`);
			const stopBtn = document.getElementById(`tts-stop-${postId}`);

			if (action === 'read') {
				// Stop any previous speech
				if (synth.speaking) {
					synth.cancel();
					if (currentPostId !== null) {
						resetPostButtons(currentPostId);
					}
				}

				const titleElem = document.getElementById(`post-title-${postId}`);
				const contentElem = document.getElementById(`post-content-${postId}`);
				
				const title = titleElem ? titleElem.textContent : "";
				const content = contentElem ? contentElem.textContent : "";
				const fullText = title + ". " + content;

				currentUtterance = new SpeechSynthesisUtterance(fullText);
				currentPostId = postId;

				currentUtterance.onstart = () => {
					readBtn.classList.add('hidden');
					pauseBtn.classList.remove('hidden');
					stopBtn.classList.remove('hidden');
					resumeBtn.classList.add('hidden');
				};

				currentUtterance.onend = () => {
					resetPostButtons(postId);
					currentPostId = null;
				};

				currentUtterance.onerror = (event) => {
					console.error('TTS Error:', event);
					resetPostButtons(postId);
					currentPostId = null;
				};

				synth.speak(currentUtterance);

			} else if (action === 'pause') {
				synth.pause();
				pauseBtn.classList.add('hidden');
				resumeBtn.classList.remove('hidden');
			} else if (action === 'resume') {
				synth.resume();
				resumeBtn.classList.add('hidden');
				pauseBtn.classList.remove('hidden');
			} else if (action === 'stop') {
				synth.cancel();
				resetPostButtons(postId);
				currentPostId = null;
			}
		}

		function resetPostButtons(postId) {
			const readBtn = document.getElementById(`tts-read-${postId}`);
			const pauseBtn = document.getElementById(`tts-pause-${postId}`);
			const resumeBtn = document.getElementById(`tts-resume-${postId}`);
			const stopBtn = document.getElementById(`tts-stop-${postId}`);
			
			if (readBtn) readBtn.classList.remove('hidden');
			if (pauseBtn) pauseBtn.classList.add('hidden');
			if (resumeBtn) resumeBtn.classList.add('hidden');
			if (stopBtn) stopBtn.classList.add('hidden');
		}

		// Initialize TTS visibility
		function initTTS() {
			if ('speechSynthesis' in window) {
				document.querySelectorAll('.tts-container').forEach(c => {
					c.classList.remove('hidden');
					c.classList.add('flex');
				});
			} else {
				console.warn('Text-to-Speech not supported in this browser.');
			}
		}

		document.addEventListener('DOMContentLoaded', initTTS);

		// Re-initialize TTS after AJAX search updates
		const observer = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (mutation.type === 'childList') {
					initTTS();
				}
			});
		});

		const postListContainer = document.getElementById('post-list-container');
		if (postListContainer) {
			observer.observe(postListContainer, { childList: true });
		}
	</script>
{% endblock %}
