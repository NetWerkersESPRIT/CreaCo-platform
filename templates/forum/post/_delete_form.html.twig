<form method="post" action="{{ path('app_post_delete', {'id': post.id}) }}" id="delete-post-form-{{ post.id }}" class="inline-block mt-4">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
	<button type="button" onclick="confirmDelete(document.getElementById('delete-post-form-{{ post.id }}'), '{{ post.title|e('js') }}')" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all border-0 rounded-lg cursor-pointer shadow-soft-md bg-150 bg-x-25 leading-pro text-xs ease-soft-in tracking-tight-soft bg-gradient-to-tl from-red-600 to-rose-400 hover:scale-102 hover:shadow-soft-xs active:opacity-85">Delete Post</button>
</form>
