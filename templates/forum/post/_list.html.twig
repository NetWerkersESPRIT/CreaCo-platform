{% for post in posts %}
	<div
		class="relative flex flex-col min-w-0 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border mb-6 hover:shadow-soft-2xl transition-all duration-300">
		<!-- Header Style -->
		<div class="p-4 pb-0">
			<div class="flex items-center">
				<div class="avatar avatar-xs me-2">
					<img src="https://ui-avatars.com/api/?name={{ post.user ? post.user.username|capitalize : 'User' }}&background=f5f5f5&color=cb0c9f" class="w-10 h-10 rounded-full border border-gray-100 shadow-soft-xs" alt="user1">
				</div>
				<div class="flex flex-col ml-3">
					<div class="flex items-center mb-0.5">
						<span class="text-sm font-bold text-slate-800 tracking-tight">
							{{ post.user ? post.user.username|capitalize : 'Anonymous' }}
						</span>
						{% if post.status == 'pending' %}
							{% set isAdmin = app.session.get('user_role') == 'ROLE_ADMIN' %}
							{% if isAdmin or (app_user and post.user == app_user) %}
								<span class="ml-2 px-2 py-0.5 text-[10px] font-bold text-orange-700 bg-orange-100 rounded-lg">Pending</span>
							{% endif %}
						{% endif %}
						{% if post.isPinned() %}
							<span class="ml-2 px-2 py-0.5 text-[10px] font-bold text-white bg-gradient-to-tl from-purple-700 to-pink-500 rounded-lg shadow-soft-sm">
								<i class="fas fa-thumbtack mr-1"></i>
								Pinned
							</span>
						{% endif %}
						{% if post.status == 'solved' %}
							<span class="ml-2 px-2 py-0.5 text-[10px] font-bold text-green-700 bg-green-100 rounded-lg">
								<i class="fas fa-check-circle mr-1"></i>
								Solved
							</span>
						{% endif %}
					</div>
				</div>
			</div>
		</div>

		<!-- Content Style -->
		<div class="p-4 pt-2">
			<a href="{{ path('app_post_show', {'id': post.id}) }}" class="block">
				<h5 id="post-title-{{ post.id }}" class="font-bold text-slate-800 mb-2 leading-tight hover:text-purple-700 transition-colors">{{ post.title }}</h5>
			</a>
			<div id="post-content-{{ post.id }}" class="text-sm leading-normal text-slate-600 mb-4 whitespace-pre-wrap">
				{{ post.content }}
			</div>

			{% if post.imageName %}
				<div class="mb-3 overflow-hidden rounded-xl border border-gray-100">
					<img src="{{ asset('uploads/' ~ post.imageName) }}" class="w-full h-auto" alt="post image">
				</div>
			{% endif %}

			{% if post.pdfName %}
				<div class="mb-3 p-3 bg-gray-50 rounded-xl border border-dashed border-gray-200 flex items-center justify-between">
					<div class="flex items-center">
						<div class="bg-red-100 p-1.5 rounded-lg mr-2">
							<i class="fas fa-file-pdf text-red-600 text-sm"></i>
						</div>
						<span class="text-xs font-bold text-slate-700">PDF Document</span>
					</div>
					<a href="{{ asset('uploads/' ~ post.pdfName) }}" target="_blank" class="text-xs font-bold text-white bg-gradient-to-tl from-purple-700 to-pink-500 px-4 py-2 rounded-lg shadow-soft-md hover:scale-102 transition-all uppercase">
						<i class="fas fa-eye mr-1"></i>
						Open
					</a>
				</div>
			{% endif %}
		</div>

		<!-- Interaction Bar -->
		<div
			class="p-4 pt-0 flex flex-wrap items-center gap-2">
			<!-- Cute & Robust Reaction Bar -->
			<div class="reaction-container relative group">
				{% set userReaction = null %}
				{% if app_user %}
					{% for r in post.reactions %}
						{% if r.user == app_user %}
							{% set userReaction = r.type %}
						{% endif %}
					{% endfor %}
				{% endif %}

				<!-- Staggered Emoji Picker (Cute Wave Effect) -->
				<div class="reaction-picker hidden group-hover:flex absolute bottom-full mb-2.5 left-0 bg-white shadow-soft-2xl rounded-full px-1.5 py-1.5 items-center gap-0.5 animate-reaction-pop z-50 border border-white/40 backdrop-blur-md bg-white/70">
					<button type="button" onclick="handleReaction({{ post.id }}, 'like')" class="hover:scale-125 transition-all duration-300 p-1.5 rounded-full stagger-1" title="Like">
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png" class="w-5.5 h-5.5" alt="👍">
					</button>
					<button type="button" onclick="handleReaction({{ post.id }}, 'love')" class="hover:scale-125 transition-all duration-300 p-1.5 rounded-full stagger-2" title="Love">
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png" class="w-5.5 h-5.5" alt="❤️">
					</button>
					<button type="button" onclick="handleReaction({{ post.id }}, 'haha')" class="hover:scale-125 transition-all duration-300 p-1.5 rounded-full stagger-3" title="Haha">
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png" class="w-5.5 h-5.5" alt="😂">
					</button>
					<button type="button" onclick="handleReaction({{ post.id }}, 'wow')" class="hover:scale-125 transition-all duration-300 p-1.5 rounded-full stagger-4" title="Wow">
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png" class="w-5.5 h-5.5" alt="😮">
					</button>
					<button type="button" onclick="handleReaction({{ post.id }}, 'sad')" class="hover:scale-125 transition-all duration-300 p-1.5 rounded-full stagger-5" title="Sad">
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png" class="w-5.5 h-5.5" alt="😢">
					</button>
					<button type="button" onclick="handleReaction({{ post.id }}, 'angry')" class="hover:scale-125 transition-all duration-300 p-1.5 rounded-full stagger-6" title="Angry">
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png" class="w-5.5 h-5.5" alt="😡">
					</button>
				</div>

				<!-- Main Button - State aware with data-reaction-type -->
				<button id="react-btn-{{ post.id }}" type="button" 
					data-reaction-type="{{ userReaction ?: '' }}"
					onclick="handleMainReaction({{ post.id }})" 
					class="flex items-center px-4 py-2 hover:bg-gray-50 rounded-xl transition-all border-0 shadow-none cursor-pointer {{ userReaction ? 'text-fuchsia-600 active-glow' : 'text-slate-600' }}">

					{% if userReaction == 'like' %}
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f44d.png" class="w-5 h-5 mr-2" alt="👍">
						<span class="text-xs font-bold">Like</span>
					{% elseif userReaction == 'love' %}
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/2764.png" class="w-5 h-5 mr-2" alt="❤️">
						<span class="text-xs font-bold">Love</span>
					{% elseif userReaction == 'haha' %}
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f602.png" class="w-5 h-5 mr-2" alt="😂">
						<span class="text-xs font-bold">Haha</span>
					{% elseif userReaction == 'wow' %}
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f62e.png" class="w-5 h-5 mr-2" alt="😮">
						<span class="text-xs font-bold">Wow</span>
					{% elseif userReaction == 'sad' %}
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f622.png" class="w-5 h-5 mr-2" alt="😢">
						<span class="text-xs font-bold">Sad</span>
					{% elseif userReaction == 'angry' %}
						<img src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f621.png" class="w-5 h-5 mr-2" alt="😡">
						<span class="text-xs font-bold">Angry</span>
					{% else %}
						<i class="far fa-thumbs-up text-xs mr-2 text-slate-400"></i>
						<span class="text-xs font-bold">Like</span>
					{% endif %}

					<span id="react-count-{{ post.id }}" class="ml-1 text-[10px] {{ userReaction ? 'text-fuchsia-600' : 'text-slate-400' }} font-bold">
						{{ post.reactions|length }}
					</span>
				</button>
			</div>

			<!-- Comment -->
			<a href="{{ path('app_post_show', {'id': post.id}) }}" class="flex items-center px-4 py-2 text-slate-600 hover:bg-gray-50 rounded-xl transition-all text-decoration-none border-0">
				<i class="fas fa-comment text-xs text-slate-500 mr-2"></i>
				<span class="text-xs font-bold">{{ post.comments|length }}
					Comments</span>
			</a>

			<!-- TTS Controls -->
			<div id="tts-container-{{ post.id }}" class="tts-container hidden flex items-center gap-2">
				<button id="tts-read-{{ post.id }}" type="button" onclick="handleTTS('read', {{ post.id }})" class="flex items-center px-4 py-2 text-purple-600 hover:bg-purple-50 rounded-xl transition-all border-0 shadow-none cursor-pointer">
					<i class="fas fa-volume-up text-xs mr-2"></i>
					<span class="text-xs font-bold">Read</span>
				</button>
				<button id="tts-pause-{{ post.id }}" type="button" onclick="handleTTS('pause', {{ post.id }})" class="hidden flex items-center px-4 py-2 text-orange-500 hover:bg-orange-50 rounded-xl transition-all border-0 shadow-none cursor-pointer">
					<i class="fas fa-pause text-xs mr-2"></i>
					<span class="text-xs font-bold">Pause</span>
				</button>
				<button id="tts-resume-{{ post.id }}" type="button" onclick="handleTTS('resume', {{ post.id }})" class="hidden flex items-center px-4 py-2 text-green-500 hover:bg-green-50 rounded-xl transition-all border-0 shadow-none cursor-pointer">
					<i class="fas fa-play text-xs mr-2"></i>
					<span class="text-xs font-bold">Resume</span>
				</button>
				<button id="tts-stop-{{ post.id }}" type="button" onclick="handleTTS('stop', {{ post.id }})" class="hidden flex items-center px-4 py-2 text-red-500 hover:bg-red-50 rounded-xl transition-all border-0 shadow-none cursor-pointer">
					<i class="fas fa-stop text-xs mr-2"></i>
					<span class="text-xs font-bold">Stop</span>
				</button>
			</div>

			{% set isAdmin = is_granted('ROLE_ADMIN') or app.session.get('user_role') == 'ROLE_ADMIN' %}
			{% set isOwner = app_user and post.user == app_user %}
			{% set canManagePost = isAdmin or isOwner %}

			{% if canManagePost %}
				<!-- Edit Button -->
				<a href="{{ path('app_post_edit', {'id': post.id}) }}" class="flex items-center px-4 py-2 text-slate-600 hover:bg-purple-50 hover:text-purple-700 rounded-xl transition-all text-decoration-none border-0">
					<i class="fas fa-edit text-xs mr-2"></i>
					<span class="text-xs font-bold">Edit</span>
				</a>

				<!-- Delete Button -->
				<form action="{{ path('app_post_delete', {'id': post.id}) }}" method="POST" class="mb-0" id="del-post-idx-{{ post.id }}">
					<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
					<button type="button" onclick="confirmDelete(document.getElementById('del-post-idx-{{ post.id }}'), '{{ post.title|e('js') }}')" class="flex items-center px-4 py-2 text-slate-600 hover:bg-red-50 hover:text-red-700 rounded-xl transition-all border-0 shadow-none cursor-pointer">
						<i class="fas fa-trash text-xs mr-2"></i>
						<span class="text-xs font-bold">Delete</span>
					</button>
				</form>
			{% endif %}

			<!-- Pin Button (Admin Only) -->
			{% if isAdmin %}
				<form action="{{ path('app_post_pin', {'id': post.id}) }}" method="POST" class="mb-0" id="pin-form-idx-{{ post.id }}">
					<button type="button" onclick="confirmAction('{{ post.isPinned() ? 'Unpin' : 'Pin' }} Post?', 'Do you want to {{ post.isPinned() ? 'unpin' : 'pin' }} this post?', 'question', 'Yes').then(c => { if(c) document.getElementById('pin-form-idx-{{ post.id }}').submit(); })" class="flex items-center px-4 py-2 text-slate-600 hover:bg-yellow-50 hover:text-yellow-700 rounded-xl transition-all border-0 shadow-none cursor-pointer" title="{{ post.isPinned() ? 'Unpin' : 'Pin' }}">
						<i class="fas fa-thumbtack text-xs mr-2 {{ post.isPinned() ? 'text-yellow-600' : '' }}"></i>
						<span class="text-xs font-bold">{{ post.isPinned() ? 'Unpin' : 'Pin' }}</span>
					</button>
				</form>
			{% endif %}
			<!-- Share Button -->
			<div class="relative inline-block text-left">
				{% set postUrl = url('app_post_show', {'id': post.id}) %}
				<button type="button" onclick="toggleShareDropdown('shareDropdown-{{ post.id }}')" class="flex items-center px-4 py-2 text-slate-600 hover:bg-gray-50 rounded-xl transition-all border-0 shadow-none cursor-pointer group">
					<i class="fas fa-share text-xs text-slate-400 group-hover:text-purple-700 transition-colors mr-2"></i>
					<span class="text-xs font-bold">Share</span>
				</button>
				<div id="shareDropdown-{{ post.id }}" class="share-dropdown-menu hidden absolute left-0 bottom-full mb-2 w-40 bg-white border border-gray-100 rounded-xl shadow-soft-2xl z-50 py-2 text-left animate-fade-in">
					<button type="button" onclick="copyPageUrl('{{ postUrl|e('js') }}', 'shareDropdown-{{ post.id }}')" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-gray-50 flex items-center border-0 bg-transparent cursor-pointer">
						<i class="fas fa-link mr-2 w-4 text-purple-700"></i>
						Copy Link
					</button>
				</div>
			</div>
		</div>
	</div>
{% else %}
	<div class="relative flex flex-col min-w-0 break-words bg-white shadow-soft-xl rounded-2xl p-12 text-center">
		<div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
			<i class="fas fa-search text-2xl text-slate-300"></i>
		</div>
		{% if app.request.query.get('q') %}
			<h6 class="mb-1 font-bold text-slate-700">No posts found</h6>
			<p class="text-sm text-slate-500 mb-0">We couldn't find any discussions matching "{{ app.request.query.get('q') }}".</p>
		{% else %}
			<h6 class="mb-1 font-bold text-slate-700">Nothing here yet</h6>
			<p class="text-sm text-slate-500 mb-0">Start the discussion and be the first to post!</p>
		{% endif %}
	</div>
{% endfor %}
