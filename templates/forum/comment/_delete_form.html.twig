<form method="post" action="{{ path('app_comment_delete', {'id': comment.id}) }}" id="delete-comment-form-{{ comment.id }}">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
	<button type="button" onclick="confirmDelete(document.getElementById('delete-comment-form-{{ comment.id }}'), 'this comment')" class="btn">Delete</button>
</form>
