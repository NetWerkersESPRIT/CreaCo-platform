{% extends 'base.html.twig' %}

{% block title %}Dashboard | CreaCo{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        :root {
            --jakarta: 'Plus Jakarta Sans', sans-serif;
            --purple-pink: linear-gradient(135deg, #9B46FF 0%, #FF46A0 100%);
        }

        body {
            font-family: var(--jakarta) !important;
            background: #F7F7FB !important;
            overflow-x: hidden;
        }

        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 24px 32px;
        }

        /* Stat Cards Grid */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 20px 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            display: flex;
            flex-direction: column;
            position: relative;
            transition: transform 0.2s ease;
        }

        .stat-card:hover {
            transform: translateY(-2px);
        }

        .stat-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: #888;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 800;
            color: #1a1a2e;
            margin: 0;
        }

        .stat-icon-orb {
            position: absolute;
            top: 20px;
            right: 24px;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--purple-pink);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
        }

        .stat-badge {
            display: inline-block;
            margin-top: 10px;
            padding: 2px 8px;
            background: #E8F5E9;
            color: #2E7D32;
            font-size: 11px;
            font-weight: 700;
            border-radius: 100px;
        }

        /* Main Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 16px;
            margin-top: 24px;
        }

        .creaco-card, .activity-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            height: 100%;
        }

        .creaco-card {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 24px;
            align-items: center;
        }

        .logo-container {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .logo-container img {
            max-width: 100%;
            height: auto;
            object-fit: contain;
        }

        /* Welcome Heading */
        .welcome-section {
            margin-bottom: 32px;
        }

        .welcome-title {
            font-size: 32px;
            font-weight: 800;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .name-gradient {
            background: var(--purple-pink);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .welcome-subtitle {
            font-size: 14px;
            color: #888;
            font-weight: 500;
        }

        /* Activity Card Tabs */
        .activity-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .tab-pill {
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 800;
            color: #888;
            background: #f1f5f9;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
            text-transform: uppercase;
        }

        .tab-pill.active {
            background: var(--purple-pink);
            color: white;
            box-shadow: 0 4px 12px rgba(155, 70, 255, 0.2);
        }

        .activity-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .activity-item {
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: #f8faff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9B46FF;
            font-size: 14px;
        }

        .activity-content h6 {
            margin: 0;
            font-size: 13px;
            font-weight: 700;
            color: #1a1a2e;
        }

        .activity-content p {
            margin: 0;
            font-size: 11px;
            color: #888;
        }

        .empty-activity {
            text-align: center;
            padding: 40px 20px;
            color: #888;
            font-size: 13px;
            font-weight: 500;
        }

        /* Remove old bloat */
        .dashboard-bg, .blob, .pulsing-orb, .glass-card, .shimmer {
            display: none !important;
        }
    </style>
{% endblock %}

{% block body %}
{% set role = app.session.get('user_role') %}
<div class="dashboard-container">
    <!-- Header Section -->
    <div class="welcome-section">
        <h1 class="welcome-title">
            Welcome back, <span class="name-gradient">{{ app_user ? app_user.username : 'Explorer' }}</span>
        </h1>
        <p class="welcome-subtitle">Here's what's happening today in the CreaCo community.</p>
    </div>

    <!-- Quick Stats Grid -->
    <div class="stat-grid">

        <!-- Total Members -->
        <div class="stat-card">
            <span class="stat-label">Total Members</span>
            <h3 class="stat-value">{{ stats.users }}</h3>
            <div class="stat-icon-orb">
                <i class="ni ni-single-02"></i>
            </div>
            {% if stats.users is defined %}
                <span class="stat-badge" style="background:#f1f5f9; color:#64748b;">{{ stats.users }} total</span>
            {% endif %}
        </div>

        <!-- Live Events -->
        <div class="stat-card">
            <span class="stat-label">Live Events</span>
            <h3 class="stat-value">{{ stats.events }}</h3>
            <div class="stat-icon-orb">
                <i class="ni ni-calendar-grid-58"></i>
            </div>
            {% if stats.events is defined %}
                {% if stats.events > 0 %}
                    <span class="stat-badge" style="background:#E8F5E9; color:#2E7D32;">Active</span>
                {% else %}
                    <span class="stat-badge" style="background:#f1f5f9; color:#64748b;">None</span>
                {% endif %}
            {% endif %}
        </div>

        <!-- Innovation Ideas -->
        <div class="stat-card">
            <span class="stat-label">Innovation Ideas</span>
            <h3 class="stat-value">{{ stats.ideas }}</h3>
            <div class="stat-icon-orb">
                <i class="ni ni-bulb-61"></i>
            </div>
            {% if stats.ideas is defined and stats.ideas > 0 %}
                <span class="stat-badge" style="background:#f3e8ff; color:#7c3aed;">+{{ stats.ideas }}</span>
            {% endif %}
        </div>

        <!-- Active Partners -->
        <div class="stat-card">
            <span class="stat-label">Active Partners</span>
            <h3 class="stat-value">{{ stats.collaborators }}</h3>
            <div class="stat-icon-orb">
                <i class="ni ni-badge"></i>
            </div>
            {% if stats.collaborators is defined %}
                <span class="stat-badge" style="background:#eff6ff; color:#1d4ed8;">Trusted</span>
            {% endif %}
        </div>

    </div>

    <!-- Main Content Grid -->
    <div class="content-grid">
        <!-- CreaCo Platform Card -->
        <div class="creaco-card">
            <div>
                <p style="color: #9B46FF; font-weight: 800; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Built by Netwerkers</p>
                <h2 style="font-size: 36px; font-weight: 900; color: #1a1a2e; margin-bottom: 16px;">CreaCo Platform</h2>
                <p style="color: #666; font-size: 14px; line-height: 1.6; margin-bottom: 24px;">
                    Experience the future of collaborative creativity. We bridge the gap between imagination and execution for creators worldwide.
                </p>
                <a href="{{ path('event_list') }}" style="display: inline-block; padding: 12px 24px; background: var(--purple-pink); color: white; border-radius: 100px; font-weight: 700; font-size: 12px; text-transform: uppercase; text-decoration: none; box-shadow: 0 4px 12px rgba(155, 70, 255, 0.3);">
                    Explore Events
                </a>
            </div>
            <div class="logo-container">
                <img src="{{ asset('/assets/img/logocreaco2.png') }}" alt="CreaCo Logo" />
            </div>
        </div>

        <!-- Your Activity Card -->
        <div class="activity-card">
            <h5 style="font-weight: 800; color: #1a1a2e; margin-bottom: 20px;">
                {% if app.session.get('user_role') == 'ROLE_CONTENT_CREATOR' %}Your Activity{% else %}Discovery Center{% endif %}
            </h5>
            
            <div class="activity-tabs">
                <button class="tab-pill active">Ideas</button>
                <button class="tab-pill">Events</button>
                <button class="tab-pill">Missions</button>
                <button class="tab-pill">Meetings</button>
            </div>

            <div class="activity-list-container">
                {% if role == 'ROLE_CONTENT_CREATOR' %}
                    <div class="activity-list">
                        <div class="activity-item">
                            <div class="activity-icon"><i class="ni ni-bulb-61"></i></div>
                            <div class="activity-content">
                                <h6>New Idea Shared</h6>
                                <p>2 hours ago in Innovation</p>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-icon"><i class="ni ni-calendar-grid-58"></i></div>
                            <div class="activity-content">
                                <h6>Event Joined</h6>
                                <p>Yesterday • Creative Workshop</p>
                            </div>
                        </div>
                    </div>
                {% else %}
                    {% if latestIdeas is not empty %}
                        <div class="activity-list">
                            {% for idea in latestIdeas|slice(0, 3) %}
                            <div class="activity-item">
                                <div class="activity-icon"><i class="ni ni-bulb-61"></i></div>
                                <div class="activity-content">
                                    <h6>{{ idea.title }}</h6>
                                    <p>{{ idea.description|slice(0, 40) }}...</p>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-activity">
                            <i class="ni ni-archive-2 text-3xl mb-2 block opacity-20"></i>
                            No activity yet
                        </div>
                    {% endif %}
                {% endif %}
            </div>

            <a href="{{ path('app_idea_index') }}" style="display: block; width: 100%; padding: 14px; background: #1a1a2e; color: white; border-radius: 12px; text-align: center; font-weight: 700; font-size: 11px; text-transform: uppercase; margin-top: 24px; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#9B46FF'" onmouseout="this.style.background='#1a1a2e'">
                View All Insights
            </a>
        </div>
    </div>

    <!-- Upcoming Events (Keep as is but clean up) -->
    <div style="margin-top: 48px;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
            <h3 style="font-size: 24px; font-weight: 900; color: #1a1a2e;">Upcoming Events</h3>
            <a href="{{ path('event_list') }}" style="font-size: 12px; font-weight: 700; color: #9B46FF; text-decoration: none;">View Calendar</a>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
            {% if upcomingEvents is empty %}
                <div style="grid-column: span 4; padding: 60px; text-align: center; color: #888;">
                    <i class="ni ni-calendar-grid-58 text-5xl mb-4 block opacity-10"></i>
                    <p style="font-weight: 600;">No events yet — be the first to create one!</p>
                </div>
            {% else %}
                {% for event in upcomingEvents %}
                <div style="background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                    <div style="height: 160px; position: relative;">
                        <img src="{{ event.imagePath ?: asset('assets/img/curved-images/curved14.jpg') }}" style="width: 100%; height: 100%; object-fit: cover;" />
                        <div style="position: absolute; top: 12px; right: 12px; background: white; padding: 4px 10px; border-radius: 100px; font-size: 10px; font-weight: 900; color: #1a1a2e;">
                            {{ event.date|date('d M') }}
                        </div>
                    </div>
                    <div style="padding: 16px;">
                        <p style="color: #9B46FF; font-size: 9px; font-weight: 800; text-transform: uppercase; margin-bottom: 4px;">{{ event.category }}</p>
                        <h6 style="font-size: 14px; font-weight: 700; color: #1a1a2e; margin-bottom: 8px;">{{ event.name }}</h6>
                        <a href="{{ path('event_show', {'id': event.id}) }}" style="font-size: 10px; font-weight: 800; color: #1a1a2e; text-transform: uppercase; text-decoration: none;">Details →</a>
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
