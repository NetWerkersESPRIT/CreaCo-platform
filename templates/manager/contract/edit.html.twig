{% extends 'layouts/dashboard.html.twig' %}

{% block title %}Edit Contract - CreaCo Manager{% endblock %}
{% block breadcrumb %}Manager / Contracts / #{{ contract.contractNumber }} / Edit{% endblock %}
{% block page_title %}Modify Contract Terms{% endblock %}

{% block body %}
<div class="flex flex-wrap -mx-3 justify-center">
    <div class="w-full max-w-full px-3 lg:w-8/12">
        <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
            <div class="p-6 pb-0 mb-0 bg-white border-b-0 rounded-t-2xl">
                <h6>Edit Draft Contract</h6>
                <p class="text-sm text-slate-500">Refine the contractual terms before sending them to the partner.</p>
            </div>
            <div class="flex-auto p-6">
                {{ form_start(form) }}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            {{ form_row(form.title, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                        </div>
                        <div>
                            {{ form_row(form.amount, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            {{ form_row(form.startDate, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                        </div>
                        <div>
                            {{ form_row(form.endDate, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-2">
                            {{ form_label(form.terms, null, {'label_attr': {'class': 'mb-0 font-bold text-xs text-slate-700'}}) }}
                            <button type="button" class="ai-rephrase-btn text-xxs font-bold uppercase py-1 px-2 rounded-lg bg-gradient-to-tl from-purple-700 to-pink-500 text-white border-0 cursor-pointer hover:scale-105 transition-all" data-target="{{ form.terms.vars.id }}" data-context="contract_terms">
                                <i class="ni ni-wand-06 mr-1"></i> AI Formal Assist
                            </button>
                        </div>
                        {{ form_widget(form.terms, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                    </div>

                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-2">
                            {{ form_label(form.paymentSchedule, null, {'label_attr': {'class': 'mb-0 font-bold text-xs text-slate-700'}}) }}
                            <button type="button" class="ai-rephrase-btn text-xxs font-bold uppercase py-1 px-2 rounded-lg bg-gradient-to-tl from-purple-700 to-pink-500 text-white border-0 cursor-pointer hover:scale-105 transition-all" data-target="{{ form.paymentSchedule.vars.id }}" data-context="payment">
                                <i class="ni ni-wand-06 mr-1"></i> AI Formal Assist
                            </button>
                        </div>
                        {{ form_widget(form.paymentSchedule, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                    </div>

                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-2">
                            {{ form_label(form.confidentialityClause, null, {'label_attr': {'class': 'mb-0 font-bold text-xs text-slate-700'}}) }}
                            <button type="button" class="ai-rephrase-btn text-xxs font-bold uppercase py-1 px-2 rounded-lg bg-gradient-to-tl from-purple-700 to-pink-500 text-white border-0 cursor-pointer hover:scale-105 transition-all" data-target="{{ form.confidentialityClause.vars.id }}" data-context="clauses">
                                <i class="ni ni-wand-06 mr-1"></i> AI Formal Assist
                            </button>
                        </div>
                        {{ form_widget(form.confidentialityClause, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                    </div>

                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-2">
                            {{ form_label(form.cancellationTerms, null, {'label_attr': {'class': 'mb-0 font-bold text-xs text-slate-700'}}) }}
                            <button type="button" class="ai-rephrase-btn text-xxs font-bold uppercase py-1 px-2 rounded-lg bg-gradient-to-tl from-purple-700 to-pink-500 text-white border-0 cursor-pointer hover:scale-105 transition-all" data-target="{{ form.cancellationTerms.vars.id }}" data-context="clauses">
                                <i class="ni ni-wand-06 mr-1"></i> AI Formal Assist
                            </button>
                        </div>
                        {{ form_widget(form.cancellationTerms, {'attr': {'class': 'focus:shadow-soft-primary-outline text-sm leading-5.6 ease-soft block w-full appearance-none rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding px-3 py-2 font-normal text-gray-700 transition-all focus:border-fuchsia-300 focus:outline-none focus:transition-shadow'}}) }}
                    </div>

                    <div class="flex justify-between mt-8">
                        <a href="{{ path('app_manager_contract_show', {'id': contract.id}) }}" class="inline-block px-6 py-3 font-bold text-center text-slate-500 uppercase align-middle transition-all bg-transparent border border-gray-200 rounded-lg cursor-pointer leading-pro text-xs ease-soft-in tracking-tight-soft hover:bg-gray-50">
                            Back
                        </a>
                        <button type="submit" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-transparent border-0 rounded-lg cursor-pointer shadow-soft-md bg-x-25 bg-150 leading-pro text-xs ease-soft-in tracking-tight-soft bg-gradient-to-tl from-purple-700 to-pink-500 hover:scale-102 hover:shadow-soft-xs active:opacity-85">
                            Update Contract
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const aiButtons = document.querySelectorAll('.ai-rephrase-btn');
    
    aiButtons.forEach(btn => {
        btn.addEventListener('click', async function() {
            const targetId = this.getAttribute('data-target');
            const context = this.getAttribute('data-context');
            const textarea = document.getElementById(targetId);
            const originalValue = textarea.value.trim();
            
            if (!originalValue) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'info',
                        title: 'Empty Field',
                        text: 'Please type some initial thoughts first so the AI can rephrase them into formal language.',
                        confirmButtonColor: '#cb0c9f'
                    });
                } else {
                    alert('Please type some initial thoughts first.');
                }
                return;
            }
            
            const originalIcon = this.innerHTML;
            this.disabled = true;
            this.innerHTML = '<i class="ni ni-settings spin-slow mr-1"></i> Processing...';
            this.classList.add('opacity-70');
            textarea.classList.add('animate-pulse', 'bg-slate-50');
            
            try {
                const response = await fetch('{{ path("app_collab_ai_rephrase") }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        text: originalValue,
                        context: context,
                        requestId: {{ contract.collabRequest ? contract.collabRequest.id : 'null' }}
                    })
                });
                
                const data = await response.json();
                
                if (data.success && data.rephrased) {
                    textarea.value = data.rephrased;
                    
                    if (typeof Swal !== 'undefined') {
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        });
                        Toast.fire({
                            icon: 'success',
                            title: 'Formally Rephrased!'
                        });
                    }
                } else {
                    throw new Error(data.error || 'AI Failed to rephrase');
                }
            } catch (error) {
                console.error('AI Assist Error:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'AI Assist Failed',
                        text: error.message || 'We couldn\'t reach the AI rephrasing service. Please try again later.',
                        confirmButtonColor: '#cb0c9f'
                    });
                }
            } finally {
                this.disabled = false;
                this.innerHTML = originalIcon;
                this.classList.remove('opacity-70');
                textarea.classList.remove('animate-pulse', 'bg-slate-50');
            }
        });
    });

    // Date synchronization logic
    const startDateInput = document.getElementById('{{ form.startDate.vars.id }}');
    const endDateInput = document.getElementById('{{ form.endDate.vars.id }}');

    if (startDateInput && endDateInput) {
        startDateInput.addEventListener('change', function() {
            if (this.value) {
                endDateInput.min = this.value;
                if (endDateInput.value && endDateInput.value < this.value) {
                    endDateInput.value = this.value;
                }
            }
        });
    }
});
</script>
<style>
.spin-slow {
    display: inline-block;
    animation: fa-spin 2s infinite linear;
}
@keyframes fa-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(359deg); }
}
</style>
{% endblock %}
{% endblock %}
