{% extends 'layouts/dashboard.html.twig' %}

{% block title %}Manage Contracts - CreaCo Manager{% endblock %}
{% block breadcrumb %}Manager / Contracts{% endblock %}
{% block page_title %}Contracts Registry{% endblock %}

{% block body %}
<div class="w-full px-6 mx-auto mb-6">
    <div class="relative flex items-center p-0 mt-2 overflow-hidden bg-center bg-cover min-h-75 rounded-2xl" style="background-image: url('https://images.unsplash.com/photo-1507679799987-c73779587ccf?q=80&w=1950'); background-position-y: 50%">
        <span class="absolute inset-y-0 w-full h-full bg-center bg-cover bg-gradient-to-tl from-purple-700 to-pink-500 opacity-60"></span>
    </div>
    <div class="relative flex flex-col flex-auto min-w-0 p-4 mx-6 -mt-16 overflow-hidden break-words border-0 shadow-blur rounded-2xl bg-white/80 bg-clip-border backdrop-blur-2xl backdrop-saturate-200">
        <h4 class="mb-0 font-bold px-3">Contracts Registry</h4>
    </div>
</div>
<div class="flex flex-wrap -mx-3">
    {% include 'collaborator/_nav.html.twig' %}
    
    <div class="flex-none w-full max-w-full px-3">
        <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
            <div class="p-6 pb-0 mb-0 bg-white border-b-0 border-b-solid rounded-t-2xl border-b-transparent flex justify-between items-center">
                <h6 class="font-bold">Managed Collaboration Contracts</h6>
                <div class="flex space-x-2">
                    <span class="bg-gray-100 text-slate-500 text-xs font-bold px-3 py-1 rounded-pill">
                        <i class="ni ni-archive-2 mr-1"></i>Official Records
                    </span>
                </div>
            </div>
            <div class="px-6 py-4 flex flex-wrap items-center justify-between gap-4 bg-gray-50/50 border-b border-gray-100">
                <div class="flex items-center space-x-2 bg-white rounded-lg border border-gray-200 px-3 py-1 shadow-sm focus-within:ring-2 focus-within:ring-fuchsia-500/20 transition-all">
                    <i class="fas fa-search text-slate-400 text-xs"></i>
                    <input type="text" id="listing-search" placeholder="Search #, title, partner..." class="border-0 focus:ring-0 text-xs text-slate-600 w-48 md:w-64" autocomplete="off">
                </div>
                <div class="flex items-center space-x-3">
                    <label for="status-filter" class="text-xxs font-bold text-slate-400 uppercase">Status:</label>
                    <select id="status-filter" class="text-xs border-gray-200 rounded-lg focus:ring-fuchsia-500/20 focus:border-fuchsia-500 py-1 pl-2 pr-8 shadow-sm text-slate-600">
                        <option value="ALL">All Statuses</option>
                        <option value="DRAFT">Draft</option>
                        <option value="SENT_TO_COLLABORATOR">Sent</option>
                        <option value="SIGNED_BY_COLLABORATOR">Signed</option>
                        <option value="ACTIVE">Active</option>
                    </select>
                </div>
            </div>

            <div class="flex-auto px-0 pt-0 pb-2">
                <div class="p-0 overflow-x-auto">
                    <table class="items-center w-full mb-0 align-top border-gray-200 text-slate-500">
                        <thead class="align-bottom">
                            <tr>
                                <th class="px-6 py-3 font-bold text-left uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Contract # / Title</th>
                                <th class="px-6 py-3 pl-2 font-bold text-left uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Partner</th>
                                <th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Amount</th>
                                <th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Status</th>
                                <th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Effective Date</th>
                                <th class="px-6 py-3 font-semibold capitalize align-middle bg-transparent border-b border-gray-200 border-solid shadow-none tracking-none whitespace-nowrap text-slate-400 opacity-70"></th>
                            </tr>
                        </thead>
                        <tbody id="listing-container">
                            {% include 'manager/contract/_list.html.twig' %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('listing-search');
    const statusFilter = document.getElementById('status-filter');
    const container = document.getElementById('listing-container');
    let debounceTimer;

    function updateList() {
        const search = searchInput.value;
        const status = statusFilter.value;
        const url = new URL(window.location.href);
        
        url.searchParams.set('search', search);
        url.searchParams.set('status', status);

        container.style.opacity = '0.4';
        container.style.filter = 'blur(1px)';
        container.style.transition = 'all 0.3s ease';

        fetch(url, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.text())
        .then(html => {
            container.innerHTML = html;
            container.style.opacity = '1';
            container.style.filter = 'blur(0)';
            window.history.pushState({}, '', url);
        })
        .catch(error => {
            console.error('Error fetching filtered list:', error);
            container.style.opacity = '1';
        });
    }

    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(updateList, 300);
    });

    statusFilter.addEventListener('change', updateList);
});
</script>
{% endblock %}
