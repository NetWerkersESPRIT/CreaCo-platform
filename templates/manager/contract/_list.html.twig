{% for contract in contracts %}
<tr class="hover:bg-gray-50 transition-colors animate-slide-right stagger-{{ (loop.index0 % 4) + 1 }}">
    <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        <div class="flex px-4 py-1">
            <div class="flex flex-col justify-center">
                <h6 class="mb-0 text-sm leading-normal font-bold">#{{ contract.contractNumber }}</h6>
                <p class="mb-0 text-xs leading-tight text-slate-400">{{ contract.title }}</p>
            </div>
        </div>
    </td>
    <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        <p class="mb-0 text-xs font-bold leading-tight">{{ contract.collaborator.companyName }}</p>
        <p class="mb-0 text-xxs leading-tight text-slate-400">Trusted Partner</p>
    </td>
    <td class="p-2 text-sm leading-normal text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        <span class="font-bold text-slate-700">{{ contract.amount|number_format(2, '.', ' ') }} DT</span>
    </td>
    <td class="p-2 text-sm leading-normal text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        {% if contract.status == 'DRAFT' %}
            <span class="bg-gradient-to-tl from-slate-600 to-slate-300 px-3 text-xxs rounded-pill py-1 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white">Draft</span>
        {% elseif contract.status == 'SENT_TO_COLLABORATOR' or contract.status == 'SENT' %}
            <span class="bg-gradient-to-tl from-blue-600 to-cyan-400 px-3 text-xxs rounded-pill py-1 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white">Sent</span>
        {% elseif contract.status == 'SIGNED_BY_COLLABORATOR' %}
            <span class="bg-gradient-to-tl from-green-600 to-lime-400 px-3 text-xxs rounded-pill py-1 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white">Signed</span>
        {% else %}
            <span class="bg-gray-100 text-slate-400 px-3 text-xxs rounded-pill py-1 font-bold uppercase">{{ contract.status }}</span>
        {% endif %}
    </td>
    <td class="p-2 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        <span class="text-xs font-bold leading-tight text-slate-400">{{ contract.startDate|date('d/m/Y') }}</span>
    </td>
    <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-right pr-6">
        <a href="{{ path('app_manager_contract_show', {'id': contract.id}) }}" class="text-xs font-bold text-fuchsia-500 hover:text-fuchsia-700 transition-all uppercase">
            Details <i class="fas fa-eye ml-1"></i>
        </a>
    </td>
</tr>
{% else %}
<tr>
    <td colspan="6" class="p-6 text-center text-sm text-slate-400 italic">No contracts found in your managed history.</td>
</tr>
{% endfor %}
