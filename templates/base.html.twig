<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, shrink-to-fit=no"/>
		<link rel="apple-touch-icon" sizes="76x76" href="{{ asset('assets/img/apple-icon.png') }}"/>
		<link rel="icon" type="image/png" href="{{ asset('assets/img/logocrea.png') }}"/>
		<title>
			{% block title %}Event Management
			{% endblock %}
		</title>
		<!--     Fonts and icons     -->
		<link
		href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet"/>

		<!-- ✅ ADDED: Font Awesome CSS (fix icons not showing) -->
		<link
		rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

		<!-- Font Awesome Icons -->
		<script src="https://kit.fontawesome.com/42d5adcbca.js" crossorigin="anonymous"></script>
		<!-- Nucleo Icons -->
		<link href="{{ asset('assets/css/nucleo-icons.css') }}" rel="stylesheet"/>
		<link
		href="{{ asset('assets/css/nucleo-svg.css') }}" rel="stylesheet"/>
		<!-- Popper -->
		<script src="https://unpkg.com/@popperjs/core@2"></script>
		<!-- SweetAlert2 -->
		<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
		<!-- CreaCo Alert Helpers -->
		<script src="{{ asset('assets/js/alerts.js') }}"></script>
		<!-- Main Styling -->
		<link href="{{ asset('assets/css/soft-ui-dashboard-tailwind.css') }}?v=1.0.5" rel="stylesheet"/>

		<style>
			@keyframes fadeInUp {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			@keyframes revealScale {
				from {
					opacity: 0;
					transform: scale(0.95);
				}
				to {
					opacity: 1;
					transform: scale(1);
				}
			}
			@keyframes pulseGlow {
				0% {
					box-shadow: 0 0 0 0 rgba(235, 78, 150, 0.4);
				}
				70% {
					box-shadow: 0 0 0 10px rgba(235, 78, 150, 0);
				}
				100% {
					box-shadow: 0 0 0 0 rgba(235, 78, 150, 0);
				}
			}
			@keyframes slideRight {
				from {
					transform: translateX(-10px);
					opacity: 0;
				}
				to {
					transform: translateX(0);
					opacity: 1;
				}
			}
			.animate-fade-in-up {
				animation: fadeInUp 0.6s ease-out forwards;
			}
			.animate-reveal-scale {
				animation: revealScale 0.5s ease-out forwards;
			}
			.animate-pulse-glow {
				animation: pulseGlow 2s infinite;
			}
			.animate-slide-right {
				animation: slideRight 0.4s ease-out forwards;
			}

			.stagger-1 {
				animation-delay: 0.1s;
			}
			.stagger-2 {
				animation-delay: 0.2s;
			}
			.stagger-3 {
				animation-delay: 0.3s;
			}
			.stagger-4 {
				animation-delay: 0.4s;
			}

			.hover-scale {
				transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
			}
			.hover-scale:hover {
				transform: scale(1.03);
			}
		</style>

		{% block stylesheets %}{% endblock %}
	</head>

	<body class="m-0 font-sans antialiased font-normal text-base leading-default bg-gray-50 text-slate-500">
		{% if app_user %}
			{% include 'partials/_sidebar.html.twig' %}
		{% endif %}

		<main
			class="ease-soft-in-out {% if app_user %}xl:ml-68.5{% endif %} relative h-full max-h-screen rounded-xl transition-all duration-200">
			<!-- Navbar -->
			{% if app_user %}
				{% include 'partials/_navbar.html.twig' %}
			{% endif %}

			<div
				class="w-full px-6 py-6 mx-auto">

				{# ✅ SUCCESS (Green) #}
				{% for message in app.flashes('success') %}
					<div class="flash-alert relative w-full p-4 mb-4 text-white bg-gradient-to-tl from-green-600 to-lime-400 rounded-lg shadow-soft-xl">
						{{ message }}
					</div>
				{% endfor %}

				{# ⚠️ ERROR (Red) #}
				{% for message in app.flashes('error') %}
					<div class="flash-alert relative w-full p-4 mb-4 text-white bg-gradient-to-tl from-red-600 to-pink-500 rounded-lg shadow-soft-xl">
						{{ message }}
					</div>
				{% endfor %}

				{# ⚠️ WARNING (Yellow/Red) #}
				{% for message in app.flashes('warning') %}
					<div class="flash-alert relative w-full p-4 mb-4 text-white bg-gradient-to-tl from-red-500 to-yellow-400 rounded-lg shadow-soft-xl">
						{{ message }}
					</div>
				{% endfor %}

				{# ⚠️ DANGER / REFUSAL (Orange/Yellow) #}
				{% for message in app.flashes('danger') %}
					<div class="flash-alert relative w-full p-4 mb-4 text-white bg-gradient-to-tl from-orange-500 to-yellow-400 rounded-lg shadow-soft-xl">
						{{ message }}
					</div>
				{% endfor %}

				{# 🚀 POST APPROVED (Green Strong Pulse) #}
				{% for message in app.flashes('post_approved') %}
					<div class="flash-alert relative w-full p-6 mb-6 text-white bg-gradient-to-tl from-green-600 to-lime-400 rounded-lg shadow-soft-xl border-0 font-bold text-center animate-pulse">
						<i class="fas fa-check-circle mr-2"></i>
						{{ message }}
					</div>
				{% endfor %}

				{# 🛑 POST REFUSED (Red/Orange Strong Pulse) #}
				{% for message in app.flashes('post_refused') %}
					<div class="flash-alert relative w-full p-6 mb-6 text-white bg-gradient-to-tl from-red-600 to-orange-400 rounded-lg shadow-soft-xl border-0 font-bold text-center animate-pulse">
						<i class="fas fa-exclamation-triangle mr-2"></i>
						{{ message }}
					</div>
				{% endfor %}

				<div class="animate-fade-in-up"> {% block body %}{% endblock %}
					</div>

				</div>

			</main>

			{% block javascripts %}
				{# 1. Load the main dashboard script without 'async' to ensure it's ready #}
				<script src="{{ asset('assets/js/soft-ui-dashboard-tailwind.js') }}?v=1.0.5"></script>

				<script>
					document.addEventListener('DOMContentLoaded', () => { // --- 1. SMART DROPDOWN TOGGLE (The "Hybrid" Fix) ---
const dropdownTrigger = document.querySelector('[dropdown-trigger]');
const dropdownMenu = document.querySelector('[dropdown-menu]');

if (dropdownTrigger && dropdownMenu) {
dropdownTrigger.addEventListener('click', (e) => {
// We check if the dashboard script is already doing its job.
// If the menu doesn't have the 'opacity-100' class after a click,
// it means the dashboard script failed, so we trigger it manually.
setTimeout(() => {
if (dropdownMenu.classList.contains('opacity-0')) {
dropdownMenu.classList.remove('opacity-0', 'pointer-events-none');
dropdownMenu.classList.add('opacity-100', 'top-[100%]');
}
}, 10);
});

// Close when clicking outside
document.addEventListener('click', (e) => {
if (! dropdownTrigger.contains(e.target) && ! dropdownMenu.contains(e.target)) {
dropdownMenu.classList.add('opacity-0', 'pointer-events-none');
dropdownMenu.classList.remove('opacity-100');
}
});
}

// --- 2. FLASH ALERTS (Smooth auto-hide) ---
setTimeout(() => {
const alerts = document.querySelectorAll('.flash-alert');
alerts.forEach(alert => {
alert.style.transition = "opacity 0.5s ease";
alert.style.opacity = "0";
setTimeout(() => alert.remove(), 500);
});
}, 2500);

// --- 3. NOTIFICATION BADGE (Polling – badge only, list loads on dropdown open) ---
function syncNotifBadge() {
fetch('{{ path("app_api_notifications_unread_count") }}').then(r => r.ok ? r.json() : {
count: 0
}).then(data => {
const badge = document.getElementById('notif-badge');
if (! badge) 
return;



if (data.count > 0) {
badge.textContent = data.count > 9 ? '9+' : data.count;
badge.style.display = 'inline-flex';
} else {
badge.style.display = 'none';
}
}).catch(() => {});
}
syncNotifBadge();
setInterval(syncNotifBadge, 30000);

});
				</script>
			{% endblock %}

			{# Global Memory Game Modal #}
			{% include 'forum/post/game.html.twig' %}
			<script>
				// Global game state and functions
window.initMemoryGame = function () {
const grid = document.getElementById('game-grid');
const winModal = document.getElementById('win-modal');
const motivationalModal = document.getElementById('motivational-modal');
const gameMainCard = document.getElementById('game-main-card');
if (! grid) 
return;

grid.innerHTML = '';
let firstCard = null,
secondCard = null,
lockBoard = false,
matches = 0;
const gameIcons = [
'🐱',
'🐱',
'🦁',
'🦁',
'🦉',
'🦉',
'🦄',
'🦄'
];
if (winModal) 
winModal.classList.add('hidden');

if (motivationalModal) 
motivationalModal.classList.add('hidden');

if (gameMainCard) 
gameMainCard.style.setProperty('display', 'flex', 'important');

const shuffled = [... gameIcons].sort(() => 0.5 - Math.random());
shuffled.forEach((value) => {
const card = document.createElement('div');
card.className = 'memory-card';
card.dataset.value = value;
card.innerHTML = `<div class="front">${value}</div><div class="back"><i class="fas fa-paw"></i></div>`;
card.addEventListener('click', () => {
if (lockBoard || card === firstCard || card.classList.contains('matched')) 
return;

card.classList.add('flipped');
if (! firstCard) {
firstCard = card;
return;
}
secondCard = card;
lockBoard = true;
if (firstCard.dataset.value === secondCard.dataset.value) {
firstCard.classList.add('matched');
secondCard.classList.add('matched');
matches++;
firstCard = null;
secondCard = null;
lockBoard = false;
if (matches === 4) {
setTimeout(() => {
if (gameMainCard) 
gameMainCard.style.setProperty('display', 'none', 'important');

winModal.classList.remove('hidden');
winModal.style.setProperty('display', 'flex', 'important');
}, 500);
}
} else {
setTimeout(() => {
if (firstCard) 
firstCard.classList.remove('flipped');

if (secondCard) 
secondCard.classList.remove('flipped');

firstCard = null;
secondCard = null;
lockBoard = false;
}, 800);
}
});
grid.appendChild(card);
});
};

document.addEventListener('DOMContentLoaded', () => { // We use querySelectorAll because there might be multiple 'start-game' triggers (sidebar + forum)
const startButtons = document.querySelectorAll('#start-game');
const overlay = document.getElementById('game-overlay');
const winModal = document.getElementById('win-modal');
const motivationalModal = document.getElementById('motivational-modal');
const phraseEl = document.getElementById('motivational-phrase');
const playAgainBtn = document.getElementById('play-again');
const victoryContinueBtn = document.getElementById('victory-continue');
const closeGameFinalBtn = document.getElementById('close-game-final');
const backBtn = document.getElementById('back-from-game');

startButtons.forEach(btn => {
btn.addEventListener('click', (e) => {
e.preventDefault();
if (overlay) {
overlay.style.setProperty('display', 'flex', 'important');
window.initMemoryGame();
}
});
});

if (victoryContinueBtn) 
victoryContinueBtn.addEventListener('click', () => {
winModal.style.setProperty('display', 'none', 'important');
motivationalModal.classList.remove('hidden');
motivationalModal.style.setProperty('display', 'flex', 'important');
fetchMotivationalPhrase();
});

if (playAgainBtn) 
playAgainBtn.addEventListener('click', () => {
motivationalModal.style.setProperty('display', 'none', 'important');
window.initMemoryGame();
});

if (closeGameFinalBtn) 
closeGameFinalBtn.addEventListener('click', () => {
overlay.style.setProperty('display', 'none', 'important');
if (typeof transformCalmBot === 'function') 
transformCalmBot();

});

if (backBtn) 
backBtn.addEventListener('click', () => {
if (overlay) {
overlay.style.setProperty('display', 'none', 'important');
overlay.style.display = 'none';
}
});


function fetchMotivationalPhrase() {
if (! phraseEl) 
return;

fetch('/data/motivational_phrases.json').then(res => res.json()).then(phrases => {
phraseEl.textContent = `"${
phrases[Math.floor(Math.random() * phrases.length)]
}"`;
}).catch(() => {
phraseEl.textContent = `"You're doing amazing!"`;
});
}
});
			</script>

		</body>
	</html>
