{% extends 'base.html.twig' %}

{% block title %}My Support Requests | CreaCo{% endblock %}

{% block body %}
    <div class="w-full px-6 py-6 mx-auto">
        <div class="flex flex-col gap-4 mb-6">
            <div class="flex items-center justify-between">
                <div>
                    <h4 class="text-xl font-bold text-slate-900">My Support Requests</h4>
                    <p class="text-sm text-slate-500">Review the status of requests you sent to the admin.</p>
                </div>
                <a href="{{ path('app_front_home') }}" class="inline-flex items-center rounded-full bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-800">Browse courses</a>
            </div>
        </div>

        {% if tickets is empty %}
            <div class="rounded-3xl border border-slate-200 bg-white p-8 text-center shadow-soft-xl">
                <h5 class="text-lg font-semibold text-slate-900">No requests yet</h5>
                <p class="mt-2 text-sm text-slate-500">Send a support request from any course page to ask the admin for help.</p>
                <a href="{{ path('app_front_home') }}" class="mt-6 inline-flex items-center justify-center rounded-full bg-purple-700 px-5 py-3 text-sm font-semibold text-white hover:bg-purple-600">Find a course</a>
            </div>
        {% else %}
            <div class="overflow-x-auto rounded-3xl bg-white p-4 shadow-soft-xl border border-slate-200">
                <table class="min-w-full text-left text-sm text-slate-600">
                    <thead class="border-b border-slate-200 text-slate-900">
                        <tr>
                            <th class="px-4 py-3">Subject</th>
                            <th class="px-4 py-3">Course</th>
                            <th class="px-4 py-3">Priority</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Updated</th>
                            <th class="px-4 py-3">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {% for ticket in tickets %}
                            <tr>
                                <td class="px-4 py-4 font-semibold text-slate-800">{{ ticket.subject }}</td>
                                <td class="px-4 py-4 text-slate-600">{{ ticket.course ? ticket.course.titre : 'General' }}</td>
                                <td class="px-4 py-4">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {% if ticket.priority == 'High' %}bg-red-100 text-red-700{% elseif ticket.priority == 'Medium' %}bg-amber-100 text-amber-700{% else %}bg-slate-100 text-slate-700{% endif %}">{{ ticket.priority }}</span>
                                </td>
                                <td class="px-4 py-4">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {% if ticket.status == 'Closed' %}bg-emerald-100 text-emerald-700{% else %}bg-slate-100 text-slate-700{% endif %}">{{ ticket.status }}</span>
                                </td>
                                <td class="px-4 py-4 text-slate-500">{{ ticket.updatedAt ? ticket.updatedAt|date('d M Y H:i') : '' }}</td>
                                <td class="px-4 py-4">
                                    <a href="{{ path('app_help_ticket_show', {'id': ticket.id}) }}" class="text-purple-700 font-semibold hover:underline">View</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
{% endblock %}
