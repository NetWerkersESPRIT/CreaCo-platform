{% extends 'base.html.twig' %}

{% block title %}Help Requests | Admin | CreaCo{% endblock %}

{% block body %}
    <div class="w-full px-6 py-6 mx-auto">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h4 class="text-xl font-bold text-slate-900">Help Requests</h4>
                <p class="text-sm text-slate-500">View every support ticket sent by content creators and respond quickly.</p>
            </div>
            <a href="{{ path('app_admin_dashboard') }}" class="inline-flex items-center rounded-full bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-800">Back to dashboard</a>
        </div>

        <div class="overflow-x-auto rounded-3xl bg-white p-4 shadow-soft-xl border border-slate-200">
            <table class="min-w-full text-left text-sm text-slate-600">
                <thead class="border-b border-slate-200 text-slate-900">
                    <tr>
                        <th class="px-4 py-3">Creator</th>
                        <th class="px-4 py-3">Subject</th>
                        <th class="px-4 py-3">Course</th>
                        <th class="px-4 py-3">Priority</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3">Updated</th>
                        <th class="px-4 py-3">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for ticket in tickets %}
                        <tr>
                            <td class="px-4 py-4 font-semibold text-slate-800">{{ ticket.creator.username }}</td>
                            <td class="px-4 py-4">{{ ticket.subject }}</td>
                            <td class="px-4 py-4">{{ ticket.course ? ticket.course.titre : 'General' }}</td>
                            <td class="px-4 py-4">
                                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {% if ticket.priority == 'High' %}bg-red-100 text-red-700{% elseif ticket.priority == 'Medium' %}bg-amber-100 text-amber-700{% else %}bg-slate-100 text-slate-700{% endif %}">{{ ticket.priority }}</span>
                            </td>
                            <td class="px-4 py-4">
                                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {% if ticket.status == 'Closed' %}bg-emerald-100 text-emerald-700{% else %}bg-slate-100 text-slate-700{% endif %}">{{ ticket.status }}</span>
                            </td>
                            <td class="px-4 py-4 text-slate-500">{{ ticket.updatedAt ? ticket.updatedAt|date('d M Y H:i') : '-' }}</td>
                            <td class="px-4 py-4">
                                <a href="{{ path('app_admin_help_ticket_show', {'id': ticket.id}) }}" class="text-purple-700 font-semibold hover:underline">Review</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-4 py-8 text-center text-sm text-slate-500">No support requests available.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
