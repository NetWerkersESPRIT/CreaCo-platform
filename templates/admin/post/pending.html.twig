{% extends 'base.html.twig' %}

{% block title %}Pending Posts
{% endblock %}
{% block page_title %}Post Moderation
{% endblock %}
{% block breadcrumb %}Admin / Pending Posts
{% endblock %}

{% block stylesheets %}
<style>
    /* New/Seen Status Styles */
    .post-new {
        background: linear-gradient(135deg, rgba(155, 70, 255, 0.06), rgba(255, 70, 160, 0.06)) !important;
        position: relative;
    }
    
    .post-new::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(to bottom, #9B46FF, #FF46A0);
        z-index: 10;
    }

    .post-seen {
        background: white !important;
    }

    .spam-border::before {
        background: #EF4444 !important;
    }

    .spam-tint {
        background: rgba(239, 68, 68, 0.05) !important;
    }

    /* Pulse Dot */
    .pulse-dot {
        width: 8px;
        height: 8px;
        background: #22C55E;
        border-radius: 50%;
        display: inline-block;
        margin-right: 10px;
        box-shadow: 0 0 0 rgba(34, 197, 94, 0.4);
        animation: pulse-green 2s infinite;
    }

    @keyframes pulse-green {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
    }

    /* New Badge */
    .new-badge {
        background: linear-gradient(135deg, #9B46FF, #FF46A0);
        color: white;
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: bold;
        margin-left: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Action Buttons */
    .btn-view-modern {
        transition: all 0.2s ease;
    }

    .btn-glow {
        box-shadow: 0 0 12px rgba(155, 70, 255, 0.4);
        animation: glow-pulse 2s infinite;
    }

    @keyframes glow-pulse {
        0% { box-shadow: 0 0 5px rgba(155, 70, 255, 0.4); }
        50% { box-shadow: 0 0 15px rgba(155, 70, 255, 0.6); }
        100% { box-shadow: 0 0 5px rgba(155, 70, 255, 0.4); }
    }

    .btn-seen {
        background: #E0E0E0 !important;
        color: #475569 !important;
        box-shadow: none !important;
        background-image: none !important;
    }
</style>
{% endblock %}

{% block body %}
	<div class="flex flex-wrap -mx-3">
		<div class="flex-none w-full max-w-full px-3">
			<div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
				<div class="p-6 pb-0 mb-0 bg-white border-b-0 rounded-t-2xl flex justify-between items-center">
					<h6>{{ showSpam ? 'Flagged Spam Posts' : 'Pending Posts' }}</h6>
					<div class="flex gap-2">
						<a href="{{ path('admin_post_pending') }}" class="px-4 py-2 text-xs font-bold {{ not showSpam ? 'text-purple-700 bg-purple-100' : 'text-slate-400 bg-gray-50' }} rounded-lg transition-all border-0 cursor-pointer text-decoration-none">
							Pending
						</a>
						<a href="{{ path('admin_post_pending', {spam: 1}) }}" class="px-4 py-2 text-xs font-bold {{ showSpam ? 'text-red-700 bg-red-100' : 'text-slate-400 bg-gray-50' }} rounded-lg transition-all border-0 cursor-pointer text-decoration-none">
							<i class="fas fa-robot mr-1"></i>
							Spam Filter
						</a>
					</div>
				</div>
				<div class="flex-auto px-0 pt-0 pb-2">
					<div class="p-0 overflow-x-auto">
						<table class="items-center w-full mb-0 align-top border-gray-200 text-slate-500">
							<thead class="align-bottom">
								<tr>
									<th class="px-6 py-3 font-bold text-left uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Title</th>
									<th class="px-6 py-3 pl-2 font-bold text-left uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Author</th>
									<th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Status</th>
									<th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Spam Score</th>
									<th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Created At</th>
									<th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for post in posts %}
									<tr id="post-row-{{ post.id }}" 
                                        class="hover:bg-gray-50/50 transition-colors cursor-pointer {{ not post.isSeen ? 'post-new' : 'post-seen' }} {{ post.isSpam ? 'spam-border spam-tint' : '' }}" 
                                        onclick="handleViewClick(event, {{ post.id }}, '{{ path('admin_post_pending_show', {'id': post.id}) }}')">
										<td class="p-4 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-sm">
											<div class="flex px-2 py-1">
												<div class="flex flex-col justify-center">
													<div class="flex items-center">
                                                        {% if not post.isSeen %}
                                                            <span class="pulse-dot"></span>
                                                        {% endif %}
														<h6 class="mb-0 leading-normal text-sm text-slate-700 font-bold hover:text-purple-700 transition-colors">{{ post.title }}</h6>
														{% if post.isSpam %}
															<span class="ml-2 px-2 py-0.5 text-[10px] bg-red-100 text-red-700 rounded-full font-bold">SPAM</span>
														{% endif %}
                                                        {% if not post.isSeen %}
                                                            <span class="new-badge">NEW</span>
                                                        {% endif %}
													</div>
												</div>
											</div>
										</td>
										<td class="p-4 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-sm">
											<span class="font-bold text-slate-700">{{ post.user ? post.user.username : 'Anonymous' }}</span>
										</td>
										<td class="p-4 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-xs">
											{% if post.status == 'pending' %}
												<span class="px-2 py-1 rounded-lg bg-orange-100 text-orange-700 font-bold text-[10px] uppercase">Pending</span>
											{% elseif post.status == 'draft' %}
												<span class="px-2 py-1 rounded-lg bg-slate-100 text-slate-600 font-bold text-[10px] uppercase">Draft</span>
											{% else %}
												<span class="px-2 py-1 rounded-lg bg-gray-100 text-gray-500 font-bold text-[10px] uppercase">{{ post.status }}</span>
											{% endif %}
										</td>
										<td class="p-4 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-xs">
											{% set score = post.spamScore|default(0) %}
											<span class="font-bold {% if score >= 70 %}text-red-600{% elseif score >= 40 %}text-orange-500{% else %}text-green-500{% endif %}">
												{{ score }}/100
											</span>
										</td>
										<td class="p-4 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-xs">
											<span class="font-bold text-slate-400">{{ post.createdAt|date('Y-m-d H:i') }}</span>
										</td>
										<td class="p-4 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-center">
											<a href="{{ path('admin_post_pending_show', {'id': post.id}) }}" 
                                               onclick="handleViewClick(event, {{ post.id }}, '{{ path('admin_post_pending_show', {'id': post.id}) }}')"
                                               class="view-btn-{{ post.id }} inline-block px-4 py-2 text-[10px] font-bold text-white uppercase {{ not post.isSeen ? 'bg-gradient-to-tl from-purple-700 to-pink-500 btn-glow' : 'btn-seen' }} rounded-lg shadow-soft-md hover:scale-102 transition-all text-decoration-none">
												<i class="fas fa-eye mr-1"></i>
												View
											</a>
										</td>

									</tr>
								{% else %}
									<tr>
										<td colspan="6" class="p-6 text-center text-slate-400 font-bold uppercase text-xs">{{ showSpam ? 'No spam posts found.' : 'No pending posts.' }}</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function handleViewClick(event, postId, url) {
    event.preventDefault();
    event.stopPropagation();

    const row = document.getElementById('post-row-' + postId);
    const viewBtn = document.querySelector('.view-btn-' + postId);
    
    // Optimistic UI update or wait for fetch - user requested wait for fetch then navigate
    fetch(`/admin/posts/${postId}/mark-seen`, { 
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    }).finally(() => {
        // We navigate even if mark-seen fails (safety first)
        window.location.href = url;
    });

    // Subtly update UI in case of back navigation or slow redirect
    if (row) {
        row.classList.remove('post-new');
        row.classList.add('post-seen');
        row.querySelector('.new-badge')?.remove();
        row.querySelector('.pulse-dot')?.remove();
        if (viewBtn) {
            viewBtn.classList.remove('btn-glow');
            viewBtn.classList.add('btn-seen');
        }
    }
}
</script>
{% endblock %}
