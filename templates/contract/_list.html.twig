{% for contract in contracts %}
<tr class="hover:bg-gray-50 transition-colors animate-slide-right stagger-{{ (loop.index0 % 4) + 1 }}">
    <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        <div class="flex px-4 py-1">
            <div class="flex flex-col justify-center">
                <h6 class="mb-0 text-sm leading-normal">
                    <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="hover:text-fuchsia-500 transition-colors">
                        #{{ contract.contractNumber }}
                    </a>
                </h6>
                <p class="mb-0 text-xs leading-tight text-slate-400">Partner : {{ contract.collabRequest.collaborator.companyName }}</p>
            </div>
        </div>
    </td>
    <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-xs font-bold text-slate-700">
         {{ contract.collaborator.domain }}
    </td>
    <td class="p-2 text-sm leading-normal text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        {% if contract.status == 'SIGNED_BY_COLLABORATOR' %}
            <span class="bg-gradient-to-tl from-green-600 to-lime-400 px-2.5 text-xs rounded-1.8 py-1.4 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white">Signed</span>
        {% elseif contract.status == 'SENT_TO_COLLABORATOR' %}
            <span class="bg-gradient-to-tl from-blue-600 to-cyan-400 px-2.5 text-xs rounded-1.8 py-1.4 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white">Sent</span>
        {% elseif contract.status == 'DRAFT' %}
            <span class="bg-gray-100 text-slate-400 px-2.5 text-xs rounded-1.8 py-1.4 font-bold uppercase">Draft</span>
        {% else %}
            <span class="bg-gray-100 text-slate-400 px-2.5 text-xs rounded-1.8 py-1.4 font-bold uppercase">{{ contract.status }}</span>
        {% endif %}
    </td>
    <td class="p-2 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent text-xs">
        {{ contract.startDate|date('d/m/Y') }}
    </td>
    <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
        <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="text-xs font-bold text-fuchsia-500 hover:underline">
            View
        </a>
    </td>
</tr>
{% else %}
<tr><td colspan="5" class="p-6 text-center text-sm text-slate-400 italic">No contracts found matching your search.</td></tr>
{% endfor %}
