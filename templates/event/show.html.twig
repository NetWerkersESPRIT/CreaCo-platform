{% extends 'base.html.twig' %}

{% block title %}Event Details{% endblock %}
{% block page_title %}Event Details{% endblock %}

{% block body %}
<div class="w-full p-6 mx-auto">
    <div class="flex flex-wrap -mx-3">
        <div class="w-full max-w-full px-3 shrink-0 md:flex-0 md:w-6/12">
            <h6 class="mb-0 font-bold capitalize">{{ event.name }}</h6>
            <p class="mb-0 leading-normal text-sm">{{ event.category }}</p>
        </div>
        <div class="w-full max-w-full px-3 text-right shrink-0 md:flex-0 md:w-6/12">
            <a href="{{ path('event_list') }}" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-transparent border-0 rounded-lg cursor-pointer leading-pro text-xs ease-soft-in shadow-soft-md bg-150 bg-x-25 bg-gradient-to-tl from-gray-900 to-slate-800 hover:shadow-soft-2xl hover:scale-102">Back to List</a>
            
            <a href="{{ path('event_manage', {'id': event.id}) }}" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-transparent border-0 rounded-lg cursor-pointer leading-pro text-xs ease-soft-in shadow-soft-md bg-150 bg-x-25 bg-gradient-to-tl from-cyan-500 to-blue-500 hover:shadow-soft-2xl hover:scale-102">Manage Reservations</a>
        </div>
    </div>
    
    <div class="flex flex-wrap -mx-3 mt-4">
        <div class="w-full max-w-full px-3 mb-6 lg:mb-0 lg:w-full lg:flex-none">
            <div class="relative flex flex-col min-w-0 break-words bg-white shadow-soft-xl rounded-2xl bg-clip-border">
                <div class="flex-auto p-4">
                    <div class="flex flex-wrap -mx-3">
                        <div class="max-w-full px-3 lg:w-1/2 lg:flex-none">
                            <div class="flex flex-col h-full">
                                <h5 class="font-bold">Description</h5>
                                <p class="mb-2 leading-normal text-sm text-slate-500">{{ event.description }}</p>
                                
                                <div class="mt-4">
                                     <h6 class="font-bold text-sm">Details</h6>
                                     <ul class="list-disc pl-5 text-sm text-slate-500">
                                        <li><strong>Date:</strong> {{ event.date|date('Y-m-d') }} at {{ event.time|date('H:i') }}</li>
                                        <li><strong>Type:</strong> {{ event.type }}</li>
                                        <li><strong>Organizer:</strong> {{ event.organizer }}</li>
                                        <li><strong>Capacity:</strong> {{ event.capacity ? event.capacity : 'Unlimited' }}</li>
                                        {% if event.type == 'online' %}
                                            <li><strong>Platform:</strong> {{ event.platform }}</li>
                                            <li><strong>Link:</strong> <a href="{{ event.meetingLink }}" class="text-blue-500 hover:text-blue-700">{{ event.meetingLink }}</a></li>
                                        {% else %}
                                            <li><strong>Address:</strong> {{ event.address }}</li>
                                       {% if event.googleMapsLink %}
                                                {{ event.googleMapsLink|raw }}
                                            {% endif %}
                                        {% endif %}
                                     </ul>

                                      {% if event.type != 'online' %}
                                      <div id="weather-section" class="mt-4 hidden">
                                          <div class="p-4 rounded-xl bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-100 shadow-sm transition-all duration-300">
                                              <div class="flex items-center gap-3 mb-2">
                                                  <div class="p-2 bg-white rounded-lg shadow-sm">
                                                      <i class="fas fa-cloud-sun text-blue-500"></i>
                                                  </div>
                                                  <span class="font-bold text-xs text-slate-700 uppercase tracking-wider">Expected Weather</span>
                                              </div>
                                              <div id="weather-content" class="text-sm text-slate-600">
                                                  <p class="animate-pulse">Loading forecast...</p>
                                              </div>
                                          </div>
                                      </div>
                                      {% endif %}
                                </div>

                                <div class="mt-6">
                                    <a href="{{ path('event_reserve', {'id': event.id}) }}" class="inline-block px-8 py-4 font-bold leading-normal text-center text-white align-middle transition-all bg-blue-500 border-0 rounded-lg cursor-pointer text-sm ease-in shadow-md hover:shadow-lg hover:bg-blue-600">
                                        Reserve My Spot
                                    </a>
                                </div>
                            </div>
                        </div>
                         <div class="max-w-full px-3 mt-12 ml-auto text-center lg:mt-0 lg:w-5/12 lg:flex-none">
                            <div class="sticky top-6 lg:top-10">
                                <div class="w-full bg-gradient-to-tl from-purple-700 to-pink-500 rounded-2xl shadow-soft-2xl overflow-hidden relative" style="aspect-ratio: 16/9; min-height: 200px;">
                                    {% if event.imagePath %}
                                        <img src="{{ event.imagePath }}" class="absolute top-0 left-0 w-full h-full object-cover" alt="{{ event.name }}">
                                    {% else %}
                                        <img src="{{ asset('assets/img/shapes/waves-white.svg') }}" class="absolute top-0 hidden w-full h-full lg:block" alt="waves">
                                        <div class="relative flex items-center justify-center h-full">
                                            <img class="relative z-20 w-32 pt-6" src="{{ asset('assets/img/illustrations/rocket-white.png') }}" alt="rocket">
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% if event.type != 'online' %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const weatherSection = document.getElementById('weather-section');
    const weatherContent = document.getElementById('weather-content');
    const eventDate = '{{ event.date|date('Y-m-d') }}';

    if (weatherSection && weatherContent) {
        weatherSection.classList.remove('hidden');
        
        fetch('{{ path('api_weather') }}')
            .then(response => response.json())
            .then(data => {
                if (data.hourly && data.hourly.time) {
                    const times = data.hourly.time;
                    const temps = data.hourly.temperature_2m;
                    const rains = data.hourly.rain;

                    const dayIndices = times.map((t, i) => t.startsWith(eventDate) ? i : -1).filter(i => i !== -1);

                    if (dayIndices.length > 0) {
                        let totalTemp = 0;
                        let maxRain = 0;
                        let count = 0;

                        dayIndices.forEach(idx => {
                            const hour = parseInt(times[idx].split('T')[1].split(':')[0]);
                            if (hour >= 8 && hour <= 20) {
                                totalTemp += temps[idx];
                                if (rains[idx] > maxRain) maxRain = rains[idx];
                                count++;
                            }
                        });

                        const avgTemp = (totalTemp / count).toFixed(1);
                        const rainStatus = maxRain > 0.5 ? 'Rain expected 🌧️' : 'Nice weather expected ☀️';
                        
                        weatherContent.innerHTML = `
                            <div class="flex flex-col gap-1">
                                <div class="flex items-center justify-between">
                                    <span class="font-medium text-slate-800">Forecasted Temp:</span>
                                    <span class="font-bold text-fuchsia-600">${avgTemp}°C</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span class="font-medium text-slate-800">Conditions:</span>
                                    <span class="${maxRain > 0.5 ? 'text-red-500' : 'text-green-500'} font-semibold">${rainStatus}</span>
                                </div>
                            </div>
                        `;
                    } else {
                        weatherContent.innerHTML = '<p class="text-slate-400 italic">Forecast only available within 16 days of today.</p>';
                    }
                }
            })
            .catch(error => {
                console.error('Weather Fetch Error:', error);
                weatherSection.style.display = 'none';
            });
    }
});
</script>
{% endif %}
{% endblock %}