{% extends './base.html.twig' %}

{% block title %}Modify Resource
{% endblock %}

{% block breadcrumbs %}
	<li class="text-sm leading-normal">
		<a class="opacity-50 text-slate-700" href="{{ path('app_ressource_index') }}">Resources</a>
	</li>
	<li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
		Modifiy
	</li>
{% endblock %}

{% block page_title %}Modify Resource
{% endblock %}

{% block body %}
	<div class="flex flex-wrap -mx-3">
		<div class="flex-none w-full max-w-full px-3">
			<div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 border-transparent border-solid shadow-soft-xl rounded-2xl bg-clip-border">
				<div class="p-6 pb-0 mb-0 bg-white border-b-0 border-b-solid rounded-t-2xl border-b-transparent">
					<h6>Modifiying :
						<span class="text-fuchsia-500">{{ ressource.nom }}</span>
					</h6>
				</div>
				<div class="flex-auto p-6">
					<div class="mb-4 p-4 bg-gray-50 rounded-xl border border-solid border-gray-200">
						{% if ressource.type == 'TEXTE' or ressource.contenu %}
							<p class="text-sm mb-1">
								<strong>Textual Resource :</strong>
							</p>
							<p class="text-xs text-slate-500 mb-0">This Resource contains text and is not linked to a file.</p>
						{% else %}
							{% set fileUrl = null %}
							{% if ressource.url %}
								{% if ressource.url starts with 'http://' or ressource.url starts with 'https://' %}
									{% set fileUrl = ressource.url %}
								{% elseif ressource.url starts with '/uploads/' or ressource.url starts with 'uploads/' %}
									{% set fileUrl = ressource.url %}
								{% else %}
									{% set fileUrl = vich_uploader_asset(ressource, 'file') %}
								{% endif %}
							{% endif %}

							{% if fileUrl %}
								<p class="text-sm mb-0">
									<strong>Current File :</strong>
									<a href="{{ fileUrl }}" target="_blank" class="text-fuchsia-500 font-bold ml-2">
										<i class="fas fa-external-link-alt mr-1"></i>
										View Resource
									</a>
								</p>
							{% else %}
								<p class="text-sm mb-0 text-slate-500">
									<strong>No file currently associated with this resource.</strong>
								</p>
							{% endif %}
						{% endif %}
						<p class="text-xs text-slate-400 mt-1 italic">Leave the "File" field empty to keep the current file.</p>
					</div>

					{{ include('back/ressource/_form.html.twig', {'button_label': 'Update'}) }}

					<div class="mt-6 flex justify-between items-center">
						<a href="{{ path('app_ressource_index') }}" class="text-xs font-semibold leading-tight text-slate-400 bg-gray-100 px-4 py-2 rounded-xl">
							<i class="fas fa-arrow-left mr-1"></i>
							Retour à la liste
						</a>

						<div class="bg-red-50 p-4 rounded-xl border border-red-100">
							<h6 class="text-xs font-bold text-red-600 uppercase mb-2">Danger Zone</h6>
							{{ include('back/ressource/_delete_form.html.twig') }}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
