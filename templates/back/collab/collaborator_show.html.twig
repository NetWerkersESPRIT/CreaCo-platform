{% extends 'base.html.twig' %}

{% block title %}Partner Profile - {{ partner.companyName }}{% endblock %}

{% block breadcrumbs %}
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        Collaboration
    </li>
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        <a href="{{ path('admin_collab_collaborators') }}" class="opacity-50">Partners</a>
    </li>
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        Profile
    </li>
{% endblock %}

{% block page_title %}Partner Details{% endblock %}

{% block body %}
<div class="w-full px-6 py-6 mx-auto">
    <div class="flex flex-wrap -mx-3">
        <!-- Profile Overview Card -->
        <div class="w-full max-w-full px-3 mb-6 lg:w-4/12">
            <div class="relative flex flex-col min-w-0 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
                <div class="flex-auto p-4">
                    <div class="flex flex-col items-center">
                        <div class="w-24 h-24 rounded-2xl bg-gradient-to-tl from-purple-700 to-pink-500 flex items-center justify-center mb-4">
                            <span class="text-white text-4xl font-bold">{{ partner.companyName|slice(0, 1)|upper }}</span>
                        </div>
                        <h5 class="mb-0 font-bold">{{ partner.companyName }}</h5>
                        <p class="mb-4 text-sm font-semibold leading-normal text-slate-400">{{ partner.domain }}</p>
                        
                        {% if partner.status == 'ACTIVE' %}
                            <span class="bg-gradient-to-tl from-green-600 to-lime-400 px-4 text-xs rounded-1.8 py-1.4 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white mb-6">Active Partner</span>
                        {% else %}
                            <span class="bg-gradient-to-tl from-slate-600 to-slate-300 px-4 text-xs rounded-1.8 py-1.4 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white mb-6">{{ partner.status }}</span>
                        {% endif %}

                        <div class="flex justify-around w-full mb-6 border-y py-4">
                            <div class="text-center">
                                <h6 class="mb-0 font-bold">{{ partner.contracts|length }}</h6>
                                <p class="mb-0 text-xs text-slate-400 font-semibold uppercase">Contracts</p>
                            </div>
                            <div class="text-center border-l pl-8">
                                <h6 class="mb-0 font-bold">{{ partner.collabRequests|length }}</h6>
                                <p class="mb-0 text-xs text-slate-400 font-semibold uppercase">Requests</p>
                            </div>
                        </div>

                        <div class="w-full">
                            <a href="{{ path('admin_collab_collaborator_edit', {'id': partner.id}) }}" class="inline-block w-full px-6 py-3 mb-2 font-bold text-center text-white uppercase align-middle transition-all bg-transparent border-0 rounded-lg cursor-pointer leading-pro text-xs ease-soft-in shadow-soft-md bg-gradient-to-tl from-purple-700 to-pink-500 hover:scale-102 active:opacity-85 hover:shadow-soft-xs">
                                Edit Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Details & Activity -->
        <div class="w-full max-w-full px-3 lg:w-8/12">
            <!-- Contact Info -->
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
                <div class="p-4 pb-0 mb-0 bg-white rounded-t-2xl">
                    <h6 class="mb-0 text-sm font-bold uppercase text-slate-400">Contact Information</h6>
                </div>
                <div class="flex-auto p-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="mb-0 text-xs font-bold text-slate-400">Representative</p>
                            <p class="text-sm font-bold text-slate-700">{{ partner.name }}</p>
                        </div>
                        <div>
                            <p class="mb-0 text-xs font-bold text-slate-400">Email</p>
                            <p class="text-sm font-bold text-slate-700">{{ partner.email }}</p>
                        </div>
                        <div>
                            <p class="mb-0 text-xs font-bold text-slate-400">Phone</p>
                            <p class="text-sm font-bold text-slate-700">{{ partner.phone|default('N/A') }}</p>
                        </div>
                        <div>
                            <p class="mb-0 text-xs font-bold text-slate-400">Website</p>
                            <a href="{{ partner.website|default('#') }}" target="_blank" class="text-sm font-bold text-purple-700 hover:underline">{{ partner.website|default('N/A') }}</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
                <div class="p-4 pb-0 mb-0 bg-white rounded-t-2xl">
                    <h6 class="mb-0 text-sm font-bold uppercase text-slate-400">About the Partner</h6>
                </div>
                <div class="flex-auto p-4">
                    <p class="text-sm text-slate-600 leading-relaxed">
                        {{ partner.description|default('No description provided.')|nl2br }}
                    </p>
                </div>
            </div>

            <!-- History Table -->
            <div class="relative flex flex-col min-w-0 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
                <div class="p-4 pb-0 mb-0 bg-white rounded-t-2xl">
                    <h6 class="mb-0">Strategic Interaction History</h6>
                </div>
                <div class="flex-auto px-0 pt-0 pb-2">
                    <div class="p-0 overflow-x-auto">
                        <table class="items-center w-full mb-0 align-top border-gray-200 text-slate-500">
                            <thead class="align-bottom">
                                <tr>
                                    <th class="px-6 py-3 font-bold text-left uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Type</th>
                                    <th class="px-6 py-3 pl-2 font-bold text-left uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Reference</th>
                                    <th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Status</th>
                                    <th class="px-6 py-3 font-bold text-center uppercase align-middle bg-transparent border-b border-gray-200 shadow-none text-xxs border-b-solid tracking-none whitespace-nowrap text-slate-400 opacity-70">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for contract in partner.contracts %}
                                    <tr>
                                        <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <div class="px-4">
                                                <span class="text-xxs font-bold px-2.5 py-1.4 rounded-1.8 bg-purple-100 text-purple-700 uppercase">Contract</span>
                                            </div>
                                        </td>
                                        <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <p class="mb-0 text-xs font-bold leading-tight">{{ contract.title }}</p>
                                        </td>
                                        <td class="p-2 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <span class="text-xs font-bold leading-tight text-slate-400">{{ contract.status }}</span>
                                        </td>
                                        <td class="p-2 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <span class="text-xs font-bold leading-tight text-slate-400">{{ contract.createdAt|date('d/m/Y') }}</span>
                                        </td>
                                    </tr>
                                {% endfor %}
                                {% for request in partner.collabRequests %}
                                    <tr>
                                        <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <div class="px-4">
                                                <span class="text-xxs font-bold px-2.5 py-1.4 rounded-1.8 bg-pink-100 text-pink-700 uppercase">Request</span>
                                            </div>
                                        </td>
                                        <td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <p class="mb-0 text-xs font-bold leading-tight">{{ request.title }}</p>
                                        </td>
                                        <td class="p-2 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <span class="text-xs font-bold leading-tight text-slate-400">{{ request.status }}</span>
                                        </td>
                                        <td class="p-2 text-center align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
                                            <span class="text-xs font-bold leading-tight text-slate-400">{{ request.createdAt|date('d/m/Y') }}</span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
