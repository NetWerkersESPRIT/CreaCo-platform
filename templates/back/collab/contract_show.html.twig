{% extends 'base.html.twig' %}

{% block title %}Contract Details - Admin{% endblock %}

{% block breadcrumbs %}
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        Collaboration
    </li>
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        <a href="{{ path('admin_collab_contracts') }}" class="opacity-50">Contracts</a>
    </li>
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        View
    </li>
{% endblock %}

{% block page_title %}Agreement Details{% endblock %}

{% block body %}
<div class="w-full px-6 py-6 mx-auto">
    <div class="flex flex-wrap -mx-3 mb-4 items-center">
        <div class="w-full px-3">
            <h5 class="mb-0 font-bold text-slate-700">Contract #{{ contract.contractNumber }}</h5>
            <p class="text-xs text-slate-400 mb-0">Legal agreement between CreaCo and {{ contract.collaborator.companyName }}.</p>
        </div>
    </div>

    <div class="flex flex-wrap -mx-3">
        <div class="w-full lg:w-8/12 px-3">
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border p-6">
                <div class="flex justify-between items-center mb-6">
                    <h6 class="font-bold text-slate-700 mb-0">General Terms</h6>
                    {% if contract.status == 'SIGNED' or contract.status == 'ACTIVE' %}
                        <span class="bg-gradient-to-tl from-green-600 to-lime-400 px-3 text-xs rounded-1.8 py-1.5 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white shadow-soft-md">Active</span>
                    {% elseif contract.status == 'PENDING' %}
                        <span class="bg-gradient-to-tl from-purple-700 to-pink-500 px-3 text-xs rounded-1.8 py-1.5 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white shadow-soft-md">Pending</span>
                    {% else %}
                        <span class="bg-gradient-to-tl from-red-600 to-pink-500 px-3 text-xs rounded-1.8 py-1.5 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white shadow-soft-md">{{ contract.status }}</span>
                    {% endif %}
                </div>

                <div class="mb-6">
                    <h4 class="font-bold text-slate-700 mb-2">{{ contract.title }}</h4>
                    <div class="bg-gray-50 rounded-xl p-4 text-sm text-slate-600 italic">
                        {{ contract.terms|nl2br }}
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">CONTRACT AMOUNT</p>
                        <h5 class="font-bold text-green-600">{{ contract.amount|number_format(0, '.', ' ') }} DT</h5>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">SIGNATURE TOKEN</p>
                        <code class="text-xs bg-gray-100 p-1 rounded">{{ contract.signatureToken }}</code>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-gray-100">
                    <h6 class="font-bold text-slate-700 mb-4">Signature Tracking</h6>
                    <div class="flex flex-wrap -mx-3">
                        <div class="w-full md:w-1/2 px-3 mb-4">
                            <div class="p-4 rounded-xl {{ contract.creatorSignatureDate ? 'bg-green-50 border-green-200' : 'bg-gray-50' }} border">
                                <p class="text-[10px] font-bold text-slate-400 uppercase mb-2">AGENCY (CREACO)</p>
                                <div class="flex items-center">
                                    <i class="fas {{ contract.creatorSignatureDate ? 'fa-check-circle text-green-500' : 'fa-clock text-slate-300' }} text-xl mr-3"></i>
                                    <div>
                                        <p class="text-sm font-bold text-slate-700 mb-0">
                                            {{ contract.creatorSignatureDate ? 'Signed on ' ~ contract.creatorSignatureDate|date('d/m/Y') : 'Pending Signature' }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="w-full md:w-1/2 px-3 mb-4">
                            <div class="p-4 rounded-xl {{ contract.collaboratorSignatureDate ? 'bg-green-50 border-green-200' : 'bg-gray-50' }} border">
                                <p class="text-[10px] font-bold text-slate-400 uppercase mb-2">PARTNER ({{ contract.collaborator.companyName }})</p>
                                <div class="flex items-center">
                                    <i class="fas {{ contract.collaboratorSignatureDate ? 'fa-check-circle text-green-500' : 'fa-clock text-slate-300' }} text-xl mr-3"></i>
                                    <div>
                                        <p class="text-sm font-bold text-slate-700 mb-0">
                                            {{ contract.collaboratorSignatureDate ? 'Signed on ' ~ contract.collaboratorSignatureDate|date('d/m/Y') : 'Pending Signature' }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-8 flex space-x-4">
                    <a href="{{ path('admin_collab_contracts') }}" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-slate-400 border-0 rounded-lg cursor-pointer shadow-soft-md leading-pro text-xs ease-soft-in hover:bg-slate-500 active:opacity-85 tracking-tight-soft">
                        BACK TO LIST
                    </a>
                    {% if contract.status != 'CANCELLED' and contract.status != 'EXPIRED' %}
                        <form action="{{ path('admin_collab_contract_expire', {'id': contract.id}) }}" method="POST" class="inline">
                            <button type="submit" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-yellow-500 border-0 rounded-lg cursor-pointer shadow-soft-md leading-pro text-xs ease-soft-in hover:bg-yellow-600 active:opacity-85 tracking-tight-soft">
                                MARK EXPIRED
                            </button>
                        </form>
                        <form action="{{ path('admin_collab_contract_cancel', {'id': contract.id}) }}" method="POST" class="inline">
                            <button type="submit" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-red-500 border-0 rounded-lg cursor-pointer shadow-soft-md leading-pro text-xs ease-soft-in hover:bg-red-600 active:opacity-85 tracking-tight-soft">
                                CANCEL CONTRACT
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="w-full lg:w-4/12 px-3">
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border p-6">
                <h6 class="font-bold text-slate-700 mb-4">Agreement Context</h6>
                <div class="flex items-center mb-4">
                    <div class="w-10 h-10 rounded-lg bg-purple-50 flex items-center justify-center mr-3">
                        <i class="ni ni-calendar-grid-58 text-purple-500"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase mb-0">CREATED AT</p>
                        <p class="text-sm font-bold text-slate-700 mb-0">{{ contract.createdAt|date('d/m/Y H:i') }}</p>
                    </div>
                </div>
                <div class="flex items-center mb-4">
                    <div class="w-10 h-10 rounded-lg bg-pink-50 flex items-center justify-center mr-3">
                        <i class="ni ni-badge text-pink-500"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase mb-0">CONTRACTOR</p>
                        <p class="text-sm font-bold text-slate-700 mb-0">{{ contract.collaborator.companyName }}</p>
                    </div>
                </div>
                {% if contract.collabRequest %}
                    <div class="flex items-center mb-0">
                        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mr-3">
                            <i class="ni ni-chat-round text-blue-500"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase mb-0">ORIGINATING REQUEST</p>
                            <a href="{{ path('admin_collab_request_show', {'id': contract.collabRequest.id}) }}" class="text-sm font-bold text-blue-500 hover:underline mb-0">View Request</a>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
