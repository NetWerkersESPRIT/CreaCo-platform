{% extends 'base.html.twig' %}

{% block title %}Request Details - Admin{% endblock %}

{% block breadcrumbs %}
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        Collaboration
    </li>
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        <a href="{{ path('admin_collab_requests') }}" class="opacity-50">Requests</a>
    </li>
    <li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
        Review
    </li>
{% endblock %}

{% block page_title %}Proposal Review{% endblock %}

{% block body %}
<div class="w-full px-6 py-6 mx-auto">
    <div class="flex flex-wrap -mx-3">
        <!-- Main Content -->
        <div class="w-full lg:w-8/12 px-3">
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border">
                <div class="p-6 pb-0 mb-0 bg-white rounded-t-2xl">
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-bold text-slate-700 mb-0">{{ request.title }}</h3>
                            <p class="text-xs text-slate-400">Created on {{ request.createdAt|date('d/m/Y at H:i') }}</p>
                        </div>
                        {% if request.status == 'APPROVED' %}
                            <span class="bg-gradient-to-tl from-green-600 to-lime-400 px-3 text-xs rounded-1.8 py-1.5 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white shadow-soft-md">Approved</span>
                        {% elseif request.status == 'PENDING' %}
                            <span class="bg-gradient-to-tl from-purple-700 to-pink-500 px-3 text-xs rounded-1.8 py-1.5 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white shadow-soft-md">Pending</span>
                        {% else %}
                            <span class="bg-gradient-to-tl from-red-600 to-pink-500 px-3 text-xs rounded-1.8 py-1.5 inline-block whitespace-nowrap text-center align-baseline font-bold uppercase leading-none text-white shadow-soft-md">{{ request.status }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="flex-auto p-6">
                    <div class="flex flex-wrap -mx-3 mb-6">
                        <div class="w-full md:w-1/2 px-3 mb-4">
                            <div class="bg-gray-50 rounded-xl p-4">
                                <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">PLANNED BUDGET</p>
                                <h4 class="font-bold text-slate-700 mb-0">{{ request.budget|number_format(0, '.', ' ') }} DT</h4>
                            </div>
                        </div>
                        <div class="w-full md:w-1/2 px-3 mb-4">
                            <div class="bg-gray-50 rounded-xl p-4">
                                <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">PERIOD</p>
                                <h4 class="font-bold text-slate-700 mb-0">
                                    {{ request.startDate|date('d/m/y') }} to {{ request.endDate|date('d/m/y') }}
                                </h4>
                            </div>
                        </div>
                    </div>

                    <div class="mb-6">
                        <h6 class="text-[10px] font-bold text-slate-400 uppercase mb-3">DESCRIPTION</h6>
                        <div class="bg-white border border-gray-100 rounded-xl p-4 text-sm text-slate-600 leading-relaxed">
                            {{ request.description|nl2br }}
                        </div>
                    </div>

                    <div class="mb-6">
                        <h6 class="text-[10px] font-bold text-slate-400 uppercase mb-3">EXPECTED DELIVERABLES</h6>
                        <div class="bg-white border border-gray-100 rounded-xl p-4 text-sm text-slate-600 leading-relaxed">
                            {{ request.deliverables|nl2br }}
                        </div>
                    </div>

                    <div class="mt-8">
                        <a href="{{ path('admin_collab_requests') }}" class="inline-block px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-slate-400 border-0 rounded-lg cursor-pointer shadow-soft-md leading-pro text-xs ease-soft-in hover:bg-slate-500 active:opacity-85 tracking-tight-soft">
                            BACK TO LIST
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="w-full lg:w-4/12 px-3">
            <!-- Partner Card -->
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border p-4">
                <p class="text-[10px] font-bold text-slate-400 uppercase mb-3">Associated partner</p>
                <div class="flex items-center">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-tl from-purple-700 to-pink-500 flex items-center justify-center mr-4 shadow-soft-md">
                        <i class="ni ni-building text-white"></i>
                    </div>
                    <div>
                        <h6 class="font-bold text-slate-700 mb-0">{{ request.collaborator.companyName }}</h6>
                        <p class="text-xs text-slate-400 mb-0">Partner entity</p>
                    </div>
                </div>
            </div>

            <!-- Revisor Card -->
            <div class="relative flex flex-col min-w-0 mb-6 break-words bg-white border-0 shadow-soft-xl rounded-2xl bg-clip-border p-4">
                <p class="text-[10px] font-bold text-slate-400 uppercase mb-3">Assigned revisor</p>
                <div class="flex items-center">
                    <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center mr-4">
                        <i class="fas fa-user text-slate-400"></i>
                    </div>
                    <div>
                        <h6 class="font-bold text-slate-700 mb-0">{{ request.revisor ? request.revisor.username : 'Not assigned' }}</h6>
                        <p class="text-xs text-slate-400 mb-0">Case manager</p>
                    </div>
                </div>
            </div>

            <!-- Contract Box -->
            {% if contract %}
                <div class="relative flex flex-col min-w-0 mb-6 break-words bg-green-50 border border-green-100 shadow-soft-xl rounded-2xl bg-clip-border p-6">
                    <h6 class="font-bold text-green-700 mb-2">Contract available</h6>
                    <p class="text-xs text-green-600 mb-4">
                        The request has been validated and the contract is ready.
                    </p>
                    <a href="{{ path('admin_collab_contract_show', {'id': contract.id}) }}" class="block w-full px-6 py-3 font-bold text-center text-white uppercase align-middle transition-all bg-gradient-to-tl from-purple-700 to-pink-500 border-0 rounded-lg cursor-pointer shadow-soft-md leading-pro text-xs ease-soft-in hover:shadow-soft-2xl active:opacity-85 tracking-tight-soft">
                        CONSULT CONTRACT
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
