{% extends './base.html.twig' %}

{% block title %}All Courses
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		@keyframes float-character {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(-6px); }
		}
		.gamification-character {
			animation: float-character 3s ease-in-out infinite;
		}
		.gamification-character-wrap {
			width: 10rem;
			height: 10rem;
			min-width: 10rem;
			min-height: 10rem;
		}
		.gamification-mascot {
			width: 6rem;
			height: 6rem;
			filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15));
		}
		.gamification-mascot .eye {
			transition: transform 0.08s ease-out;
			transform-origin: center center;
		}
		.gamification-mascot.blink .eye {
			transform: scaleY(0.08);
		}
		@keyframes sparkle {
			0%, 100% { opacity: 1; transform: scale(1) rotate(0deg); }
			50% { opacity: 0.85; transform: scale(1.15) rotate(5deg); }
		}
		.gamification-mascot .sparkle {
			animation: sparkle 1.5s ease-in-out infinite;
		}
		.gamification-mascot .sparkle-2 { animation-delay: 0.5s; }
		.gamification-mascot .sparkle-3 { animation-delay: 1s; }
		@keyframes wiggle {
			0%, 100% { transform: rotate(-3deg); }
			50% { transform: rotate(3deg); }
		}
		.gamification-mascot .trophy-hat {
			transform-origin: 32px 18px;
			animation: wiggle 2s ease-in-out infinite;
		}
		@keyframes blush-pulse {
			0%, 100% { opacity: 0.9; }
			50% { opacity: 0.6; }
		}
		.gamification-mascot .cheek {
			animation: blush-pulse 2.5s ease-in-out infinite;
		}
	</style>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		window.addEventListener('DOMContentLoaded', function () {
			const form = document.getElementById('search-form');
			if (form) {
				['niveau', 'statut'].forEach(function (name) {
					const select = document.querySelector('select[form="search-form"][name="' + name + '"]');
					if (select) {
						select.addEventListener('change', function () {
							form.submit();
						});
					}
				});
			}
			var mascot = document.querySelector('.gamification-mascot');
			if (mascot) {
				function blink() {
					mascot.classList.add('blink');
					setTimeout(function() { mascot.classList.remove('blink'); }, 120);
				}
				setInterval(blink, 2500);
				setTimeout(blink, 800);
			}
		});
	</script>
{% endblock %}

{% block breadcrumbs %}
	<li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
		Courses
	</li>
{% endblock %}

{% block page_title %}Courses Management
{% endblock %}

