										<th class="px-6 py-2 bg-transparent border-b border-gray-200"></th>
										<th class="px-6 py-2 bg-transparent border-b border-gray-200"></th>
										<th class="px-6 py-2 bg-transparent border-b border-gray-200"></th>
								</tr>
							</thead>
							<tbody>
								{% for cour in cours %}
									<tr>
										<td class="p-2 align-middle bg-transparent border-b shadow-transparent" style="max-width: 250px;">
											<div class="flex px-2 py-1">
												<div>
													{% if cour.image %}
														<img src="{{ cour.image }}" class="inline-flex items-center justify-center mr-4 text-sm text-white transition-all duration-200 ease-soft-in-out h-9 w-9 rounded-xl" alt="{{ cour.titre }}"/>
													{% else %}
														<div class="inline-flex items-center justify-center mr-4 text-sm text-white transition-all duration-200 ease-soft-in-out h-9 w-9 rounded-xl bg-slate-200 opacity-60">
															<i class="fas fa-book text-slate-400"></i>
														</div>
													{% endif %}
												</div>
												<div class="flex flex-col justify-center">
													<h6 class="mb-0 text-sm leading-normal break-words">{{ cour.titre }}</h6>
												</div>
											</div>
										</td>
										<td class="p-2 align-middle bg-transparent border-b shadow-transparent" style="max-width: 150px;">
											<p class="mb-0 text-xs font-semibold leading-tight text-blue-500 break-words">{{ cour.categorie ? cour.categorie.nom : 'None' }}</p>
										</td>
												<td class="p-2 align-middle bg-transparent border-b shadow-transparent" style="max-width: 140px;">
													{% if cour.niveau %}
														{% set levelLabel = cour.niveau == 'beginner' ? 'Beginner' : (cour.niveau == 'intermediate' ? 'Intermediate' : 'Advanced') %}
														{% set levelColor = cour.niveau == 'beginner' ? 'bg-emerald-500' : (cour.niveau == 'intermediate' ? 'bg-yellow-500' : 'bg-red-500') %}
														<span class="px-2 py-1 text-xxs font-bold text-white rounded-full {{ levelColor }}">{{ levelLabel }}</span>
													{% else %}
														<span class="text-xs text-slate-400">—</span>
													{% endif %}
												</td>
												<td class="p-2 align-middle bg-transparent border-b shadow-transparent" style="max-width: 140px;">
													{% set statusValue = cour.statut ?? 'draft' %}
													{% set statusLabel = statusValue == 'published' ? 'Published' : (statusValue == 'archived' ? 'Archived' : 'Draft') %}
													{% set statusColor = statusValue == 'published' ? 'bg-emerald-500' : (statusValue == 'archived' ? 'bg-slate-500' : 'bg-gray-400') %}
													<span class="px-2 py-1 text-xxs font-bold text-white rounded-full {{ statusColor }}">{{ statusLabel }}</span>
												</td>
										<td class="p-2 align-middle bg-transparent border-b shadow-transparent" style="max-width: 300px;">
											<p class="mb-0 text-xs font-semibold break-words" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">{{ cour.description }}</p>
										</td>
										<td class="p-2 align-middle bg-transparent border-b shadow-transparent">
											<div class="flex items-center gap-2">
												<span class="text-xs font-bold leading-tight text-slate-700">{{ cour.views ?? 0 }}</span>
												<i class="fas fa-eye text-xxs text-slate-400"></i>
											</div>
										</td>
												<td class="p-2 align-middle bg-transparent border-b shadow-transparent">
													{% if cour.dureeEstimee %}
													{% set hours = (cour.dureeEstimee / 60)|round(0, 'floor') %}
													{% set minutes = cour.dureeEstimee - (hours * 60) %}
														<span class="text-xs font-semibold leading-tight text-slate-700">
															{% if hours > 0 %}
																{{ hours }}h{% if minutes > 0 %} {{ minutes }}m{% endif %}
															{% else %}
																{{ minutes }}m
															{% endif %}
														</span>
													{% else %}
														<span class="text-xs text-slate-400">—</span>
													{% endif %}
												</td>
										<td class="p-2 align-middle bg-transparent border-b whitespace-nowrap shadow-transparent">
											<span class="text-xs font-semibold leading-tight text-slate-400">{{ cour.dateDeCreation ? cour.dateDeCreation|date('d/m/Y H:i') : '-' }}</span>
										</td>
										<td class="p-2 text-center align-middle bg-transparent border-b shadow-transparent">
											<div class="flex flex-col items-center gap-2">
												<a href="{{ path('app_cours_resources', {'id': cour.id}) }}" class="text-xs font-semibold leading-tight text-slate-400 bg-gray-100 px-3 py-1 rounded-lg w-full text-center">
													<i class="ni ni-zoom-split-in mr-1"></i>
													Resources
												</a>
												<a href="{{ path('app_cours_edit', {'id': cour.id}) }}" class="text-xs font-semibold leading-tight text-slate-400 bg-gray-100 px-3 py-1 rounded-lg w-full text-center">
													<i class="ni ni-settings mr-1 text-xs"></i>
													Edit
												</a>
												<form method="post" action="{{ path('app_cours_delete', {'id': cour.id}) }}" onsubmit="return confirm('Are you sure?');" class="w-full" novalidate>
													<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cour.id) }}">
													<button class="text-xs font-semibold leading-tight text-red-500 bg-gray-100 px-3 py-1 rounded-lg border-0 cursor-pointer w-full">
														<i class="ni ni-fat-delete mr-1"></i>
														Delete
													</button>
												</form>
											</div>
										</td>
									</tr>
								{% else %}
									<tr>
												<td colspan="9" class="p-4 text-center">No courses found</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
					<div class="px-6 py-4 border-t border-gray-200">
						{{ knp_pagination_render(cours) }}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
