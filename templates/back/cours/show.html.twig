{% extends './base.html.twig' %}

{% block title %}Cours
{% endblock %}

{% block body %}
	<h1>Cours</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ cour.id }}</td>
			</tr>
			<tr>
				<th>Title</th>
				<td>{{ cour.titre }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ cour.description }}</td>
			</tr>
			<tr>
				<th>Image</th>
				<td>{{ cour.image }}</td>
			</tr>
			<tr>
				<th>Category</th>
				<td>{{ cour.categorie ? cour.categorie.nom : '' }}</td>
			</tr>
				<tr>
					<th>Status</th>
					<td>
						{% set statusValue = cour.statut ?? 'draft' %}
						{% if statusValue == 'published' %}
							Published
						{% elseif statusValue == 'archived' %}
							Archived
						{% else %}
							Draft
						{% endif %}
					</td>
				</tr>
				<tr>
					<th>Level</th>
					<td>
						{% if cour.niveau == 'beginner' %}
							Beginner
						{% elseif cour.niveau == 'intermediate' %}
							Intermediate
						{% elseif cour.niveau == 'advanced' %}
							Advanced
						{% else %}
							-
						{% endif %}
					</td>
				</tr>
				<tr>
					<th>Estimated duration</th>
					<td>
						{% if cour.dureeEstimee %}
								{% set hours = (cour.dureeEstimee / 60)|round(0, 'floor') %}
								{% set minutes = cour.dureeEstimee - (hours * 60) %}
							{% if hours > 0 %}
								{{ hours }}h{% if minutes > 0 %} {{ minutes }}m{% endif %}
							{% else %}
								{{ minutes }}m
							{% endif %}
						{% else %}
							-
						{% endif %}
					</td>
				</tr>
			<tr>
				<th>Created at</th>
				<td>{{ cour.dateDeCreation ? cour.dateDeCreation|date('d/m/Y H:i') : '-' }}</td>
			</tr>
			<tr>
				<th>Last modified</th>
				<td>{{ cour.dateDeModification ? cour.dateDeModification|date('d/m/Y H:i') : '-' }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_cours_index') }}">back to list</a>

	<a href="{{ path('app_cours_edit', {'id': cour.id}) }}">edit</a>

	{{ include('back/cours/_delete_form.html.twig') }}
{% endblock %}
