{% extends 'base.html.twig' %}

{% block title %}CreaCo - Workshops
{% endblock %}
{% block page_title %}Workshops
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		@keyframes float-character {
			0%, 100% {
				transform: translateY(0);
			}
			50% {
				transform: translateY(-6px);
			}
		}

		.gamification-character {
			animation: float-character 3s ease-in-out infinite;
		}

		.gamification-character.delay-1 {
			animation-delay: 0.3s;
		}

		.gamification-character.delay-2 {
			animation-delay: 0.6s;
		}

		.gamification-character-wrap {
			width: 10rem;
			height: 10rem;
			min-width: 10rem;
			min-height: 10rem;
		}
		.gamification-mascot {
			width: 6rem;
			height: 6rem;
			filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15));
		}
		.gamification-mascot .eye {
			transition: transform 0.08s ease-out;
			transform-origin: center center;
		}
		.gamification-mascot.blink .eye {
			transform: scaleY(0.08);
		}
		@keyframes sparkle {
			0%, 100% { opacity: 1; transform: scale(1) rotate(0deg); }
			50% { opacity: 0.85; transform: scale(1.15) rotate(5deg); }
		}
		.gamification-mascot .sparkle {
			animation: sparkle 1.5s ease-in-out infinite;
		}
		.gamification-mascot .sparkle-2 { animation-delay: 0.5s; }
		.gamification-mascot .sparkle-3 { animation-delay: 1s; }
		@keyframes wiggle {
			0%, 100% { transform: rotate(-3deg); }
			50% { transform: rotate(3deg); }
		}
		.gamification-mascot .trophy-hat {
			transform-origin: 32px 18px;
			animation: wiggle 2s ease-in-out infinite;
		}
		@keyframes blush-pulse {
			0%, 100% { opacity: 0.9; }
			50% { opacity: 0.6; }
		}
		.gamification-mascot .cheek {
			animation: blush-pulse 2.5s ease-in-out infinite;
		}
	</style>
{% endblock %}

	{% block body %}
		<div
			class="w-full px-6 py-6 mx-auto">
			<!-- Gamification / Leaderboard Highlight -->
			<div class="flex flex-wrap -mx-3 mb-6">
				<div class="w-full max-w-full px-3">
					<a href="{{ path('app_leaderboard') }}" class="block">
						<div class="relative flex flex-wrap items-center min-w-0 break-words bg-gradient-to-r from-purple-700 via-fuchsia-500 to-pink-500 shadow-soft-xl rounded-2xl bg-clip-border text-white overflow-hidden hover:shadow-soft-2xl hover:scale-102 transition-all duration-300">
							<div class="w-full lg:w-2/3 p-6">
								<p class="text-xs font-semibold uppercase opacity-80 mb-1">Gamification</p>
								<h5 class="mb-2 font-bold text-lg">Climb the XP leaderboard</h5>
								<p class="text-sm opacity-90 mb-4">Earn XP by opening resources and completing courses, unlock badges and see how you rank among other learners.</p>
								<span class="inline-flex items-center px-4 py-2 text-xs font-bold uppercase bg-white/20 rounded-lg backdrop-blur-sm">
									<i class="fas fa-trophy mr-2"></i>
									Go to leaderboard
								</span>
							</div>
							<div class="gamification-characters flex w-full lg:w-1/3 justify-center items-center pr-6 mt-4 lg:mt-0">
								<div class="gamification-character gamification-character-wrap rounded-full flex items-center justify-center shadow-soft-2xl border-4 border-white/80 bg-gradient-to-br from-amber-200/90 via-orange-300/80 to-fuchsia-300/90 backdrop-blur-sm">
									<svg class="gamification-mascot" viewBox="0 0 64 64" aria-hidden="true">
										<!-- sparkles -->
										<circle class="sparkle sparkle-2" cx="8" cy="16" r="3" fill="#FDE047" />
										<circle class="sparkle sparkle-3" cx="56" cy="20" r="2.5" fill="#F472B6" />
										<circle class="sparkle" cx="12" cy="52" r="2" fill="#A78BFA" />
										<circle class="sparkle sparkle-2" cx="52" cy="48" r="2.5" fill="#34D399" />
										<!-- trophy crown hat -->
										<g class="trophy-hat">
											<path d="M 20 20 L 24 12 L 32 8 L 40 12 L 44 20 L 42 20 L 42 24 L 22 24 L 22 20 Z" fill="url(#gold)" stroke="#B45309" stroke-width="0.8" />
											<circle cx="32" cy="10" r="3" fill="#FDE047" />
										</g>
										<defs>
											<linearGradient id="gold" x1="0%" y1="0%" x2="0%" y2="100%">
												<stop offset="0%" style="stop-color:#FDE047" />
												<stop offset="50%" style="stop-color:#F59E0B" />
												<stop offset="100%" style="stop-color:#D97706" />
											</linearGradient>
											<linearGradient id="body" x1="0%" y1="0%" x2="100%" y2="100%">
												<stop offset="0%" style="stop-color:#FBBF24" />
												<stop offset="40%" style="stop-color:#F97316" />
												<stop offset="100%" style="stop-color:#EC4899" />
											</linearGradient>
											<linearGradient id="cheekGrad" x1="0%" y1="0%" x2="100%" y2="0%">
												<stop offset="0%" style="stop-color:#F472B6;stop-opacity:0.9" />
												<stop offset="100%" style="stop-color:#EC4899;stop-opacity:0.7" />
											</linearGradient>
										</defs>
										<!-- body/head -->
										<circle cx="32" cy="36" r="20" fill="url(#body)" stroke="#EA580C" stroke-width="1.2" />
										<!-- rosy cheeks -->
										<ellipse class="cheek" cx="18" cy="38" rx="5" ry="3" fill="url(#cheekGrad)" />
										<ellipse class="cheek" cx="46" cy="38" rx="5" ry="3" fill="url(#cheekGrad)" />
										<!-- eyes -->
										<ellipse class="eye" cx="24" cy="32" rx="4.5" ry="5.5" fill="white" />
										<ellipse class="eye" cx="40" cy="32" rx="4.5" ry="5.5" fill="white" />
										<circle class="eye" cx="24" cy="33" r="2.5" fill="#1E1B4B" />
										<circle class="eye" cx="40" cy="33" r="2.5" fill="#1E1B4B" />
										<circle cx="25" cy="31.5" r="0.8" fill="white" />
										<circle cx="41" cy="31.5" r="0.8" fill="white" />
										<!-- big smile -->
										<path d="M 22 42 Q 32 52 42 42" stroke="#C2410C" stroke-width="2.2" fill="none" stroke-linecap="round" />
										<path d="M 26 44 Q 32 48 38 44" stroke="#9A3412" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.8" />
									</svg>
								</div>
							</div>
						</div>
					</a>
				</div>
			</div>

			<!-- Header & Search -->
			<div class="flex flex-wrap -mx-3 mb-6">
				<div class="w-full max-w-full px-3">
					<div class="relative flex flex-col min-w-0 break-words bg-white shadow-soft-xl rounded-2xl bg-clip-border">
						<div class="p-6 pb-0 mb-0 bg-white border-b-0 rounded-t-2xl">
							<h6 class="mb-1">Discover our workshops</h6>
							<p class="text-sm leading-normal text-slate-500">Choose a category to explore available courses and resources.</p>
						</div>
						<div class="flex-auto p-6">
							<form method="get" class="relative flex flex-wrap items-stretch w-full transition-all rounded-lg ease-soft">
								<span class="text-sm ease-soft leading-5.6 absolute z-50 -ml-px flex h-full items-center whitespace-nowrap rounded-lg rounded-tr-none rounded-br-none border border-r-0 border-transparent bg-transparent py-2 px-2.5 text-center font-normal text-slate-500 transition-all">
									<i class="fas fa-search" aria-hidden="true"></i>
								</span>
								<input type="text" name="search" value="{{ search ?? '' }}" class="pl-8.75 text-sm focus:shadow-soft-primary-outline ease-soft w-1/100 leading-5.6 relative -ml-px block min-w-0 flex-auto rounded-lg border border-solid border-gray-300 bg-white bg-clip-padding py-2 pr-3 text-gray-700 transition-all placeholder:text-gray-500 focus:border-fuchsia-300 focus:outline-none focus:transition-shadow" placeholder="Rechercher une catégorie..."/>
							</form>
						</div>
					</div>
				</div>
			</div>

			<!-- Categories Grid -->
		<div class="flex flex-wrap -mx-3">
			{% for category in categories %}
				<div class="w-full max-w-full px-3 mb-6 sm:w-1/2 lg:w-1/3">
					<a href="{{ path('app_front_category', {'id': category.id}) }}" class="block h-full">
						<div class="relative flex flex-col min-w-0 break-words bg-white shadow-soft-xl rounded-2xl bg-clip-border h-full hover:shadow-soft-2xl hover:scale-102 transition-all duration-300">
							<div class="flex-auto p-6">
								<div class="flex items-center mb-4">
									<div class="inline-flex items-center justify-center w-12 h-12 mr-4 text-white transition-all duration-200 text-base ease-soft-in-out rounded-xl bg-gradient-to-tl from-purple-700 to-pink-500 shadow-soft-2xl">
										<i class="ni ni-app"></i>
									</div>
									<h5 class="mb-0 font-bold text-slate-700">{{ category.nom }}</h5>
								</div>
								<p class="mb-4 leading-normal text-sm text-slate-500">{{ category.description|length > 100 ? category.description|slice(0, 100) ~ '...' : category.description }}</p>
								<div class="flex items-center justify-between mt-auto">
									<span class="text-xs font-semibold uppercase text-slate-400">Explore courses</span>
									<i class="fas fa-arrow-right text-xs text-slate-400"></i>
								</div>
							</div>
						</div>
					</a>
				</div>
			{% else %}
				<div class="w-full max-w-full px-3">
					<div class="text-center p-12 bg-white shadow-soft-xl rounded-2xl">
						<i class="ni ni-box-2 text-4xl text-slate-300 mb-4"></i>
						<p class="text-lg font-semibold text-slate-500">No categories available at the moment.</p>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			var mascot = document.querySelector('.gamification-mascot');
			if (!mascot) return;
			function blink() {
				mascot.classList.add('blink');
				setTimeout(function() {
					mascot.classList.remove('blink');
				}, 120);
			}
			setInterval(blink, 2500);
			setTimeout(blink, 800);
		});
	</script>
{% endblock %}
