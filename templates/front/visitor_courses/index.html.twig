<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8"/>
		<meta http-equiv="X-UA-Compatible" content="IE=edge"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<link rel="apple-touch-icon" sizes="76x76" href="{{ asset('assets/img/apple-icon.png') }}"/>
		<link rel="icon" type="image/png" href="{{ asset('assets/img/logocrea.png') }}"/>
		<title>CreaCo | Explore Our Courses</title>
		
		<!-- Fonts and icons -->
		<link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet"/>
		<!-- Font Awesome Icons -->
		<script src="https://kit.fontawesome.com/42d5adcbca.js" crossorigin="anonymous"></script>
		<!-- Nucleo Icons -->
		<link href="{{ asset('assets/css/nucleo-icons.css') }}" rel="stylesheet"/>
		<link href="{{ asset('assets/css/nucleo-svg.css') }}" rel="stylesheet"/>
		<!-- Main Styling -->
		<link href="{{ asset('assets/css/soft-ui-dashboard-tailwind.css?v=1.0.5') }}" rel="stylesheet"/>
		
		<style>
			.glass-card {
				background: rgba(255, 255, 255, 0.7);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.3);
			}
			.animate-float {
				animation: float 6s ease-in-out infinite;
			}
			@keyframes float {
				0% { transform: translateY(0px); }
				50% { transform: translateY(-10px); }
				100% { transform: translateY(0px); }
			}
		</style>

		{% if app.environment == 'dev' %}
		<style>
			/* Force Symfony Debug Bar Visibility */
			.sf-toolbar { display: block !important; visibility: visible !important; z-index: 999999 !important; }
			.sf-display-none { display: block !important; }
		</style>
		{% endif %}
	</head>

	<body class="m-0 font-sans antialiased font-normal bg-gray-50 text-start text-base leading-default text-slate-500 overflow-x-hidden">
		
		<!-- Minimal Visitor Navbar -->
		<nav class="w-11/12 lg:w-1/2 z-30 flex justify-center items-center px-4 py-2 mx-auto my-4 shadow-soft-2xl rounded-blur bg-white/80 backdrop-blur-2xl backdrop-saturate-200 sticky top-4">
			<div class="flex items-center justify-between w-full p-0 pl-6 mx-auto flex-wrap-inherit">
				<a class="flex items-center" href="{{ path('app_visitor') }}">
					<img src="{{ asset('assets/img/logocreaco.svg') }}" alt="Logo" class="w-12 h-10 mr-2">
					<span class="text-sm whitespace-nowrap font-bold text-slate-700">CreaCo</span>
				</a>
				
				<div navbar-menu class="items-center justify-end flex-grow overflow-hidden transition-all duration-500 ease-soft lg-max:max-h-0 basis-full lg:flex lg:basis-auto">
					<a href="{{ path('app_auth') }}" class="leading-pro text-xs ease-soft-in inline-block cursor-pointer border-0 bg-gradient-to-tl from-gray-900 to-slate-800 px-8 py-2 text-center align-middle font-bold uppercase tracking-tight-soft text-white transition-all shadow-soft-md hover:scale-102 active:opacity-85 rounded-xl">
						Sign In
					</a>
				</div>
			</div>
		</nav>

		<main class="mt-12 transition-all duration-200 ease-soft-in-out pb-20">
			
			<div class="container mx-auto px-6">
				<div class="text-center mb-16">
					<h6 class="font-bold text-fuchsia-500 uppercase text-sm mb-2 tracking-widest">Level Up Your Skills</h6>
					<h2 class="text-4xl font-black text-slate-800 leading-tight mb-4">
						Explore Our <span class="text-transparent bg-clip-text bg-gradient-to-tl from-blue-600 to-cyan-400">Published Courses</span>
					</h2>
					<p class="text-slate-500 max-w-2xl mx-auto">
						Start your creative journey today. Access our premium courses and join a community of creators.
					</p>
				</div>

				<!-- Courses Grid -->
				<div class="flex flex-wrap -mx-3">
					{% for course in courses %}
						<div class="w-full max-w-full px-3 mb-8 sm:w-1/2 lg:w-1/3">
							<a href="{{ path('app_front_course', {'id': course.id}) }}" class="relative flex flex-col min-w-0 break-words bg-white shadow-soft-xl rounded-2xl bg-clip-border h-full hover:shadow-soft-2xl hover:scale-102 transition-all duration-300 group overflow-hidden">
								
								<!-- Image Container -->
								<div class="relative h-48 overflow-hidden">
									{% if course.image %}
										<img src="{{ course.image }}" alt="{{ course.titre }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
									{% else %}
										<div class="w-full h-full flex items-center justify-center bg-gradient-to-tl from-gray-900 to-slate-800 text-white">
											<i class="fas fa-graduation-cap text-4xl"></i>
										</div>
									{% endif %}
									
									<!-- Category Badge -->
									<div class="absolute top-0 left-0 m-4">
										<span class="bg-white/80 backdrop-blur-md text-slate-700 text-xxs font-bold px-3 py-1 rounded-lg shadow-soft-xl uppercase">
											{{ course.categorie ? course.categorie.nom : 'General' }}
										</span>
									</div>

                                    <!-- Views Badge -->
                                    <div class="absolute bottom-0 right-0 m-4">
                                        <span class="bg-gray-900/60 backdrop-blur-sm text-white text-xxs font-bold px-3 py-1 rounded-lg">
                                            <i class="fas fa-eye mr-1"></i> {{ course.views ?? 0 }}
                                        </span>
                                    </div>
								</div>

								<div class="flex-auto p-6 flex flex-col">
									<h5 class="mb-2 font-bold text-slate-700">{{ course.titre }}</h5>
									<p class="mb-6 text-sm text-slate-500 leading-relaxed line-clamp-3">
										{{ course.description }}
									</p>
									
									<div class="mt-auto flex items-center justify-between">
										<div class="flex items-center text-slate-400 text-xs">
											<i class="fas fa-signal mr-1 text-fuchsia-500"></i>
											<span class="capitalize">{{ course.niveau ?? 'Beginner' }}</span>
										</div>
                                        
                                        <span class="inline-block px-4 py-2 font-bold text-center text-white uppercase align-middle transition-all bg-gradient-to-tl from-purple-700 to-pink-500 rounded-lg shadow-soft-md group-hover:scale-105 active:opacity-85 text-xs tracking-tight-soft">
											Enroll Now
										</span>
									</div>
								</div>
							</a>
						</div>
					{% else %}
						<div class="w-full px-3 text-center py-20">
							<div class="inline-flex items-center justify-center w-20 h-20 mb-6 rounded-3xl bg-white shadow-soft-xl text-slate-300 text-3xl">
								<i class="ni ni-folder-17"></i>
							</div>
							<h4 class="text-slate-800 font-bold mb-2">No courses available yet</h4>
							<p class="text-slate-500">Check back soon for new content!</p>
						</div>
					{% endfor %}
				</div>
			</div>

		</main>

		<footer class="py-12 bg-white">
			<div class="container mx-auto px-6 text-center">
				<div class="flex items-center justify-center mb-6">
					<img src="{{ asset('assets/img/logocreaco.svg') }}" alt="Logo" class="w-10 h-8 mr-3">
					<span class="text-xl font-bold text-slate-800 tracking-tight">CreaCo</span>
				</div>
				<p class="text-sm text-slate-400">
					&copy; <script>document.write(new Date().getFullYear());</script> NetWorkers. Distributed with ❤️.
				</p>
			</div>
		</footer>

		<!-- Scripts -->
		<script src="{{ asset('assets/js/plugins/perfect-scrollbar.min.js') }}"></script>
		<script src="{{ asset('assets/js/soft-ui-dashboard-tailwind.js?v=1.0.5') }}"></script>
	</body>
</html>
