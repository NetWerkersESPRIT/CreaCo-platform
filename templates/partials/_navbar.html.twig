<!-- Navbar -->
<nav class="topbar relative flex flex-wrap items-center justify-between px-0 py-2 mx-6 transition-all shadow-none duration-250 ease-soft-in rounded-2xl lg:flex-nowrap lg:justify-start" navbar-main navbar-scroll="true">
	<div class="flex items-center justify-between w-full px-4 py-1 mx-auto flex-wrap-inherit">
		<nav>
			{% set breadcrumb_mapping = {
				'app_home': 'Dashboard',
				'forum_index': 'Forum',
				'app_post_show': 'Forum',
				'app_post_new': 'Forum',
				'app_post_edit': 'Forum',
				'admin_post_pending': 'Pending Posts',
				'admin_post_pending_show': 'Pending Posts',
				'app_useradd': 'Users',
				'app_profile': 'Users',
				'google_signup_start': 'Users',
				'google_signup_check': 'Users',
				'app_auth': 'Login'
			} %}
			{% set current_route = app.request.attributes.get('_route') %}
			{% set module_name = breadcrumb_mapping[current_route] ?? 'Dashboard' %}

			<ol class="flex flex-wrap pt-1 mr-12 bg-transparent rounded-lg sm:mr-16">
				<li class="leading-normal text-sm">
					<a class="opacity-50 text-slate-700" href="javascript:;">Pages</a>
				</li>
				<li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
					{% block breadcrumb %}
						{{ module_name }}
					{% endblock %}
				</li>
			</ol>
			<h6 class="mb-0 font-bold capitalize text-gradient" style="font-size: 28px;">
				{% block page_title %}
					{{ module_name }}
				{% endblock %}
			</h6>
		</nav>

		<div
			class="flex items-center mt-2 grow sm:mt-0 md:mr-0 lg:flex lg:basis-auto justify-between gap-4">
			<!-- Spacing for right alignment -->
			<div class="flex items-center md:ml-auto md:pr-4">
				<!-- Virtual Coworking Quick Access -->
				<a href="{{ path('app_coworking_space') }}" class="mr-4 group relative inline-flex items-center justify-center px-6 py-2 overflow-hidden font-bold text-white transition-all duration-300 bg-gradient-to-br from-purple-600 to-pink-500 rounded-xl hover:shadow-lg hover:scale-105 active:scale-95">
					<span class="absolute inset-0 w-full h-full bg-gradient-to-br from-blue-400 to-purple-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
					<i class="ni ni-world-2 mr-2 relative z-10"></i>
					<span class="relative z-10 text-xs uppercase tracking-wider">Join Coworking Space</span>
					<div class="absolute -right-1 -top-1">
						<span class="flex h-3 w-3">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
						</span>
					</div>
				</a>
			</div>

			<!-- User Info & Actions (Right Side) -->

			<!-- Global Notification Bell -->
			<div
				class="relative flex items-center" id="notif-wrapper" style="margin-right:1.25rem;">

				{% set serverUnreadCount = get_unread_notif_count() %}
				<!-- Bell Button -->
				<button id="notifBtn" type="button" onclick="toggleNotifDropdown(event)" aria-expanded="false" class="{{ serverUnreadCount > 0 ? 'bell-animate' : '' }}" style="position:relative; background:#fff; margin-left:1rem; display:flex; width:3rem; height:3rem; align-items:center; justify-content:center; border-radius:0.9rem; border:none; cursor:pointer; box-shadow:0 4px 20px rgba(0,0,0,.12); transition:transform .2s, box-shadow .2s;" onmouseover="this.style.transform='scale(1.07)';this.style.boxShadow='0 8px 28px rgba(124,58,237,.25)'" onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,.12)'">

					<i class="fa fa-bell" style="font-size:1.15rem; background:linear-gradient(135deg,#7c3aed,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent;"></i>
					<!-- Unread Badge -->
					<span id="notif-badge" style="{{ serverUnreadCount > 0 ? 'display:inline-flex;' : 'display:none;' }} position:absolute; top:-5px; right:-5px; min-width:20px; height:20px; padding:0 5px; align-items:center; justify-content:center; font-size:0.65rem; font-weight:700; color:#fff; background:linear-gradient(135deg,#7c3aed,#ec4899); border-radius:999px; border:2px solid #fff; box-shadow:0 2px 8px rgba(124,58,237,.4); pointer-events:none;">{{ serverUnreadCount }}</span>
				</button>

				<!-- Dropdown Panel -->
				<div
					id="notifDropdown" style="display:none; opacity:0; transform:translateY(-8px) scale(0.97); transition:opacity .2s ease, transform .2s ease;
																														       position:absolute; right:0; top:calc(100% + 12px);
																														       width:420px; max-width:90vw; z-index:99999;
																														       background:#fff; border-radius:20px;
																														       border:1px solid rgba(124,58,237,.12);
																														       box-shadow:0 24px 64px rgba(0,0,0,.16), 0 4px 24px rgba(124,58,237,.08);
																														       overflow:hidden;">
					<!-- ── Header ── -->
					<div style="display:flex; align-items:center; justify-content:space-between; padding:16px 20px; background:linear-gradient(135deg,#7c3aed11,#ec489911); border-bottom:1px solid rgba(124,58,237,.1);">
						<div style="display:flex; align-items:center; gap:8px;">
							<div style="width:32px; height:32px; border-radius:10px; background:linear-gradient(135deg,#7c3aed,#ec4899); display:flex; align-items:center; justify-content:center;">
								<i class="fa fa-bell" style="color:#fff; font-size:0.9rem;"></i>
							</div>
							<span style="font-weight:700; font-size:1rem; color:#1e293b; letter-spacing:-.01em;">Notifications</span>
							<span id="notif-header-badge" style="{{ serverUnreadCount > 0 ? 'display:inline-flex;' : 'display:none;' }} align-items:center; justify-content:center; padding:2px 8px; font-size:0.68rem; font-weight:700; color:#fff; background:linear-gradient(135deg,#7c3aed,#ec4899); border-radius:999px;">{{ serverUnreadCount }}</span>
						</div>
						<a href="{{ path('app_notifications') }}" style="font-size:0.82rem; font-weight:600; background:linear-gradient(135deg,#7c3aed,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; text-decoration:none; white-space:nowrap;">
							View all →
						</a>
					</div>

					<!-- ── Notification List ── -->
					<div
						id="notif-list-container" style="overflow-y:auto; max-height:420px; padding:10px 12px; display:flex; flex-direction:column; gap:6px;">
						<!-- JS populates this -->
						<div id="notif-empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 0; color:#94a3b8;">
							<div style="width:52px; height:52px; border-radius:50%; background:#f1f5f9; display:flex; align-items:center; justify-content:center; margin-bottom:12px;">
								<i class="fa fa-bell-slash" style="font-size:1.3rem; opacity:0.4;"></i>
							</div>
							<p style="font-size:0.875rem; margin:0; font-weight:500;">No notifications yet</p>
						</div>
					</div>

					<!-- ── Footer ── -->
					<div style="padding:10px 20px; border-top:1px solid #f1f5f9; background:#fafafa; text-align:center;">
						<a href="{{ path('app_notifications_mark_all_seen') }}" onclick="event.preventDefault(); fetch(this.href, {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}}).then(() => { document.querySelectorAll('.notif-item').forEach(el => el.style.borderLeftColor='transparent'); document.getElementById('notif-badge').style.display='none'; document.getElementById('notif-header-badge').style.display='none'; });" style="font-size:0.75rem; font-weight:600; color:#94a3b8; text-decoration:none; transition:color .15s;" onmouseover="this.style.color='#7c3aed'" onmouseout="this.style.color='#94a3b8'">
							Mark all as read
						</a>
					</div>
				</div>

				<script>
					function openNotifDropdown() {
						var dropdown = document.getElementById('notifDropdown');
						var btn = document.getElementById('notifBtn');
						if (!dropdown || !btn) return;

						dropdown.style.display = 'block';
						requestAnimationFrame(function () {
							dropdown.style.opacity = '1';
							dropdown.style.transform = 'translateY(0) scale(1)';
						});
						btn.setAttribute('aria-expanded', 'true');
						loadNotifications();
					}

					function closeNotifDropdown() {
						var dropdown = document.getElementById('notifDropdown');
						var btn = document.getElementById('notifBtn');
						if (!dropdown || !btn) return;

						dropdown.style.opacity = '0';
						dropdown.style.transform = 'translateY(-8px) scale(0.97)';
						setTimeout(function () {
							dropdown.style.display = 'none';
						}, 200);
						btn.setAttribute('aria-expanded', 'false');
					}

					function toggleNotifDropdown(e) {
						if (e) e.stopPropagation();
						var btn = document.getElementById('notifBtn');
						var isOpen = btn && btn.getAttribute('aria-expanded') === 'true';
						if (isOpen) {
							closeNotifDropdown();
						} else {
							openNotifDropdown();
						}
					}

					// Global click to close
					document.addEventListener('click', function (e) {
						var wrapper = document.getElementById('notif-wrapper');
						if (wrapper && !wrapper.contains(e.target)) {
							closeNotifDropdown();
						}
					});






function timeAgo(dateStr) {
var diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
if (diff < 60) 
return diff + 's';



if (diff < 3600) 
return Math.floor(diff / 60) + 'm';



if (diff < 86400) 
return Math.floor(diff / 3600) + 'h';



return Math.floor(diff / 86400) + 'j';
}

function iconForType(type) {
var icons = {
'new_post': {
icon: 'fa-file-alt',
grad: 'linear-gradient(135deg,#f59e0b,#ef4444)'
},
'post_approved': {
icon: 'fa-check',
grad: 'linear-gradient(135deg,#22c55e,#14b8a6)'
},
'post_refused': {
icon: 'fa-times',
grad: 'linear-gradient(135deg,#ef4444,#f43f5e)'
},
'invitation': {
icon: 'fa-envelope-open-text',
grad: 'linear-gradient(135deg,#3b82f6,#06b6d4)'
}
};
return icons[type] || {
icon: 'fa-bell',
grad: 'linear-gradient(135deg,#7c3aed,#ec4899)'
};
}

function updateBadge(count) {
    var badge = document.getElementById('notif-badge');
    var headerBadge = document.getElementById('notif-header-badge');
    if (!badge || !headerBadge) return;

    if (count > 0) {
        badge.textContent = count;
        badge.style.display = 'inline-flex';
        headerBadge.textContent = count;
        headerBadge.style.display = 'inline-flex';
    } else {
        badge.style.display = 'none';
        headerBadge.style.display = 'none';
    }
}

function markAsRead(id, itemEl, redirectUrl) {
    var badge = document.getElementById('notif-badge');
    
    // Optimistic UI update
    if (itemEl) {
        itemEl.style.background = '#fff';
        itemEl.style.border = '1px solid #f1f5f9';
        itemEl.style.borderLeft = '3px solid transparent';
        var msg = itemEl.querySelector('p');
        if (msg) {
            msg.style.fontWeight = '400';
            msg.style.color = '#475569';
        }
        var dot = itemEl.querySelector('.notif-unread-dot');
        if (dot) dot.remove();
    }

    fetch('/notifications/api/' + id + '/read', {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    }).finally(function () {
        if (badge) {
            var currentCount = parseInt(badge.textContent) || 0;
            updateBadge(Math.max(0, currentCount - 1));
        }

        if (redirectUrl && redirectUrl !== '#' && redirectUrl !== '') {
            window.location.href = redirectUrl;
        }
    });
}

function loadNotifications() {
    var container = document.getElementById('notif-list-container');
    var emptyState = document.getElementById('notif-empty-state');
    if (!container || !emptyState) return;

    fetch('{{ path("app_api_notifications_latest") }}').then(function (r) {
        return r.ok ? r.json() : [];
    }).then(function (data) { 
        container.querySelectorAll('.notif-item').forEach(function (el) {
            el.remove();
        });

        if (!data || data.length === 0) {
            emptyState.style.display = 'flex';
            return;
        }
        emptyState.style.display = 'none';


        var unreadCount = 0;
        data.forEach(function (n) {
            var isUnread = !n.isRead;
            if (isUnread) unreadCount++;

            var ico = iconForType(n.type);
            var item = document.createElement('div');
            item.className = 'notif-item';
            item.setAttribute('data-id', n.id);
            item.setAttribute('data-url', n.targetUrl || '');
            item.setAttribute('data-unread', isUnread ? 'true' : 'false');
            
            item.style.cssText = [
                'display:flex',
                'align-items:flex-start',
                'gap:12px',
                'padding:12px 14px',
                'border-radius:14px',
                'cursor:pointer',
                'border:1px solid ' + (isUnread ? 'rgba(124,58,237,.2)' : '#f1f5f9'),
                'background:' + (isUnread ? 'linear-gradient(135deg,#fdf4ff,#fce7f3)' : '#fff'),
                'border-left:3px solid ' + (isUnread ? '#7c3aed' : 'transparent'),
                'transition:background .15s, border-color .15s'
            ].join(';');

            item.innerHTML = '<div style="flex-shrink:0;margin-top:2px;width:36px;height:36px;border-radius:10px;background:' + ico.grad + ';display:flex;align-items:center;justify-content:center;">' + 
                             '<i class="fa ' + ico.icon + '" style="color:#fff;font-size:0.85rem;"></i>' + 
                             '</div>' + 
                             '<div style="flex:1;min-width:0;">' + 
                             '<p style="margin:0 0 4px;font-size:0.84rem;font-weight:' + (isUnread ? '600' : '400') + ';color:' + (isUnread ? '#1e293b' : '#475569') + ';line-height:1.4;white-space:normal;">' + n.message + '</p>' + 
                             '<span style="font-size:0.72rem;color:#94a3b8;"><i class="fa fa-clock" style="margin-right:3px;"></i>' + timeAgo(n.createdAt) + '</span>' + 
                             '</div>' + 
                             (isUnread ? '<span class="notif-unread-dot" style="flex-shrink:0;margin-top:6px;width:8px;height:8px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#ec4899);"></span>' : '');

            item.addEventListener('click', function(e) {
                e.preventDefault();
                var id = this.getAttribute('data-id');
                var url = this.getAttribute('data-url');
                var unread = this.getAttribute('data-unread') === 'true';
                
                if (unread) {
                    markAsRead(id, this, url);
                } else if (url && url !== '#' && url !== '') {
                    window.location.href = url;
                }
            });

            container.insertBefore(item, emptyState);
        });

        // Sync badges
        updateBadge(unreadCount);
    }).catch(function () {});
}

// Initial sync in background
loadNotifications();
				</script>
			</div>


			<ul class="flex flex-row items-center justify-end pl-0 mb-0 list-none gap-4">
				{% if app_user %}
					<!-- User Card -->
