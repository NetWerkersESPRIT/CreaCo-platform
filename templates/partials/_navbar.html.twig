<!-- Navbar -->
<nav class="relative flex flex-wrap items-center justify-between px-0 py-2 mx-6 transition-all shadow-none duration-250 ease-soft-in rounded-2xl lg:flex-nowrap lg:justify-start" navbar-main navbar-scroll="true">
	<div class="flex items-center justify-between w-full px-4 py-1 mx-auto flex-wrap-inherit">
		<nav>
			{% set breadcrumb_mapping = {
				'app_home': 'Dashboard',
				'forum_index': 'Forum',
				'app_post_show': 'Forum',
				'app_post_new': 'Forum',
				'app_post_edit': 'Forum',
				'admin_post_pending': 'Pending Posts',
				'admin_post_pending_show': 'Pending Posts',
				'app_useradd': 'Users',
				'app_profile': 'Users',
				'google_signup_start': 'Users',
				'google_signup_check': 'Users',
				'app_auth': 'Login'
			} %}
			{% set current_route = app.request.attributes.get('_route') %}
			{% set module_name = breadcrumb_mapping[current_route] ?? 'Dashboard' %}

			<ol class="flex flex-wrap pt-1 mr-12 bg-transparent rounded-lg sm:mr-16">
				<li class="leading-normal text-sm">
					<a class="opacity-50 text-slate-700" href="javascript:;">Pages</a>
				</li>
				<li class="text-sm pl-2 capitalize leading-normal text-slate-700 before:float-left before:pr-2 before:text-gray-600 before:content-['/']" aria-current="page">
					{% block breadcrumb %}
						{{ module_name }}
					{% endblock %}
				</li>
			</ol>
			<h6 class="mb-0 font-bold capitalize">
				{% block page_title %}
					{{ module_name }}
				{% endblock %}
			</h6>
		</nav>

		<div
			class="flex items-center mt-2 grow sm:mt-0 md:mr-0 lg:flex lg:basis-auto justify-between gap-4">
			<!-- Spacing for right alignment -->
			<div class="flex items-center md:ml-auto md:pr-4"></div>

			<!-- User Info & Actions (Right Side) -->

			<!-- Global Notification Bell -->
			<div
				class="relative flex items-center" id="notif-wrapper" style="margin-right:1.25rem;">

				<!-- Bell Button -->
				<button id="notifBtn" type="button" aria-expanded="false" style="position:relative; background:#fff; margin-left:1rem; display:flex; width:3rem; height:3rem; align-items:center; justify-content:center; border-radius:0.9rem; border:none; cursor:pointer; box-shadow:0 4px 20px rgba(0,0,0,.12); transition:transform .2s, box-shadow .2s;" onmouseover="this.style.transform='scale(1.07)';this.style.boxShadow='0 8px 28px rgba(124,58,237,.25)'" onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,.12)'">
					<i class="fa fa-bell" style="font-size:1.15rem; background:linear-gradient(135deg,#7c3aed,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent;"></i>
					<!-- Unread Badge -->
					<span id="notif-badge" style="display:none; position:absolute; top:-5px; right:-5px; min-width:20px; height:20px; padding:0 5px; align-items:center; justify-content:center; font-size:0.65rem; font-weight:700; color:#fff; background:linear-gradient(135deg,#7c3aed,#ec4899); border-radius:999px; border:2px solid #fff; box-shadow:0 2px 8px rgba(124,58,237,.4);">0</span>
				</button>

				<!-- Dropdown Panel -->
				<div
					id="notifDropdown" style="display:none; opacity:0; transform:translateY(-8px) scale(0.97); transition:opacity .2s ease, transform .2s ease;
																		       position:absolute; right:0; top:calc(100% + 12px);
																		       width:420px; max-width:90vw; z-index:9999;
																		       background:#fff; border-radius:20px;
																		       border:1px solid rgba(124,58,237,.12);
																		       box-shadow:0 24px 64px rgba(0,0,0,.16), 0 4px 24px rgba(124,58,237,.08);
																		       overflow:hidden;">
					<!-- ── Header ── -->
					<div style="display:flex; align-items:center; justify-content:space-between; padding:16px 20px; background:linear-gradient(135deg,#7c3aed11,#ec489911); border-bottom:1px solid rgba(124,58,237,.1);">
						<div style="display:flex; align-items:center; gap:8px;">
							<div style="width:32px; height:32px; border-radius:10px; background:linear-gradient(135deg,#7c3aed,#ec4899); display:flex; align-items:center; justify-content:center;">
								<i class="fa fa-bell" style="color:#fff; font-size:0.9rem;"></i>
							</div>
							<span style="font-weight:700; font-size:1rem; color:#1e293b; letter-spacing:-.01em;">Notifications</span>
							<span id="notif-header-badge" style="display:none; align-items:center; justify-content:center; padding:2px 8px; font-size:0.68rem; font-weight:700; color:#fff; background:linear-gradient(135deg,#7c3aed,#ec4899); border-radius:999px;"></span>
						</div>
						<a href="{{ path('app_notifications') }}" style="font-size:0.82rem; font-weight:600; background:linear-gradient(135deg,#7c3aed,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; text-decoration:none; white-space:nowrap;">
							View all →
						</a>
					</div>

					<!-- ── Notification List ── -->
					<div
						id="notif-list-container" style="overflow-y:auto; max-height:480px; padding:10px 12px; display:flex; flex-direction:column; gap:6px;">
						<!-- JS populates this -->
						<div id="notif-empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 0; color:#94a3b8;">
							<div style="width:52px; height:52px; border-radius:50%; background:#f1f5f9; display:flex; align-items:center; justify-content:center; margin-bottom:12px;">
								<i class="fa fa-bell-slash" style="font-size:1.3rem; opacity:0.4;"></i>
							</div>
							<p style="font-size:0.875rem; margin:0; font-weight:500;">No notifications yet</p>
						</div>
					</div>

					<!-- ── Footer ── -->
					<div style="padding:10px 20px; border-top:1px solid #f1f5f9; background:#fafafa; text-align:center;">
						<a href="{{ path('app_notifications_mark_all_seen') }}" onclick="event.preventDefault(); fetch(this.href, {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}}).then(() => { document.querySelectorAll('.notif-item').forEach(el => el.style.borderLeftColor='transparent'); document.getElementById('notif-badge').style.display='none'; document.getElementById('notif-header-badge').style.display='none'; });" style="font-size:0.75rem; font-weight:600; color:#94a3b8; text-decoration:none; transition:color .15s;" onmouseover="this.style.color='#7c3aed'" onmouseout="this.style.color='#94a3b8'">
							Mark all as read
						</a>
					</div>
				</div>

				<script>
					(function () {
var btn = document.getElementById('notifBtn');
var dropdown = document.getElementById('notifDropdown');
var wrapper = document.getElementById('notif-wrapper');
var container = document.getElementById('notif-list-container');
var emptyState = document.getElementById('notif-empty-state');
var headerBadge = document.getElementById('notif-header-badge');
var badge = document.getElementById('notif-badge');

if (! btn || ! dropdown) 
return;



function openDropdown() {
dropdown.style.display = 'block';
requestAnimationFrame(function () {
dropdown.style.opacity = '1';
dropdown.style.transform = 'translateY(0) scale(1)';
});
btn.setAttribute('aria-expanded', 'true');
}

function closeDropdown() {
dropdown.style.opacity = '0';
dropdown.style.transform = 'translateY(-8px) scale(0.97)';
setTimeout(function () {
dropdown.style.display = 'none';
}, 200);
btn.setAttribute('aria-expanded', 'false');
}

btn.addEventListener('click', function (e) {
e.stopPropagation();
var isOpen = btn.getAttribute('aria-expanded') === 'true';
if (isOpen) {
closeDropdown();
} else {
openDropdown();
loadNotifications();
}
});

document.addEventListener('click', function (e) {
if (wrapper && ! wrapper.contains(e.target)) {
closeDropdown();
}
});

function timeAgo(dateStr) {
var diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
if (diff < 60) 
return diff + 's';


if (diff < 3600) 
return Math.floor(diff / 60) + 'm';


if (diff < 86400) 
return Math.floor(diff / 3600) + 'h';


return Math.floor(diff / 86400) + 'j';
}

function iconForType(type) {
var icons = {
'post_approved': {
icon: 'fa-check',
grad: 'linear-gradient(135deg,#22c55e,#14b8a6)'
},
'post_refused': {
icon: 'fa-times',
grad: 'linear-gradient(135deg,#ef4444,#f43f5e)'
},
'invitation': {
icon: 'fa-envelope-open-text',
grad: 'linear-gradient(135deg,#3b82f6,#06b6d4)'
}
};
return icons[type] || {
icon: 'fa-bell',
grad: 'linear-gradient(135deg,#7c3aed,#ec4899)'
};
}

function loadNotifications() {
fetch('{{ path("app_api_notifications_latest") }}').then(function (r) {
return r.ok ? r.json() : [];
}).then(function (data) { // Remove all existing notif items
container.querySelectorAll('.notif-item').forEach(function (el) {
el.remove();
});

if (! data || data.length === 0) {
emptyState.style.display = 'flex';
return;
}
emptyState.style.display = 'none';

var unreadCount = 0;
data.forEach(function (n) {
var isUnread = ! n.isRead;
if (isUnread) 
unreadCount++;


var ico = iconForType(n.type);

var item = document.createElement('div');
item.className = 'notif-item';
item.style.cssText = 'display:flex; align-items:flex-start; gap:12px; padding:12px 14px; border-radius:14px; cursor:pointer;' + 'border:1px solid ' + (
isUnread ? 'rgba(124,58,237,.2)' : '#f1f5f9'
) + ';' + 'background:' + (
isUnread ? 'linear-gradient(135deg,#fdf4ff,#fce7f3)' : '#fff'
) + ';' + 'border-left:3px solid ' + (
isUnread ? '#7c3aed' : 'transparent'
) + ';' + 'transition:background .15s, border-color .15s;';

if (n.targetUrl) {
item.style.cursor = 'pointer';
item.addEventListener('click', function () {
window.location = n.targetUrl;
});
}

item.innerHTML = '<div style="flex-shrink:0; margin-top:2px; width:36px; height:36px; border-radius:10px; background:' + ico.grad + '; display:flex; align-items:center; justify-content:center;">' + '<i class="fa ' + ico.icon + '" style="color:#fff; font-size:0.85rem;"></i>' + '</div>' + '<div style="flex:1; min-width:0;">' + '<p style="margin:0 0 4px; font-size:0.84rem; font-weight:' + (
isUnread ? '600' : '400'
) + '; color:' + (
isUnread ? '#1e293b' : '#475569'
) + '; line-height:1.4; white-space:normal;">' + n.message + '</p>' + '<span style="font-size:0.72rem; color:#94a3b8;"><i class="fa fa-clock" style="margin-right:3px;"></i>' + timeAgo(n.createdAt) + '</span>' + '</div>' + (
isUnread ? '<span style="flex-shrink:0; margin-top:6px; width:8px; height:8px; border-radius:50%; background:linear-gradient(135deg,#7c3aed,#ec4899);"></span>' : ''
);

container.insertBefore(item, emptyState);
});

// Sync header badge
if (unreadCount > 0) {
headerBadge.textContent = unreadCount;
headerBadge.style.display = 'inline-flex';
} else {
headerBadge.style.display = 'none';
}
}).catch(function () {});
}
})();
				</script>
			</div>


			<ul class="flex flex-row items-center justify-end pl-0 mb-0 list-none gap-4">
				{% if app_user %}
					<!-- User Card -->
					<div class="relative flex min-w-0 mb-0 mt-0 bg-white shadow-soft-xl rounded-xl bg-clip-border">
						<div class="pt-2 pr-4 pl-4 pb-2 flex-col w-md">
							<div class="flex flex-wrap w-full">
								<div class="max-w-full px-3 pr-6 flex items-center">
									<div class="flex flex-col mr-4 text-right">
										<p class="mb-0 font-sans font-semibold leading-normal text-sm text-fuchsia-500">Welcome</p>
										<h5 class="mb-0 font-bold text-slate-700">
											{{ app_user.username }}
										</h5>
									</div>

									{% if app_user.role == 'ROLE_ADMIN' %}
										<span class="py-2 px-2 text-xs rounded-1.8 inline-block whitespace-nowrap text-center bg-gradient-to-tl from-gray-900 to-slate-800 align-baseline font-bold uppercase leading-none text-white">Admin</span>
									{% endif %}
									{% if app_user.role == 'ROLE_CONTENT_CREATOR' %}
										<span class="py-2 px-2 text-xs rounded-1.8 inline-block whitespace-nowrap text-center bg-gradient-to-tl from-purple-700 to-pink-500 align-baseline font-bold uppercase leading-none text-white">Content Creator</span>
									{% endif %}
									{% if app_user.role == 'ROLE_MANAGER' %}
										<span class="py-2 px-2 text-xs rounded-1.8 inline-block whitespace-nowrap text-center bg-gradient-to-tl from-green-600 to-lime-400 align-baseline font-bold uppercase leading-none text-white">Manager</span>
									{% endif %}
									{% if app_user.role == 'ROLE_MEMBER' %}
										<span class="py-2 px-2 text-xs rounded-1.8 inline-block whitespace-nowrap text-center bg-gradient-to-tl from-blue-600 to-cyan-400 align-baseline font-bold uppercase leading-none text-white">Member</span>
									{% endif %}
								</div>

								<div class="w-auto max-w-full px-3 ml-auto -mx-3 text-right flex-0 hover:scale-102 transition-all duration-200 ease-in-out hover:border-4 hover:border-pink-500 hover:rounded-xl rounded-full">
									<a href="{{ path('app_profile') }}">
										<img src="https://raw.githubusercontent.com/creativetimofficial/public-assets/master/soft-ui-dashboard/assets/img/drake.jpg" alt="avatar image" class="inline-flex items-center justify-center w-12 h-12 text-white transition-all duration-200 ease-in-out text-sm rounded-full"/>
									</a>
								</div>
							</div>
						</div>
					</div>

					<!-- Logout Button -->
					<li>
						<a href="{{ path('app_logout') }}">
							<button type="button" class="relative bg-gradient-to-tl p-2 from-red-500 to-pink-500 shadow-soft-2xl ml-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white bg-center stroke-0 text-center hover:scale-105 transition-transform">
								<svg xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" width="25px" height="25px" viewbox="0 0 18 18">
									<path d="M11.75,11.5c-.414,0-.75,.336-.75,.75v2.5c0,.138-.112,.25-.25,.25H5.448l1.725-1.069c.518-.322,.827-.878,.827-1.487V5.557c0-.609-.31-1.166-.827-1.487l-1.725-1.069h5.302c.138,0,.25,.112,.25,.25v2.5c0,.414,.336,.75,.75,.75s.75-.336,.75-.75V3.25c0-.965-.785-1.75-1.75-1.75H4.25c-.965,0-1.75,.785-1.75,1.75V14.75c0,.965,.785,1.75,1.75,1.75h6.5c.965,0,1.75-.785,1.75-1.75v-2.5c0-.414-.336-.75-.75-.75Z" fill="rgba(255, 255, 255, 1)"></path>
									<path d="M17.78,8.47l-2.75-2.75c-.293-.293-.768-.293-1.061,0s-.293,.768,0,1.061l1.47,1.47h-4.189c-.414,0-.75,.336-.75,.75s.336,.75,.75,.75h4.189l-1.47,1.47c-.293,.293-.293,.768,0,1.061,.146,.146,.338,.22,.53,.22s.384-.073,.53-.22l2.75-2.75c.293-.293,.293-.768,0-1.061Z" fill="rgba(255, 255, 255, 1)" data-color="color-2"></path>
								</svg>
							</button>
						</a>
					</li>
				{% endif %}
			</ul>
		</div>
	</div>
</nav>
<!-- end Navbar -->
