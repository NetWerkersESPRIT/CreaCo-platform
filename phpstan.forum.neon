includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon

parameters:
    level: 5
    paths:
        # Contrôleurs
        - src/Controller/Forum
        - src/Controller/Forum/PostController.php
        - src/Controller/Forum/CommentController.php
        
        # Entités
        - src/Entity/Post.php
        - src/Entity/Comment.php
        - src/Entity/PostReaction.php
        
        # Repositories
        - src/Repository/PostRepository.php
        - src/Repository/CommentRepository.php
        - src/Repository/PostReactionRepository.php
        
        # Formulaires
        - src/Form/PostType.php
        - src/Form/CommentType.php
        
        # Services (directement dans src/Service/)
        - src/Service/ProfanityFilterService.php
        - src/Service/TextGearsService.php
        - src/Service/SpamDetectionService.php
        - src/Service/SentimentService.php

    # Configuration Symfony
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml

    # Ignorer certaines erreurs spécifiques au forum
    ignoreErrors:
        # Doctrine ID errors
        - '#Property .*::\$id .* never assigned int#'
        - '#Method .*::getCreatedAt\(\) should return .* but returns .*#'
        
        # Ignorer temporairement les erreurs de null coalesce (à corriger plus tard)
        - '#Offset .* on left side of \?\? always exists#'
        
        # Ignorer les méthodes non trouvées dans les repositories (à implémenter)
        - '#Call to an undefined method .*::findPublishedPinnedFirst\(\)#'
        - '#Call to an undefined method .*::findUnnotifiedModerationPosts\(\)#'

    # Traiter les types PHPdoc comme certains ou non
    treatPhpDocTypesAsCertain: false